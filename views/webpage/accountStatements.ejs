<!DOCTYPE html>
<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Account Statement | WicketAdda</title>
    <link rel="icon" type="image/png" href="https://ik.imagekit.io/xcrdwi6be/Batting_assets/bmcn2NR451G1XkRXqUlOZz.png" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#e1fdff", "primary-container": "#00f2ff", "primary-fixed-dim": "#00dbe7",
                        "on-primary": "#00363a", "secondary": "#4edea3", "secondary-container": "#00a572",
                        "error": "#ffb4ab", "error-container": "#93000a",
                        "background": "#131313", "surface": "#131313", "surface-container-lowest": "#0e0e0e",
                        "surface-container-low": "#1c1b1b", "surface-container": "#201f1f", "surface-container-high": "#2a2a2a",
                        "on-surface": "#e5e2e1", "on-surface-variant": "#b9cacb"
                    },
                    fontFamily: { "body": ["Inter", "sans-serif"] },
                    borderRadius: { "2xl": "1.5rem" },
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .glass-card {
            background: linear-gradient(135deg, rgba(0, 242, 255, 0.08) 0%, rgba(0, 242, 255, 0.02) 100%);
            border: 1px solid rgba(225, 253, 255, 0.05);
        }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>

<body class="bg-background text-on-surface font-body selection:bg-primary-container selection:text-on-primary-container min-h-screen">
    
    <nav class="fixed top-0 w-full z-50 bg-[#131313]/80 backdrop-blur-xl shadow-[0_20px_40px_rgba(0,219,231,0.04)]">
        <div class="flex items-center justify-between px-6 h-16 w-full max-w-2xl mx-auto">
            <div class="flex items-center gap-4">
                <a href="/home" class="text-[#00f2ff] hover:bg-[#2a2a2a] transition-colors duration-200 active:scale-95 p-1 rounded-full flex items-center justify-center">
                    <span class="material-symbols-outlined">arrow_back</span>
                </a>
                <h1 class="font-bold tracking-tight text-lg text-[#00f2ff]">Account Statement</h1>
            </div>
        </div>
        <div class="bg-[#1c1b1b] h-[1px] w-full opacity-10"></div>
    </nav>

    <main class="pt-20 pb-24 px-4 max-w-2xl mx-auto">
        <section class="mb-6">
            <div class="glass-card rounded-2xl p-6 backdrop-blur-2xl relative overflow-hidden group shadow-lg">
                <div class="absolute -top-24 -right-24 w-48 h-48 bg-primary-container/10 blur-[80px] rounded-full pointer-events-none"></div>
                <div class="relative z-10">
                    <p class="text-on-surface-variant text-sm font-medium tracking-wide flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px]">account_balance_wallet</span>
                        Current Wallet Balance
                    </p>
                    <div class="mt-2 flex items-baseline gap-1">
                        <span class="text-primary font-black text-4xl tracking-tighter">
                            ₹<%= Math.floor(user.balance).toLocaleString('en-IN') %>
                        </span>
                        <span class="text-on-surface-variant font-medium text-lg">
                            .<%= (user.balance % 1).toFixed(2).substring(2) %>
                        </span>
                    </div>
                    <div class="mt-6 flex gap-3">
                        <a href="/transaction/deposit" class="flex-1 bg-gradient-to-r from-primary-fixed-dim to-primary-container text-on-primary py-3 rounded-xl font-bold text-sm text-center active:scale-95 transition-transform">
                            Add Cash
                        </a>
                        <a href="/transaction/withdraw" class="flex-1 border border-white/5 bg-white/5 text-primary py-3 rounded-xl font-bold text-sm text-center active:scale-95 transition-transform hover:bg-white/10">
                            Withdraw
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <section class="mb-6 flex gap-3 items-center overflow-x-auto pb-2 no-scrollbar">
            <div class="relative min-w-[150px]">
                <select id="txn-filter" onchange="filterTransactions()" class="appearance-none w-full bg-surface-container-low border border-white/5 rounded-xl px-4 py-2.5 text-sm font-medium text-on-surface focus:ring-1 focus:ring-primary-container outline-none transition-all cursor-pointer">
                    <option value="all">All Transactions</option>
                    <option value="deposit">Deposits</option>
                    <option value="withdrawal">Withdrawals</option>
                    <option value="bet_placed">Bets Placed (Deductions)</option>
                    <option value="bet_won">Bets Won (Profits)</option>
                    <option value="bet_lost">Bets Lost (Settled)</option> 
                    <option value="refund">Refunds</option>
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none text-sm">expand_more</span>
            </div>
        </section>

        <div id="ledger-container" class="space-y-2">
            
            <% if (typeof statement !== 'undefined' && statement.length > 0) { %>
                
                <% 
                    let lastDateStr = null;
                    
                    // IST FORMATTING LOGIC
                    const istOptions = { timeZone: 'Asia/Kolkata', year: 'numeric', month: '2-digit', day: '2-digit' };
                    const now = new Date();
                    const todayDate = now.toLocaleDateString('en-IN', istOptions);
                    const yesterdayDate = new Date(now.getTime() - 86400000).toLocaleDateString('en-IN', istOptions);

                    statement.forEach(txn => { 
                        const txnDateObj = new Date(txn.createdAt);
                        const txnDateString = txnDateObj.toLocaleDateString('en-IN', istOptions);
                        
                        let dateHeader = "";
                        if (txnDateString === todayDate) {
                            dateHeader = `Today — ${txnDateObj.toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', month: 'short', day: 'numeric' })}`;
                        } else if (txnDateString === yesterdayDate) {
                            dateHeader = `Yesterday — ${txnDateObj.toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', month: 'short', day: 'numeric' })}`;
                        } else {
                            dateHeader = txnDateObj.toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', weekday: 'long', month: 'short', day: 'numeric' });
                        }

                        if (dateHeader !== lastDateStr) { 
                            if (lastDateStr !== null) { %> </div></div> <% } 
                %>
                            <div class="date-group mt-6">
                                <h3 class="text-on-surface-variant text-[11px] font-black uppercase tracking-[0.15em] mb-4 px-1">
                                    <%= dateHeader %>
                                </h3>
                                <div class="space-y-3">
                <% 
                            lastDateStr = dateHeader;
                        } 

                        let icon, iconColor, bgIconColor, title, subtitle, sign, amountColor, runningBal;

                        if (txn.type === 'deposit') {
                            icon = 'add'; iconColor = 'text-secondary'; bgIconColor = 'bg-secondary-container/10';
                            title = 'Deposit'; subtitle = `Status: ${txn.status || 'Completed'}`;
                            sign = '+'; amountColor = 'text-secondary'; runningBal = '—';
                        } else if (txn.type === 'withdrawal') {
                            icon = 'account_balance_wallet'; iconColor = 'text-error'; bgIconColor = 'bg-error-container/10';
                            title = 'Withdrawal'; subtitle = `Status: ${txn.status || 'Pending'}`;
                            sign = '-'; amountColor = 'text-error'; runningBal = '—';
                        } else if (txn.type === 'bet_placed') {
                            icon = 'north_east'; iconColor = 'text-error'; bgIconColor = 'bg-error-container/10';
                            title = 'Bet Placed'; subtitle = txn.betId ? txn.betId.eventName : txn.remarks;
                            sign = '-'; amountColor = 'text-error'; runningBal = `Bal: ₹${txn.balanceAfter ? txn.balanceAfter.toLocaleString('en-IN') : 'N/A'}`;
                        } else if (txn.type === 'bet_won') {
                            icon = 'south_west'; 
                            iconColor = 'text-secondary'; 
                            bgIconColor = 'bg-secondary-container/10';
                            title = txn.betId ? `Won: ${txn.betId.selection}` : 'Winnings'; 
                            subtitle = txn.betId ? txn.betId.eventName : txn.remarks;
                            sign = '+'; 
                            amountColor = 'text-secondary'; 
                            runningBal = `Bal: ₹${txn.balanceAfter ? txn.balanceAfter.toLocaleString('en-IN') : 'N/A'}`;
                        } else if (txn.type === 'bet_lost') {
                            icon = 'close'; 
                            iconColor = 'text-error'; 
                            bgIconColor = 'bg-error-container/10';
                            title = txn.betId ? `Lost: ${txn.betId.selection}` : 'Bet Lost'; 
                            subtitle = txn.betId ? txn.betId.eventName : txn.remarks;
                            sign = '-'; 
                            amountColor = 'text-error';
                        } else if (txn.type === 'refund') {
                            icon = 'undo'; iconColor = 'text-primary-container'; bgIconColor = 'bg-primary-container/10';
                            title = 'Refund'; subtitle = txn.remarks;
                            sign = '+'; amountColor = 'text-primary-container'; runningBal = `Bal: ₹${txn.balanceAfter ? txn.balanceAfter.toLocaleString('en-IN') : 'N/A'}`;
                        } else {
                            icon = 'swap_horiz'; iconColor = 'text-on-surface'; bgIconColor = 'bg-white/5';
                            title = 'Adjustment'; subtitle = txn.remarks || 'Admin adjustment';
                            sign = txn.amount > 0 ? '+' : '-'; amountColor = txn.amount > 0 ? 'text-secondary' : 'text-error';
                            runningBal = txn.balanceAfter ? `Bal: ₹${txn.balanceAfter.toLocaleString('en-IN')}` : '—';
                        }

                        const displayAmount = Math.abs(txn.amount);
                %>
                        <div class="txn-item bg-surface-container-low rounded-2xl p-4 flex items-center justify-between border border-white/5 hover:bg-surface-container-high transition-all" data-type="<%= txn.type %>">
                            <div class="flex items-center gap-4 min-w-0 pr-4">
                                <div class="w-12 h-12 shrink-0 rounded-full <%= bgIconColor %> flex items-center justify-center">
                                    <span class="material-symbols-outlined <%= iconColor %>"><%= icon %></span>
                                </div>
                                <div class="min-w-0">
                                    <h4 class="text-on-surface font-semibold text-[15px] truncate"><%= title %></h4>
                                    <p class="text-on-surface-variant text-[11px] mt-0.5 truncate">
                                        <%= txnDateObj.toLocaleTimeString('en-IN', { timeZone: 'Asia/Kolkata', hour: '2-digit', minute: '2-digit', hour12: true }) %> • <%= subtitle %>
                                    </p>
                                </div>
                            </div>
                            <div class="text-right shrink-0">
                                <div class="<%= amountColor %> font-black text-base">
                                    <%= sign %>₹<%= displayAmount.toLocaleString('en-IN') %>
                                </div>
                                <div class="text-on-surface-variant text-[10px] mt-0.5 font-medium tracking-wide">
                                    <%= runningBal %>
                                </div>
                            </div>
                        </div>

                <% }); %>
                <% if (lastDateStr !== null) { %> </div></div> <% } %>

                <% if (totalPages > 1) { %>
                    <div class="flex items-center justify-between mt-8 border-t border-white/10 pt-6 px-1">
                        <a href="?page=<%= currentPage - 1 %>" 
                           class="<%= !hasPrevPage ? 'pointer-events-none opacity-40' : 'hover:bg-white/10' %> flex items-center gap-1 px-4 py-2.5 rounded-xl border border-white/5 bg-surface-container-low text-primary text-sm font-bold transition-all">
                            <span class="material-symbols-outlined text-[18px]">chevron_left</span> Prev
                        </a>
                        
                        <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest bg-[#1c1b1b] px-4 py-2 rounded-lg border border-white/5">
                            Page <%= currentPage %> of <%= totalPages %>
                        </span>
                        
                        <a href="?page=<%= currentPage + 1 %>" 
                           class="<%= !hasNextPage ? 'pointer-events-none opacity-40' : 'hover:bg-white/10' %> flex items-center gap-1 px-4 py-2.5 rounded-xl border border-white/5 bg-surface-container-low text-primary text-sm font-bold transition-all">
                            Next <span class="material-symbols-outlined text-[18px]">chevron_right</span>
                        </a>
                    </div>
                <% } %>
                <% } else { %>
                <div class="flex flex-col items-center justify-center py-16 px-4 text-center">
                    <div class="w-16 h-16 rounded-full bg-white/5 flex items-center justify-center mb-4">
                        <span class="material-symbols-outlined text-white/20 text-3xl">receipt_long</span>
                    </div>
                    <h3 class="text-white font-bold mb-1">No Transactions Yet</h3>
                    <p class="text-white/40 text-xs">Your financial history will appear here once you make a deposit or place a bet.</p>
                </div>
            <% } %>

        </div>
    </main>

    <div class="fixed top-1/4 -left-20 w-64 h-64 bg-primary-container/5 blur-[120px] rounded-full pointer-events-none -z-10"></div>
    <div class="fixed bottom-1/4 -right-20 w-64 h-64 bg-secondary-container/5 blur-[120px] rounded-full pointer-events-none -z-10"></div>

    <script>
        function filterTransactions() {
            const filterValue = document.getElementById('txn-filter').value;
            const dateGroups = document.querySelectorAll('.date-group');

            dateGroups.forEach(group => {
                let hasVisibleItems = false;
                const items = group.querySelectorAll('.txn-item');
                
                items.forEach(item => {
                    const itemType = item.getAttribute('data-type');
                    
                    if (filterValue === 'all' || itemType === filterValue) {
                        item.style.display = 'flex'; 
                        hasVisibleItems = true;
                    } else {
                        item.style.display = 'none';
                    }
                });

                if (hasVisibleItems) {
                    group.style.display = 'block';
                } else {
                    group.style.display = 'none';
                }
            });
        }
    </script>
</body>
</html>