<!DOCTYPE html>
<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Daily Spin & Win | WicketAdda.in</title>
    
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>

    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "surface": "#131313",
                        "primary": "#ffb77d",
                        "primary-container": "#ff8c00",
                        "background": "#0a0a0a",
                        "surface-container-highest": "#2a2a2a",
                        "success": "#28a745",
                    },
                    fontFamily: {
                        "headline": ["Space Grotesk", "sans-serif"],
                        "body": ["Inter", "sans-serif"],
                    },
                },
            },
        }
    </script>

    <style>
        body {
            background-color: #0a0a0a;
            color: #e5e2e1;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
            min-height: 100dvh;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .glass-panel {
            background: rgba(26, 26, 26, 0.8);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 140, 0, 0.2);
        }

        /* Animated Glowing Shadow for the Wheel */
        @keyframes pulseGlow {
            0% { box-shadow: 0 0 20px rgba(255, 140, 0, 0.2), inset 0 0 10px rgba(255, 140, 0, 0.1); }
            50% { box-shadow: 0 0 50px rgba(255, 140, 0, 0.6), inset 0 0 20px rgba(255, 140, 0, 0.4); }
            100% { box-shadow: 0 0 20px rgba(255, 140, 0, 0.2), inset 0 0 10px rgba(255, 140, 0, 0.1); }
        }
        .spin-wheel-border {
            animation: pulseGlow 2s infinite ease-in-out;
            border: 6px solid #ff8c00;
        }

        .reward-gradient {
            background: linear-gradient(135deg, #ffb77d 0%, #ff8c00 100%);
        }
        
        .no-scrollbar::-webkit-scrollbar { display: none; }
    </style>
</head>

<body class="min-h-screen flex flex-col relative">
    
    <header class="w-full z-50 flex items-center justify-between p-6 absolute top-0 left-0">
        <h1 class="font-headline font-black text-2xl tracking-tighter text-[#ff8c00] drop-shadow-[0_0_10px_rgba(255,140,0,0.5)]">
            WicketAdda.in
        </h1>
    </header>

    <main class="flex-grow pt-24 pb-12 px-6 flex flex-col items-center max-w-md mx-auto w-full z-10">
        
        <section class="text-center mb-8 w-full">
            <p class="font-headline text-[#ffb77d] text-xs font-bold tracking-[0.2em] uppercase mb-2 animate-pulse">
                Guaranteed Prizes Inside!
            </p>
            <h2 class="font-headline text-4xl font-extrabold tracking-tight mb-8 text-white">
                 Spin <span class="text-[#ff8c00]">&</span> Win
            </h2>

            <div class="relative w-[300px] h-[300px] mx-auto mb-8">
                <div class="absolute -top-4 left-1/2 -translate-x-1/2 z-20">
                    <div class="w-0 h-0 border-l-[15px] border-l-transparent border-r-[15px] border-r-transparent border-t-[28px] border-t-[#ff8c00] drop-shadow-[0_4px_10px_rgba(255,140,0,0.8)]"></div>
                </div>

                <div id="spin-wheel" class="w-full h-full rounded-full spin-wheel-border relative overflow-hidden bg-surface transition-transform"
                     style="background: conic-gradient(from -45deg, #3a1500 0 90deg, #1a1a1a 90deg 180deg, #3a1500 180deg 270deg, #1a1a1a 270deg 360deg);">
                    
                    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-14 h-14 bg-gradient-to-br from-[#ffb77d] to-[#ff8c00] rounded-full z-10 shadow-[0_0_20px_rgba(0,0,0,0.8)] border-4 border-[#131313] flex items-center justify-center">
                        <span class="material-symbols-outlined text-[#131313] text-2xl font-bold" style="font-variation-settings: 'FILL' 1;">bolt</span>
                    </div>

                    <div class="absolute inset-0 pointer-events-none font-headline font-black text-xs text-white uppercase text-center drop-shadow-md">
                        <div class="absolute top-[15%] left-1/2 -translate-x-1/2 w-24 text-[#ffb77d]">Rs. 10,000 Cash</div>
                        <div class="absolute top-1/2 right-[5%] -translate-y-1/2 rotate-90 w-24 text-[#83fc8e] text-sm">100% Bonus</div>
                        <div class="absolute bottom-[15%] left-1/2 -translate-x-1/2 rotate-180 w-24 text-white/70">Better Luck</div>
                        <div class="absolute top-1/2 left-[5%] -translate-y-1/2 -rotate-90 w-24 text-[#ffb77d]">200% Bonus</div>
                    </div>
                </div>
            </div>
        </section>

        <div class="w-full space-y-8">
            <button id="spin-btn" onclick="executeRiggedSpin()" class="reward-gradient w-full py-5 rounded-2xl font-headline font-extrabold text-2xl tracking-widest text-[#2f1500] uppercase shadow-[0_10px_40px_rgba(255,140,0,0.5)] active:scale-95 hover:brightness-110 transition-all duration-200">
                SPIN NOW
            </button>

            <div class="glass-panel rounded-2xl p-5 shadow-2xl">
                <div class="flex items-center gap-3 mb-4 border-b border-white/10 pb-3">
                    <span class="material-symbols-outlined text-[#ff8c00] animate-pulse">sensors</span>
                    <h3 class="font-headline font-bold text-sm tracking-widest uppercase text-[#ff8c00]">Live Payouts</h3>
                </div>
                
                <div id="winners-feed" class="space-y-3 h-32 overflow-hidden relative">
                    </div>
            </div>
        </div>
    </main>

    <div id="reward-popup" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/90 backdrop-blur-sm transition-opacity">
        <div class="bg-[#1a1a1a] border border-[#ff8c00]/50 rounded-3xl p-8 max-w-sm w-11/12 text-center shadow-[0_0_80px_rgba(255,140,0,0.3)] transform scale-0 transition-transform duration-500" id="popup-content">
            
            <div class="w-20 h-20 bg-gradient-to-br from-[#83fc8e] to-[#28a745] rounded-full flex items-center justify-center mx-auto mb-6 shadow-[0_0_30px_rgba(40,167,69,0.5)]">
                <span class="material-symbols-outlined text-black text-4xl" style="font-variation-settings: 'FILL' 1;">redeem</span>
            </div>

            <h2 class="font-headline font-black text-3xl text-white mb-2 tracking-tight">JACKPOT!</h2>
            <p class="text-gray-300 mb-6 font-medium">You have won the <span class="text-[#83fc8e] font-bold text-lg">100% Deposit Bonus!</span></p>
            
            <div class="bg-black/50 rounded-xl p-4 border border-dashed border-[#ff8c00]/50 mb-6">
                <p class="text-xs text-gray-400 uppercase tracking-widest mb-1">Your Secret Coupon Code</p>
                <p id="coupon-code" class="font-mono text-2xl font-bold text-[#ff8c00] tracking-widest">WA-XXXX</p>
            </div>

            <button onclick="claimViaWhatsApp()" class="w-full bg-[#25D366] hover:bg-[#20b858] text-white font-black text-lg py-4 rounded-xl shadow-[0_10px_20px_rgba(37,211,102,0.3)] active:scale-95 transition-all flex items-center justify-center gap-2 uppercase tracking-wide">
                <span class="material-symbols-outlined">chat</span> Claim 100% Bonus
            </button>
        </div>
    </div>

    <div class="fixed top-0 right-0 w-96 h-96 bg-[#ff8c00]/10 rounded-full blur-[120px] pointer-events-none z-0"></div>
    <div class="fixed bottom-0 left-0 w-96 h-96 bg-[#ff8c00]/10 rounded-full blur-[120px] pointer-events-none z-0"></div>

    <script>
        // -----------------------------------------
        // 1. DYNAMIC FAKE WINNERS FEED LOGIC
        // -----------------------------------------
        const names = ["Rahul K.", "Vikram S.", "Priya M.", "Amit P.", "Sneha R.", "Rohan D.", "Karan B.", "Neha T.", "Arjun V.", "Pooja J."
            , "Aditya L.", "Sonal G.", "Manish K.", "Anjali S.", "Vishal R.", "Divya M.", "Suresh P.", "Kavya N.", "Ravi D.", "Meera T."
            , "Ashish B.", "Nisha J.", "Sanjay L.", "Pallavi G.", "Deepak K.", "Ritika S.", "Anil R.", "Shreya M.", "Kunal P.", "Isha N.",
                "Vijay D.", "Sneha T.", "Rahul B.", "Pooja J.", "Amit L.", "Kavya G.", "Rohan K.", "Anjali S.", "Suresh R.", "Neha M."
                , "Arjun P.", "Divya N.", "Manish D.", "Sonal T.", "Aditya B.", "Meera J.", "Vishal L.", "Anil G.", "Ritika K.", "Ashish S."
                , "Isha R.", "Sanjay M.", "Pallavi P.", "Deepak N." , "Ravi T.", "Shreya B.", "Kunal J.", "Vijay L.", "Sonal G.", "Rahul K.", "Pooja M."
        ];
        const rewards = ["Rs. 10,000 Cash", "100% Deposit Bonus", "200% Deposit Bonus"];
        const feedContainer = document.getElementById('winners-feed');

        function createWinnerRow() {
            const name = names[Math.floor(Math.random() * names.length)];
            const reward = rewards[Math.floor(Math.random() * rewards.length)];
            const time = Math.floor(Math.random() * 59) + 1; // 1 to 59 seconds ago
            const initial = name.charAt(0);

            const row = document.createElement('div');
            row.className = "flex items-center justify-between py-1 transition-all duration-500 opacity-0 translate-y-4";
            row.innerHTML = `
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-[#2a2a2a] flex items-center justify-center text-[10px] font-bold text-[#ffb77d] border border-white/5">${initial}</div>
                    <span class="text-sm font-medium text-white/90">${name} won <span class="text-[#ff8c00] font-bold">${reward}</span></span>
                </div>
                <span class="text-[10px] text-white/40">${time}s ago</span>
            `;
            return row;
        }

        function updateWinnersFeed() {
            const newRow = createWinnerRow();
            feedContainer.prepend(newRow); // Add to top
            
            // Trigger animation
            setTimeout(() => {
                newRow.classList.remove('opacity-0', 'translate-y-4');
            }, 50);

            // Remove oldest child if there are more than 3 to keep it clean
            if (feedContainer.children.length > 3) {
                const lastChild = feedContainer.lastElementChild;
                lastChild.classList.add('opacity-0');
                setTimeout(() => lastChild.remove(), 500);
            }
        }

        // Initialize feed with 3 items immediately, then update every 2.5 seconds
        updateWinnersFeed(); updateWinnersFeed(); updateWinnersFeed();
        setInterval(updateWinnersFeed, 2500);


        // -----------------------------------------
        // 2. RIGGED WHEEL SPIN LOGIC
        // -----------------------------------------
        let generatedCode = "";

        function executeRiggedSpin() {
            const wheel = document.getElementById('spin-wheel');
            const btn = document.getElementById('spin-btn');
            
            btn.disabled = true;
            btn.innerText = "SPINNING...";
            btn.classList.add('opacity-80', 'cursor-not-allowed');

            // The "100% Bonus" is positioned exactly at 90 degrees (Right side).
            // To bring the Right side (90 deg) to the Top pointer (0 deg), 
            // the wheel needs to rotate backwards by 90deg, or forwards by 270deg.
            
            const extraSpins = 360 * 8; // Spin around 8 full times for dramatic effect
            const targetRotation = extraSpins + 270; // Lands perfectly on 100% Bonus!

            // Apply realistic deceleration spin
            wheel.style.transition = 'transform 5s cubic-bezier(0.15, 0.85, 0.15, 1)'; 
            wheel.style.transform = `rotate(${targetRotation}deg)`;

            // Wait for wheel to stop
            setTimeout(() => {
                triggerSuccess();
            }, 5200); 
        }

        // -----------------------------------------
        // 3. SUCCESS, CONFETTI & WHATSAPP LOGIC
        // -----------------------------------------
        function triggerSuccess() {
            // Generate Random Code
            const randomString = Math.random().toString(36).substring(2, 6).toUpperCase();
            generatedCode = `WA-${randomString}`;
            document.getElementById('coupon-code').innerText = generatedCode;

            // Fire Confetti!
            var duration = 3 * 1000;
            var end = Date.now() + duration;

            (function frame() {
                confetti({
                    particleCount: 5,
                    angle: 60,
                    spread: 55,
                    origin: { x: 0 },
                    colors: ['#ff8c00', '#28a745', '#ffffff']
                });
                confetti({
                    particleCount: 5,
                    angle: 120,
                    spread: 55,
                    origin: { x: 1 },
                    colors: ['#ff8c00', '#28a745', '#ffffff']
                });

                if (Date.now() < end) {
                    requestAnimationFrame(frame);
                }
            }());

            // Show Popup Modal with Animation
            const popup = document.getElementById('reward-popup');
            const popupContent = document.getElementById('popup-content');
            
            popup.classList.remove('hidden');
            popup.classList.add('flex');
            
            // Tiny delay to allow display:flex to apply before animating scale
            setTimeout(() => {
                popupContent.classList.remove('scale-0');
                popupContent.classList.add('scale-100');
            }, 50);
        }

        function claimViaWhatsApp() {
            // Replace '918102073403' with your actual WhatsApp support number if needed
            const phoneNumber = "918102073403"; 
            const message = encodeURIComponent(`Hi WicketAdda! I just won the 100% Deposit Bonus from the Daily Spin! My secret coupon code is: ${generatedCode}. How do I claim it?`);
            const whatsappUrl = `https://wa.me/${phoneNumber}?text=${message}`;
            
            window.location.href = whatsappUrl;
        }
    </script>
</body>
</html>