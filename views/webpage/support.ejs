<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Help &amp; Support | WicketAdda</title>
    <link rel="icon" type="image/png" href="https://ik.imagekit.io/xcrdwi6be/Batting_assets/bmcn2NR451G1XkRXqUlOZz.png" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#e1fdff",
                        "on-surface": "#e5e2e1",
                        "on-surface-variant": "#b9cacb",
                        "surface-container-lowest": "#0e0e0e",
                        "surface-container": "#201f1f",
                        "surface-container-high": "#2a2a2a",
                        "primary-container": "#00f2ff",
                        "on-primary": "#00363a",
                        "primary-fixed-dim": "#00dbe7",
                        "secondary": "#4edea3",
                        "outline-variant": "#3a494b",
                    },
                    fontFamily: { "headline": ["Inter"], "body": ["Inter"], "label": ["Inter"] },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "2xl": "1rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        body { background-color: #131313; color: #e5e2e1; font-family: 'Inter', sans-serif; min-height: max(884px, 100dvh); }
        .glass-card { background: linear-gradient(180deg, rgba(0, 242, 255, 0.05) 0%, rgba(0, 242, 255, 0) 100%); backdrop-filter: blur(12px); }
        .tab-active { color: #00f2ff; border-bottom: 2px solid #00f2ff; }
        .tab-inactive { color: #b9cacb; border-bottom: 2px solid transparent; }
    </style>
</head>

<body class="flex flex-col min-h-screen pb-24">
    <header class="fixed top-0 w-full z-50 bg-[#131313] shadow-[0_20px_40px_rgba(0,219,231,0.04)]">
        <div class="flex items-center px-5 h-16 w-full max-w-2xl mx-auto">
            <a href="/home" class="text-[#00f2ff] active:scale-95 transition-transform mr-4 flex items-center">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
            <h1 class="text-[#e1fdff] font-headline font-bold text-lg tracking-tight">Help &amp; Support</h1>
        </div>
        <div class="bg-[#1c1b1b] h-[2.5px] w-full"></div>
    </header>

    <nav class="mt-16 bg-[#201f1f] rounded-t-[1.5rem] flex justify-around items-center w-full max-w-2xl mx-auto py-4 px-6 relative z-10">
        <button id="btn-raise" onclick="switchTab('raise')" class="font-headline text-sm font-medium uppercase tracking-wider transition-all duration-300 ease-in-out pb-2 tab-active">
            Raise a Ticket
        </button>
        <button id="btn-history" onclick="switchTab('history')" class="font-headline text-sm font-medium uppercase tracking-wider transition-all duration-300 ease-in-out pb-2 tab-inactive hover:text-[#e1fdff]">
            My Past Tickets
        </button>
    </nav>

    <main class="flex-1 px-5 pt-8 max-w-2xl mx-auto w-full">

        <% if (locals.success && success.length > 0) { %>
            <div class="mb-6 p-4 bg-secondary/10 border border-secondary/30 rounded-xl text-secondary text-sm font-bold flex gap-2 items-center">
                <span class="material-symbols-outlined">check_circle</span>
                <%= success %>
            </div>
        <% } %>
        <% if (locals.error && error.length > 0) { %>
            <div class="mb-6 p-4 bg-red-500/10 border border-red-500/30 rounded-xl text-red-500 text-sm font-bold flex gap-2 items-center">
                <span class="material-symbols-outlined">error</span>
                <%= error %>
            </div>
        <% } %>

        <section class="space-y-6 block animate-in fade-in duration-300" id="raise-ticket">
            <div class="space-y-2">
                <h2 class="text-on-surface font-headline font-bold text-xl tracking-tight">Create New Request</h2>
                <p class="text-on-surface-variant text-sm">Our 24/7 support team usually responds within 15 minutes.</p>
            </div>
            
            <form action="/user/support/complaint" method="POST" class="space-y-5">
                <div class="space-y-2">
                    <label class="block text-xs font-label uppercase tracking-widest text-on-surface-variant px-1">Category *</label>
                    <div class="relative">
                        <select name="category" required class="w-full bg-surface-container-lowest border border-outline-variant/15 rounded-2xl py-4 px-5 text-on-surface appearance-none focus:ring-2 focus:ring-primary-container focus:border-transparent transition-all outline-none">
                            <option value="Deposit Issue">Deposit Issue</option>
                            <option value="Withdrawal Issue">Withdrawal Issue</option>
                            <option value="Bet Settlement">Bet Settlement</option>
                            <option value="Technical Bug">Technical Bug</option>
                            <option value="Other">Other</option>
                        </select>
                        <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-on-surface-variant">
                            <span class="material-symbols-outlined">expand_more</span>
                        </div>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="block text-xs font-label uppercase tracking-widest text-on-surface-variant px-1">Reference ID (Optional)</label>
                    <input name="referenceId" type="text" class="w-full bg-surface-container-lowest border border-outline-variant/15 rounded-2xl py-4 px-5 text-on-surface focus:ring-2 focus:ring-primary-container focus:border-transparent transition-all outline-none placeholder:text-on-surface-variant/40" placeholder="e.g. BET-99210 or TXN-882" />
                </div>

                <div class="space-y-2">
                    <label class="block text-xs font-label uppercase tracking-widest text-on-surface-variant px-1">Subject *</label>
                    <input name="subject" type="text" required maxlength="100" class="w-full bg-surface-container-lowest border border-outline-variant/15 rounded-2xl py-4 px-5 text-on-surface focus:ring-2 focus:ring-primary-container focus:border-transparent transition-all outline-none placeholder:text-on-surface-variant/40" placeholder="Brief summary of the issue" />
                </div>

                <div class="space-y-2">
                    <label class="block text-xs font-label uppercase tracking-widest text-on-surface-variant px-1">Issue Details *</label>
                    <textarea name="description" required maxlength="1000" rows="5" class="w-full bg-surface-container-lowest border border-outline-variant/15 rounded-2xl py-4 px-5 text-on-surface focus:ring-2 focus:ring-primary-container focus:border-transparent transition-all outline-none placeholder:text-on-surface-variant/40 resize-none" placeholder="Describe your issue in detail..."></textarea>
                </div>

                <div class="pt-4 pb-10">
                    <button type="submit" class="w-full py-5 rounded-2xl bg-gradient-to-r from-primary-fixed-dim to-primary-container text-on-primary font-bold text-lg shadow-[0_0_25px_rgba(0,242,255,0.3)] active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                        Submit Ticket
                        <span class="material-symbols-outlined text-xl">send</span>
                    </button>
                </div>
            </form>
        </section>

        <section class="pb-10 hidden animate-in fade-in duration-300" id="past-tickets">
            <div class="flex items-center justify-between mb-6 px-1">
                <h2 class="text-on-surface font-headline font-bold text-xl tracking-tight">Recent Tickets</h2>
            </div>
            
            <div class="space-y-4">
                <% if (tickets && tickets.length > 0) { %>
                    <% tickets.forEach(ticket => { %>
                        <% 
                            let borderColor = "border-outline-variant/30";
                            let badgeClass = "bg-surface-container-highest text-on-surface-variant border-outline-variant/15";
                            let iconHtml = "";
                            
                            if (ticket.status === 'Open') {
                                borderColor = "border-yellow-500/50";
                                badgeClass = "bg-yellow-500/10 text-yellow-400 border-yellow-500/20";
                                iconHtml = '<span class="w-1.5 h-1.5 rounded-full bg-yellow-500 animate-pulse"></span>';
                            } else if (ticket.status === 'In Progress') {
                                borderColor = "border-blue-500/50";
                                badgeClass = "bg-blue-500/10 text-blue-400 border-blue-500/20";
                                iconHtml = '<span class="material-symbols-outlined text-[12px]">pending</span>';
                            } else if (ticket.status === 'Resolved') {
                                borderColor = "border-secondary/50";
                                badgeClass = "bg-secondary/10 text-secondary border-secondary/20";
                                iconHtml = '<span class="material-symbols-outlined text-[12px]">check_circle</span>';
                            } else if (ticket.status === 'Closed') {
                                badgeClass = "bg-surface-container-highest text-on-surface-variant border-outline-variant/15 opacity-70";
                            }
                        %>

                        <div class="surface-container rounded-2xl p-5 border-l-4 <%= borderColor %> glass-card">
                            <div class="flex justify-between items-start mb-3">
                                <span class="text-xs font-mono font-bold text-on-surface-variant">#<%= ticket.ticketId %></span>
                                <span class="px-3 py-1 text-[10px] font-bold uppercase tracking-wider rounded-full border flex items-center gap-1 <%= badgeClass %>">
                                    <%- iconHtml %>
                                    <%= ticket.status %>
                                </span>
                            </div>
                            
                            <h3 class="text-on-surface font-bold text-base mb-1"><%= ticket.subject %></h3>
                            <p class="text-xs text-on-surface-variant/80 mb-3"><%= ticket.category %></p>
                            
                            <% if (ticket.adminReply && ticket.adminReply.length > 0) { %>
                                <div class="mt-3 p-3 bg-surface-container-lowest/50 rounded-lg border border-primary/20">
                                    <p class="text-[10px] font-bold uppercase tracking-widest text-primary mb-1">Admin Reply:</p>
                                    <p class="text-xs text-on-surface"><%= ticket.adminReply %></p>
                                </div>
                            <% } %>

                            <div class="flex justify-between items-center mt-4 pt-4 border-t border-white/5">
                                <span class="text-on-surface-variant text-[11px] flex items-center gap-1">
                                    <span class="material-symbols-outlined text-sm">calendar_today</span>
                                    <%= new Date(ticket.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                                </span>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="text-center py-10 surface-container rounded-2xl border border-white/5 border-dashed">
                        <span class="material-symbols-outlined text-4xl text-on-surface-variant/50 mb-2">inbox</span>
                        <p class="text-on-surface-variant text-sm font-medium">You have no past tickets.</p>
                    </div>
                <% } %>
            </div>
        </section>
    </main>


    <script>
        function switchTab(tabName) {
            const raiseSection = document.getElementById('raise-ticket');
            const pastSection = document.getElementById('past-tickets');
            const btnRaise = document.getElementById('btn-raise');
            const btnHistory = document.getElementById('btn-history');

            if (tabName === 'raise') {
                raiseSection.classList.remove('hidden');
                pastSection.classList.add('hidden');
                
                btnRaise.classList.add('tab-active');
                btnRaise.classList.remove('tab-inactive');
                
                btnHistory.classList.remove('tab-active');
                btnHistory.classList.add('tab-inactive');
            } else {
                raiseSection.classList.add('hidden');
                pastSection.classList.remove('hidden');
                
                btnHistory.classList.add('tab-active');
                btnHistory.classList.remove('tab-inactive');
                
                btnRaise.classList.remove('tab-active');
                btnRaise.classList.add('tab-inactive');
            }
        }

        // Optional: If the URL has ?tab=history, automatically open the history tab
        window.onload = function() {
            const urlParams = new URLSearchParams(window.location.search);
            if(urlParams.get('tab') === 'history') {
                switchTab('history');
            }
        }
    </script>
</body>
</html>