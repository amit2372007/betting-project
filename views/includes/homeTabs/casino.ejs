                </div>
                <!-- Fade gradient -->
                <div style="position:absolute;bottom:0;left:0;right:0;height:48px;background:linear-gradient(to top,#0c0c0c,transparent);pointer-events:none;"></div>
            </div>
        </div>
    </section>

</main>

<script>
document.addEventListener("DOMContentLoaded", () => {
    const feedContainer = document.getElementById('live-wins-feed');
    
    const gamesList = [
        { name: 'Aviator',       color: '#ff3131', icon: 'flight_takeoff' },
        { name: 'Mines & Mac',   color: '#00f2ff', icon: 'diamond' },
        { name: '7 Up 7 Down',   color: '#a78bfa', icon: 'casino' },
        { name: 'Roulette 3D',   color: '#ffd700', icon: 'incomplete_circle' },
        { name: 'Fruit Bonanza', color: '#ff007a', icon: 'view_week' },
        { name: 'Super Over',    color: '#ff8c00', icon: 'sports_cricket' }
    ];
    
    const playerNames = ["Alex***", "Raj***", "Dev***", "Sam***", "Poo***", "Moh***", "Vik***", "Sne***", "Joh***", "Chris***",
        "Ami***", "Anu***", "Sai***", "Kav***", "Nikh***", "Har***", "Aar***", "Pri***", "Adh***", "Man***", "Shiv***", "Arj***",
        "Kri***", "Suh***", "Tan***", "Dha***", "Yog***", "Ish***", "Par***", "Gau***", "Lak***", "Vi***", "Sha***", "Ragh***", "Kum***",
        "Chir***", "Samar***", "Nave***", "Tej***", "Vij***", "Ash***", "Mahi***", "Rit***", "Sidh***", "Ansh***", "Kaly***", "Shan***",
        "Raghv***", "Amit***", "Saty***", "Vish***", "Karan***", "Jai***", "Rah***", "Aditya***", "Suresh***", "Vikram***", "Sanjay***",
        "Rohit***", "Aman***", "Kunal***", "Pranav***", "Sahil***", "Nikhil***", "Harsh***", "Aarav***", "Priyansh***", "Adhvik***",
        "Manav***", "Shivam***", "Arjun***", "Krish***", "Suhas***", "Tanmay***", "Dhaval***", "Yogesh***", "Ishaan***", "Parth***",
        "Gaurav***", "Lakshay***", "Vishal***", "Shantanu***"
    ];

    feedContainer.innerHTML = '';

    function generateFakeWin() {
        const game   = gamesList[Math.floor(Math.random() * gamesList.length)];
        const player = playerNames[Math.floor(Math.random() * playerNames.length)];
        
        const betAmounts = [10, 50, 100, 200, 500, 1000];
        const bet = betAmounts[Math.floor(Math.random() * betAmounts.length)];
        
        let multiplier;
        const luck = Math.random();
        if (luck > 0.9)      multiplier = (Math.random() * 20 + 5).toFixed(2);
        else if (luck > 0.6) multiplier = (Math.random() * 3  + 2).toFixed(2);
        else                 multiplier = (Math.random() * 1  + 1.1).toFixed(2);

        const payout = (bet * multiplier).toFixed(2);

        const row = document.createElement('div');
        row.className = 'feed-row animate-slide-in';
        row.innerHTML = `
            <div style="display:flex;align-items:center;gap:10px;overflow:hidden;">
                <div style="width:30px;height:30px;border-radius:8px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <span class="material-symbols-outlined" style="font-size:16px;color:${game.color};font-variation-settings:'FILL' 1;">${game.icon}</span>
                </div>
                <div style="overflow:hidden;">
                    <p style="font-family:'Oswald',sans-serif;font-size:12px;font-weight:600;letter-spacing:0.3px;color:rgba(255,255,255,0.9);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${game.name}</p>
                    <p style="font-size:10px;color:rgba(255,255,255,0.35);margin-top:1px;">${player}</p>
                </div>
            </div>
            <div style="text-align:center;">
                <p style="font-family:'Oswald',sans-serif;font-size:12px;color:rgba(255,255,255,0.55);">₹${bet}</p>
                <p style="font-family:'Oswald',sans-serif;font-size:10px;font-weight:600;color:${game.color};">${multiplier}x</p>
            </div>
            <div style="text-align:right;display:flex;align-items:center;justify-content:flex-end;gap:4px;">
                <span style="font-family:'Oswald',sans-serif;font-size:14px;font-weight:700;color:#22c55e;text-shadow:0 0 12px rgba(34,197,94,0.4);">+₹${payout}</span>
            </div>
        `;

        feedContainer.insertBefore(row, feedContainer.firstChild);

        if (feedContainer.children.length > 8) {
            feedContainer.removeChild(feedContainer.lastChild);
        }

        const nextDelay = Math.random() * 2500 + 1500;
        setTimeout(generateFakeWin, nextDelay);
    }

    generateFakeWin();
});
</script>
