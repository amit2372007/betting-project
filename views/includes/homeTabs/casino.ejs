                    <p class="game-card-name">7 Up 7 Down</p>
                    <a href="/casino/7up-7down" class="play-btn play-btn-ghost" style="border-color:rgba(167,139,250,0.2);color:rgba(255,255,255,0.7);">Play Now</a>
                </div>
            </div>

        </div>
    </section>

    <!-- ════════════ LIVE PAYOUTS ════════════ -->
    <section style="margin-top:24px;" class="px-4">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
            <div style="position:relative;width:10px;height:10px;flex-shrink:0;">
                <span style="position:absolute;inset:0;border-radius:50%;background:#ffd700;display:block;"></span>
                <span class="dot-ping" style="position:absolute;inset:-3px;border-radius:50%;background:rgba(255,215,0,0.4);display:block;"></span>
            </div>
