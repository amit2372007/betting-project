<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" name="viewport" />
    <title>Casino Lobby | WicketAdda</title>
    <link rel="icon" type="image/png" href="https://ik.imagekit.io/xcrdwi6be/Batting_assets/bmcn2NR451G1XkRXqUlOZz.png" />
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#ff8c00",
                        "casino-dark": "#080808",
                        "surface-dark": "#111111",
                        "neon-blue": "#00f2ff",
                        "neon-pink": "#ff007a",
                        "neon-gold": "#ffd700",
                        "neon-red": "#ff3131",
                    },
                    fontFamily: {
                        "display": ["Oswald", "sans-serif"],
                        "body": ["DM Sans", "sans-serif"],
                    },
                },
            },
        }
    </script>
    
    <style>
        :root {
            --gold: #c9a84c;
            --gold-light: #f0d080;
            --gold-dim: rgba(201,168,76,0.15);
            --red-hot: #ff3131;
            --red-dim: rgba(255,49,49,0.15);
            --blue-neon: #00f2ff;
            --blue-dim: rgba(0,242,255,0.12);
            --surface: #111111;
            --surface-2: #181818;
            --surface-3: #1e1e1e;
            --border: rgba(255,255,255,0.07);
            --border-gold: rgba(201,168,76,0.25);
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'DM Sans', sans-serif;
            background-color: #080808;
            color: #fff;
            min-height: 100svh;
            -webkit-tap-highlight-color: transparent;
            /* Subtle noise texture */
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
        }

        h1, h2, h3, h4, .display { font-family: 'Oswald', sans-serif; }

        /* ── Scrollbar ── */
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

        /* ── Hero Banner ── */
        .hero-banner {
            position: relative;
            width: 100%;
            aspect-ratio: 16/7;
            border-radius: 20px;
            overflow: hidden;
            background: linear-gradient(135deg, #1a0404 0%, #0d0208 50%, #040a0d 100%);
            border: 1px solid rgba(255,49,49,0.2);
        }
        .hero-banner::before {
            content: '';
            position: absolute;
            inset: 0;
            background: 
                radial-gradient(ellipse 80% 60% at 20% 50%, rgba(255,49,49,0.12) 0%, transparent 70%),
                radial-gradient(ellipse 40% 40% at 80% 30%, rgba(255,140,0,0.08) 0%, transparent 60%);
        }
        .hero-banner::after {
            content: '';
            position: absolute;
            inset: 0;
            background: repeating-linear-gradient(
                0deg,
                transparent,
                transparent 2px,
                rgba(255,255,255,0.012) 2px,
                rgba(255,255,255,0.012) 4px
            );
            pointer-events: none;
        }

        /* ── Multiplier Counter ── */
        .multiplier-display {
            font-family: 'Oswald', sans-serif;
            font-size: 42px;
            font-weight: 700;
            color: var(--red-hot);
            text-shadow: 0 0 30px rgba(255,49,49,0.7), 0 0 60px rgba(255,49,49,0.3);
            letter-spacing: -1px;
            line-height: 1;
            animation: flicker 3s ease-in-out infinite;
        }
        @keyframes flicker {
            0%,100% { text-shadow: 0 0 30px rgba(255,49,49,0.7), 0 0 60px rgba(255,49,49,0.3); }
            50% { text-shadow: 0 0 20px rgba(255,49,49,0.5), 0 0 40px rgba(255,49,49,0.2); }
        }

        /* ── Hero CTA ── */
        .hero-cta {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 24px;
            background: var(--red-hot);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 10px;
            font-family: 'Oswald', sans-serif;
            font-size: 14px;
            font-weight: 600;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: #fff;
            text-decoration: none;
            box-shadow: 0 0 24px rgba(255,49,49,0.5), 0 4px 16px rgba(0,0,0,0.4);
            transition: all 0.2s;
        }
        .hero-cta:active { transform: scale(0.96); }
        .hero-cta:hover { box-shadow: 0 0 36px rgba(255,49,49,0.7), 0 4px 20px rgba(0,0,0,0.5); }

        /* ── Section heading ── */
        .section-title {
            font-family: 'Oswald', sans-serif;
            font-size: 14px;
            font-weight: 600;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.85);
        }
        .section-link {
            font-family: 'Oswald', sans-serif;
            font-size: 11px;
            font-weight: 500;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--blue-neon);
            text-decoration: none;
            transition: color 0.15s;
        }
        .section-link:hover { color: #fff; }

        /* ── Game Cards ── */
        .game-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            overflow: hidden;
            transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
            cursor: pointer;
        }
        .game-card:active { transform: scale(0.97); }

        .game-card-thumb {
            aspect-ratio: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }
        .game-card-thumb::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, transparent 40%, rgba(0,0,0,0.6) 100%);
        }

        /* Glow accent line at top of card */
        .card-accent-line {
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 2px;
            opacity: 0.8;
        }

        .game-card-body {
            padding: 12px 14px 14px;
            border-top: 1px solid var(--border);
        }
        .game-card-category {
            font-family: 'Oswald', sans-serif;
            font-size: 9px;
            font-weight: 500;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.35);
            margin-bottom: 3px;
        }
        .game-card-name {
            font-family: 'Oswald', sans-serif;
            font-size: 15px;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.92);
            margin-bottom: 12px;
        }

        .play-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            padding: 10px;
            border-radius: 8px;
            font-family: 'Oswald', sans-serif;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            text-decoration: none;
            cursor: pointer;
            border: none;
            transition: all 0.15s;
        }
        .play-btn:active { transform: scale(0.95); }

        .play-btn-ghost {
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.1);
            color: rgba(255,255,255,0.7);
        }
        .play-btn-ghost:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.2); color: #fff; }

        .play-btn-blue {
            background: rgba(0,242,255,0.08);
            border: 1px solid rgba(0,242,255,0.25);
            color: var(--blue-neon);
        }
        .play-btn-blue:hover { background: rgba(0,242,255,0.14); }

        /* ── Live Badge ── */
        .live-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: rgba(0,0,0,0.65);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 6px;
            padding: 4px 8px;
            font-family: 'Oswald', sans-serif;
            font-size: 9px;
            font-weight: 600;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.8);
        }

        /* ── Hot Badge ── */
        .hot-badge {
            font-family: 'Oswald', sans-serif;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: #fff;
            background: var(--red-hot);
            padding: 3px 10px;
            border-radius: 5px;
            box-shadow: 0 2px 12px rgba(255,49,49,0.5);
        }

        /* ── Payout Feed ── */
        .feed-table {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            overflow: hidden;
        }
        .feed-header {
            display: grid;
            grid-template-columns: 5fr 3fr 4fr;
            gap: 8px;
            padding: 10px 16px;
            border-bottom: 1px solid var(--border);
            background: rgba(255,255,255,0.03);
            font-family: 'Oswald', sans-serif;
            font-size: 9px;
            font-weight: 500;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.3);
        }
        #live-wins-feed { background: #0e0e0e; }

        .feed-row {
            display: grid;
            grid-template-columns: 5fr 3fr 4fr;
            gap: 8px;
            align-items: center;
            padding: 10px 16px;
            border-bottom: 1px solid rgba(255,255,255,0.04);
            transition: background 0.2s;
        }
        .feed-row:last-child { border-bottom: none; }

        /* ── Slide-in animation ── */
        @keyframes slideInDown {
            0%   { opacity: 0; transform: translateY(-12px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        .animate-slide-in { animation: slideInDown 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }

        /* ── Pulse dots ── */
        @keyframes ping { 0%{transform:scale(1);opacity:0.8} 75%,100%{transform:scale(2);opacity:0} }
        .dot-ping { animation: ping 1.4s cubic-bezier(0,0,0.2,1) infinite; }

        /* ── Decorative plane trail ── */
        .plane-trail {
            position: absolute;
            right: 24px;
            bottom: 30px;
            pointer-events: none;
        }
        @keyframes soar {
            0%   { transform: translate(0, 0) rotate(-15deg); }
            50%  { transform: translate(-8px, -6px) rotate(-18deg); }
            100% { transform: translate(0, 0) rotate(-15deg); }
        }
        .plane-icon { animation: soar 3s ease-in-out infinite; }

        /* ── Dots indicator ── */
        .dot-indicator {
            display: flex;
            gap: 5px;
            align-items: center;
        }
        .dot-indicator span {
            display: block;
            width: 6px; height: 6px;
            border-radius: 50%;
            transition: all 0.3s;
        }

        /* ── Gold section accent ── */
        .gold-accent-line {
            width: 24px; height: 2px;
            background: linear-gradient(90deg, var(--gold), transparent);
            border-radius: 1px;
        }
    </style>
</head>

<body>
<main class="pb-28 max-w-2xl mx-auto">

    <!-- ════════════ HERO BANNER — AVIATOR ════════════ -->
    <section class="px-4 pt-6 pb-4">
        <div class="hero-banner group">
            <!-- Decorative grid -->
            <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(255,49,49,0.06) 1px,transparent 1px),linear-gradient(90deg,rgba(255,49,49,0.06) 1px,transparent 1px);background-size:40px 40px;"></div>

            <!-- Content -->
            <div style="position:relative;z-index:10;padding:20px 20px 18px;height:100%;display:flex;flex-direction:column;justify-content:space-between;">
