                    </div>
                    <div style="background:rgba(0,0,0,0.55);backdrop-filter:blur(12px);border:1px solid rgba(255,49,49,0.25);border-radius:12px;padding:10px 14px;text-align:right;">
                        <p style="font-family:'Oswald',sans-serif;font-size:9px;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.45);margin-bottom:3px;">Live Multiplier</p>
                        <p class="multiplier-display">14.52x</p>
