<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" name="viewport" />
    <title>Premium Casino Lobby</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;700;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#ff8c00",
                        "casino-dark": "#0a0a0a",
                        "surface-dark": "#161616",
                        "neon-blue": "#00f2ff",
                        "neon-pink": "#ff007a",
                        "neon-gold": "#ffd700",
                        "neon-red": "#ff3131",
                    },
                    fontFamily: {
                        "display": ["Lexend", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "0.75rem", "lg": "1.5rem", "xl": "2.5rem", "full": "9999px" },
                },
            },
        }
    </script>
    
    <style type="text/tailwindcss">
        @layer base {
            body {
                font-family: 'Lexend', sans-serif;
                -webkit-tap-highlight-color: transparent;
                background-color: #0a0a0a;
                color: #ffffff;
            }
        }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        .neon-glow-red { box-shadow: 0 0 20px rgba(255, 49, 49, 0.4); }
        .neon-glow-blue { box-shadow: 0 0 15px rgba(0, 242, 255, 0.3); }
        .neon-glow-gold { box-shadow: 0 0 15px rgba(255, 215, 0, 0.3); }
        
        /* Smooth animation for the live feed */
        @keyframes slideInDown {
            0% { opacity: 0; transform: translateY(-15px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        .animate-slide-in {
            animation: slideInDown 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        }
    </style>
</head>

<body class="min-h-screen">

    <main class="pb-24">

        <section class="px-4 py-6">
            <div class="relative w-full aspect-[16/9] rounded-2xl overflow-hidden bg-gradient-to-br from-[#1a0505] to-[#0a0a0a] border border-neon-red/20 neon-glow-red group">
                <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-20"></div>
                <div class="absolute inset-0 p-5 flex flex-col justify-between z-10">
                    <div class="flex justify-between items-start">
                        <div>
                            <span class="bg-neon-red text-[10px] font-black px-2 py-0.5 rounded text-white uppercase italic shadow-lg shadow-neon-red/50">Hot Now</span>
                            <h2 class="text-3xl font-black italic tracking-tighter mt-1 text-white drop-shadow-md">AVIATOR</h2>
                        </div>
                        <div class="text-right bg-black/40 backdrop-blur-sm border border-neon-red/20 rounded-xl px-3 py-1.5">
                            <p class="text-[9px] font-bold text-white/60 uppercase">Live Multiplier</p>
                            <p class="text-3xl font-black text-neon-red italic tracking-tighter">14.52x</p>
                        </div>
                    </div>
                    
                    <div class="flex justify-between items-end">
                        <a href="/casino/aviator" class="w-1/2 py-3 bg-neon-red hover:bg-neon-red/80 text-white rounded-xl text-xs font-black uppercase tracking-[0.2em] transition-all duration-300 flex items-center justify-center gap-2 shadow-[0_0_15px_rgba(255,49,49,0.4)] active:scale-95 border border-white/20">
                            <span class="material-symbols-outlined text-lg">play_arrow</span> Play
                        </a>
                        <div class="flex gap-1.5 bg-black/40 px-2 py-1 rounded-full backdrop-blur-sm">
                            <div class="size-2 rounded-full bg-neon-red animate-pulse"></div>
                            <div class="size-2 rounded-full bg-white/20"></div>
                            <div class="size-2 rounded-full bg-white/20"></div>
                        </div>
                    </div>
                </div>
                <div class="absolute right-0 bottom-0 w-3/4 h-3/4 pointer-events-none transition-transform duration-700 group-hover:scale-110">
                    <span class="material-symbols-outlined absolute right-8 bottom-12 text-[120px] text-neon-red/40 rotate-[-15deg]">flight_takeoff</span>
                    <div class="absolute right-16 bottom-24 w-40 h-1 bg-gradient-to-l from-neon-red to-transparent opacity-50 rotate-[-15deg]"></div>
                </div>
            </div>
        </section>

        <section class="px-4 py-2">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-sm font-bold uppercase tracking-[0.2em] text-white/90">Popular Games</h3>
                <span class="text-[10px] font-bold text-neon-blue uppercase cursor-pointer hover:text-white transition-colors">View All</span>
            </div>
            
            <div class="grid grid-cols-2 gap-3">
                <div class="bg-surface-dark rounded-xl overflow-hidden border border-white/5 group relative">
                    <div class="aspect-square relative bg-gradient-to-b from-[#1a1a1a] to-[#0a0a0a] flex items-center justify-center p-6 overflow-hidden">
                        <span class="material-symbols-outlined text-7xl text-neon-gold opacity-80 group-hover:scale-110 transition-transform duration-500 neon-glow-gold rounded-full">incomplete_circle</span>
                        <div class="absolute top-2 right-2 flex items-center gap-1 bg-black/60 backdrop-blur-md px-2 py-1 rounded text-[8px] font-bold border border-white/10">
                            <span class="size-1.5 rounded-full bg-green-500 animate-pulse"></span> LIVE
                        </div>
                    </div>
                    <div class="p-3 border-t border-white/5">
                        <p class="text-[9px] font-black text-white/40 uppercase mb-0.5">Table Games</p>
                        <p class="text-xs font-bold uppercase mb-3 text-white/90">Roulette 3D</p>
                        <button class="w-full py-2.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all active:scale-95 hover:border-neon-gold/50 hover:text-neon-gold">Play Now</button>
                    </div>
                </div>

                <div class="bg-surface-dark rounded-xl overflow-hidden border border-white/5 group relative">
                    <div class="aspect-square relative bg-gradient-to-b from-[#0a1622] to-[#0a0a0a] flex items-center justify-center p-6 overflow-hidden">
                        <div class="grid grid-cols-2 gap-2 group-hover:scale-110 transition-transform duration-500">
                            <span class="material-symbols-outlined text-4xl text-neon-blue neon-glow-blue">diamond</span>
                            <span class="material-symbols-outlined text-4xl text-white/10">diamond</span>
                            <span class="material-symbols-outlined text-4xl text-white/10">diamond</span>
                            <span class="material-symbols-outlined text-4xl text-neon-red neon-glow-red">bomb</span>
                        </div>
                    </div>
                    <div class="p-3 border-t border-white/5">
                        <p class="text-[9px] font-black text-white/40 uppercase mb-0.5">Crash Games</p>
                        <p class="text-xs font-bold uppercase mb-3 text-white/90">Diamond Mines</p>
                        <a href="/casino/diamond-and-mines" class="w-full py-2.5 bg-neon-blue/10 hover:bg-neon-blue/20 border border-neon-blue/30 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all active:scale-95 text-neon-blue flex items-center justify-center">Play Now</a>
                    </div>
                </div>

                <div class="bg-surface-dark rounded-xl overflow-hidden border border-white/5 group relative">
                    <div class="aspect-square relative bg-gradient-to-b from-[#220a1c] to-[#0a0a0a] flex items-center justify-center p-6 overflow-hidden">
                        <div class="flex gap-1 items-center bg-black/60 p-2 rounded-xl border border-neon-pink/30 group-hover:scale-110 transition-transform duration-500 shadow-[0_0_20px_rgba(255,0,122,0.2)]">
                            <span class="text-3xl">🍒</span><span class="text-3xl">🍒</span><span class="text-3xl">🍒</span>
                        </div>
                    </div>
                    <div class="p-3 border-t border-white/5">
                        <p class="text-[9px] font-black text-white/40 uppercase mb-0.5">Slots</p>
                        <p class="text-xs font-bold uppercase mb-3 text-white/90">Fruit Bonanza</p>
                        <a href="/casino/fruit-bonanza" class="w-full py-2.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all active:scale-95 hover:border-neon-pink/50 hover:text-neon-pink">Play Now</a>
                    </div>
                </div>
                
                <div class="bg-surface-dark rounded-xl overflow-hidden border border-white/5 group relative">
                    <div class="aspect-square relative bg-gradient-to-b from-[#1a0a22] to-[#0a0a0a] flex items-center justify-center p-6 overflow-hidden">
                        <div class="flex gap-2 group-hover:scale-110 transition-transform duration-500">
                             <span class="material-symbols-outlined text-5xl text-purple-400 drop-shadow-[0_0_15px_rgba(192,132,252,0.5)]">casino</span>
                             <span class="material-symbols-outlined text-5xl text-purple-400 drop-shadow-[0_0_15px_rgba(192,132,252,0.5)]">casino</span>
                        </div>
                    </div>
                    <div class="p-3 border-t border-white/5">
                        <p class="text-[9px] font-black text-white/40 uppercase mb-0.5">Table Games</p>
                        <p class="text-xs font-bold uppercase mb-3 text-white/90">7 Up 7 Down</p>
                        <a href="/casino/7up-7down" class="w-full py-2.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all active:scale-95 hover:border-purple-400/50 hover:text-purple-400 flex items-center justify-center">Play Now</a>
                    </div>
                </div>
            </div>
        </section>

        <section class="mt-6 px-4">
            <div class="flex items-center gap-2 mb-3">
                <span class="material-symbols-outlined text-neon-gold animate-pulse text-lg">sensors</span>
                <h3 class="text-sm font-bold uppercase tracking-[0.2em] text-white/90">Live Payouts</h3>
            </div>
            
            <div class="bg-surface-dark rounded-2xl border border-white/5 overflow-hidden shadow-lg">
                <div class="grid grid-cols-12 gap-2 p-3 border-b border-white/5 bg-white/5 text-[9px] font-black uppercase text-white/40 tracking-widest">
                    <div class="col-span-5">Game / Player</div>
                    <div class="col-span-3 text-center">Bet</div>
                    <div class="col-span-4 text-right">Payout</div>
                </div>
                
                <div class="relative w-full">
                    <div id="live-wins-feed" class="flex flex-col max-h-[220px] overflow-hidden bg-[#111]">
                        <div class="p-3 text-center text-xs font-bold text-white/30 italic">Connecting to live servers...</div>
                    </div>
                    <div class="absolute bottom-0 left-0 w-full h-12 bg-gradient-to-t from-surface-dark to-transparent pointer-events-none"></div>
                </div>
            </div>
        </section>
        
    </main>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const feedContainer = document.getElementById('live-wins-feed');
            
            // Casino Games Database
            const gamesList = [
                { name: 'Aviator', color: 'text-neon-red', icon: 'flight_takeoff' },
                { name: 'Mines & Mac', color: 'text-neon-blue', icon: 'diamond' },
                { name: '7 Up 7 Down', color: 'text-purple-400', icon: 'casino' },
                { name: 'Roulette 3D', color: 'text-neon-gold', icon: 'incomplete_circle' },
                { name: 'Fruit Bonanza', color: 'text-neon-pink', icon: 'view_week' },
                { name: 'Super Over', color: 'text-primary', icon: 'sports_cricket' }
            ];
            
            // Fake Usernames
            const playerNames = ["Alex***", "Raj***", "Dev***", "Sam***", "Poo***", "Moh***", "Vik***", "Sne***", "Joh***", "Chris***"
                , "Ami***", "Anu***", "Sai***", "Kav***", "Nikh***", "Har***", "Aar***", "Pri***", "Adh***", "Man***", "Shiv***", "Arj***",
                 "Kri***", "Suh***", "Tan***", "Dha***", "Yog***", "Ish***", "Par***", "Gau***", "Lak***", "Vi***", "Sha***", "Ragh***", "Kum***",
                  "Chir***", "Samar***", "Nave***", "Tej***", "Vij***", "Ash***", "Mahi***", "Rit***", "Sidh***", "Ansh***", "Kaly***", "Shan***",
                 "Raghv***", "Amit***", "Saty***", "Vish***", "Karan***", "Jai***", "Rah***", "Aditya***", "Suresh***", "Vikram***", "Sanjay***", 
                 "Rohit***", "Aman***", "Kunal***", "Pranav***", "Sahil***"
                , "Nikhil***", "Harsh***", "Aarav***", "Priyansh***", "Adhvik***", "Manav***", "Shivam***", "Arjun***", "Krish***", "Suhas***", "Tanmay***",
                 "Dhaval***", "Yogesh***", "Ishaan***", "Parth***", "Gaurav***", "Lakshay***", "Vishal***", "Shantanu***"
            ];

            // Clear the "Connecting..." text initially
            feedContainer.innerHTML = '';

            function generateFakeWin() {
                // Randomly select data
                const game = gamesList[Math.floor(Math.random() * gamesList.length)];
                const player = playerNames[Math.floor(Math.random() * playerNames.length)];
                
                // Randomize Bet and Multiplier
                const betAmounts = [10, 50, 100, 200, 500, 1000];
                const bet = betAmounts[Math.floor(Math.random() * betAmounts.length)];
                
                // Multipliers favor smaller wins, occasional big wins
                let multiplier;
                const luck = Math.random();
                if (luck > 0.9) multiplier = (Math.random() * 20 + 5).toFixed(2); // 5x to 25x
                else if (luck > 0.6) multiplier = (Math.random() * 3 + 2).toFixed(2); // 2x to 5x
                else multiplier = (Math.random() * 1 + 1.1).toFixed(2); // 1.1x to 2x

                const payout = (bet * multiplier).toFixed(2);

                // Create the row element
                const row = document.createElement('div');
                row.className = 'grid grid-cols-12 gap-2 items-center px-3 py-2.5 border-b border-white/5 bg-surface-dark/50 animate-slide-in';
                
                // Format the HTML
                row.innerHTML = `
                    <div class="col-span-5 flex items-center gap-2 overflow-hidden">
                        <span class="material-symbols-outlined text-[16px] ${game.color}">${game.icon}</span>
                        <div class="flex flex-col truncate">
                            <span class="text-[10px] font-bold text-white/90 truncate">${game.name}</span>
                            <span class="text-[9px] font-medium text-white/40">${player}</span>
                        </div>
                    </div>
                    <div class="col-span-3 text-center flex flex-col justify-center">
                        <span class="text-[10px] font-mono text-white/60">₹${bet}</span>
                        <span class="text-[8px] font-bold ${game.color} opacity-80">${multiplier}x</span>
                    </div>
                    <div class="col-span-4 text-right flex items-center justify-end">
                        <span class="text-xs font-black text-[#28a745] drop-shadow-[0_0_8px_rgba(40,167,69,0.5)]">+₹${payout}</span>
                    </div>
                `;

                // Insert at the top
                feedContainer.insertBefore(row, feedContainer.firstChild);

                // Keep only the latest 8 rows to prevent DOM bloat
                if (feedContainer.children.length > 8) {
                    feedContainer.removeChild(feedContainer.lastChild);
                }

                // Schedule next win (random interval between 1.5s and 4s)
                const nextDelay = Math.random() * 2500 + 1500;
                setTimeout(generateFakeWin, nextDelay);
            }

            // Kick off the engine
            generateFakeWin();
        });
    </script>
</body>
</html>