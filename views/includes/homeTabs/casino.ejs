                    </a>
                    <div class="dot-indicator">
                        <span style="background:var(--red-hot);width:20px;border-radius:3px;"></span>
                        <span style="background:rgba(255,255,255,0.2);"></span>
                        <span style="background:rgba(255,255,255,0.2);"></span>
                    </div>
                </div>
            </div>

            <!-- Decorative plane -->
            <div class="plane-trail">
                <div class="plane-icon">
                    <span class="material-symbols-outlined" style="font-size:88px;color:rgba(255,49,49,0.22);">flight_takeoff</span>
                </div>
                <!-- Trail lines -->
                <div style="position:absolute;right:72px;bottom:28px;width:120px;height:1.5px;background:linear-gradient(270deg,rgba(255,49,49,0.4),transparent);transform:rotate(-15deg);border-radius:1px;"></div>
                <div style="position:absolute;right:72px;bottom:38px;width:80px;height:1px;background:linear-gradient(270deg,rgba(255,49,49,0.2),transparent);transform:rotate(-15deg);border-radius:1px;"></div>
            </div>
        </div>
    </section>

    <!-- ════════════ POPULAR GAMES ════════════ -->
    <section class="px-4 py-2">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
            <div style="display:flex;align-items:center;gap:10px;">
                <div class="gold-accent-line"></div>
                <span class="section-title">Popular Games</span>
            </div>
            <span class="section-link">View All →</span>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">

            <div class="game-card" style="position:relative;">
    <div class="card-accent-line" style="background:linear-gradient(90deg, #ff8c00, transparent);"></div>
    
    <div class="game-card-thumb" style="background:radial-gradient(ellipse at center, #291500 0%, #0d0d0d 100%);">
        
        <span class="material-symbols-outlined group-hover:scale-110" style="font-size:76px;color:#ffb77d;filter:drop-shadow(0 0 20px rgba(255,140,0,0.4));transition:transform 0.4s;z-index:2;">
            egg
        </span>
        
        <div style="position:absolute;top:10px;right:10px;z-index:3;" class="live-badge">
            <span style="width:5px;height:5px;border-radius:50%;background:#22c55e;position:relative;flex-shrink:0;">
                <span class="dot-ping" style="position:absolute;inset:-2px;border-radius:50%;background:#22c55e;display:block;"></span>
            </span>
            LIVE
        </div>
    </div>
    
    <div class="game-card-body">
        <p class="game-card-category">Mini Games</p>
        <p class="game-card-name">Chicken Road</p>
        <a href="/casino/chicken-road" class="play-btn play-btn-ghost">Play Now</a>
    </div>
</div>

            <!-- ── Diamond Mines ── -->
            <div class="game-card" style="position:relative;">
                <div class="card-accent-line" style="background:linear-gradient(90deg,var(--blue-neon),transparent);"></div>
                <div class="game-card-thumb" style="background:radial-gradient(ellipse at center, #041520 0%, #0a0a0a 100%);">
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;transition:transform 0.4s;z-index:2;">
                        <span class="material-symbols-outlined" style="font-size:38px;color:var(--blue-neon);filter:drop-shadow(0 0 12px rgba(0,242,255,0.6));font-variation-settings:'FILL' 1;">diamond</span>
                        <span class="material-symbols-outlined" style="font-size:38px;color:rgba(255,255,255,0.08);font-variation-settings:'FILL' 1;">diamond</span>
                        <span class="material-symbols-outlined" style="font-size:38px;color:rgba(255,255,255,0.08);font-variation-settings:'FILL' 1;">diamond</span>
                        <span class="material-symbols-outlined" style="font-size:38px;color:var(--red-hot);filter:drop-shadow(0 0 12px rgba(255,49,49,0.6));font-variation-settings:'FILL' 1;">bomb</span>
                    </div>
                </div>
                <div class="game-card-body">
                    <p class="game-card-category">Crash Games</p>
                    <p class="game-card-name">Diamond Mines</p>
                    <a href="/casino/diamond-and-mines" class="play-btn play-btn-blue">Play Now</a>
                </div>
            </div>

            <!-- ── Fruit Bonanza ── -->
            <div class="game-card" style="position:relative;">
                <div class="card-accent-line" style="background:linear-gradient(90deg,#ff007a,transparent);"></div>
                <div class="game-card-thumb" style="background:radial-gradient(ellipse at center, #1a0510 0%, #0a0a0a 100%);">
                    <div style="display:flex;align-items:center;gap:4px;background:rgba(0,0,0,0.5);border:1px solid rgba(255,0,122,0.25);border-radius:14px;padding:14px 16px;box-shadow:0 0 24px rgba(255,0,122,0.15);z-index:2;">
                        <span style="font-size:34px;line-height:1;">🍒</span>
                        <span style="font-size:34px;line-height:1;">🍒</span>
                        <span style="font-size:34px;line-height:1;">🍒</span>
                    </div>
                </div>
                <div class="game-card-body">
                    <p class="game-card-category">Slots</p>
                    <p class="game-card-name">Fruit Bonanza</p>
                    <a href="/casino/fruit-bonanza" class="play-btn play-btn-ghost" style="border-color:rgba(255,0,122,0.2);color:rgba(255,255,255,0.7);">Play Now</a>
                </div>
