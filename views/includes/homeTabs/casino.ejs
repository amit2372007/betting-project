                <div class="card-accent-line" style="background:linear-gradient(90deg,#a78bfa,transparent);"></div>
                <div class="game-card-thumb" style="background:radial-gradient(ellipse at center, #120a22 0%, #0a0a0a 100%);">
                    <div style="display:flex;gap:10px;z-index:2;">
                        <span class="material-symbols-outlined" style="font-size:52px;color:#a78bfa;filter:drop-shadow(0 0 16px rgba(167,139,250,0.5));font-variation-settings:'FILL' 1;">casino</span>
                        <span class="material-symbols-outlined" style="font-size:52px;color:#a78bfa;filter:drop-shadow(0 0 16px rgba(167,139,250,0.5));font-variation-settings:'FILL' 1;">casino</span>
                    </div>
                </div>
