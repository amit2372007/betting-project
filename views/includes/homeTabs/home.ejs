<style>
    @keyframes oddsFlashUp {
        0% { background-color: #22c55e; color: white; transform: scale(1.05); } /* Tailwind Green-500 */
        100% { background-color: inherit; color: inherit; transform: scale(1); }
    }
    @keyframes oddsFlashDown {
        0% { background-color: #ef4444; color: white; transform: scale(1.05); } /* Tailwind Red-500 */
        100% { background-color: inherit; color: inherit; transform: scale(1); }
    }
    .flash-up { animation: oddsFlashUp 1s ease-out !important; }
    .flash-down { animation: oddsFlashDown 1s ease-out !important; }
</style>
