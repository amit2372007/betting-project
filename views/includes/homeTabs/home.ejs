<script>
    const socket = io();

    socket.on('odds_update', (data) => {
        // Expected data format: { eventId: "...", homeOdds: 2.15, drawOdds: 3.20, awayOdds: 2.80 }
        console.log("🚨 SOCKET RECEIVED ON HOME PAGE:", data);
        if(data.homeOdds) updateOddBox('home', data.eventId, data.homeOdds);
        if(data.drawOdds) updateOddBox('draw', data.eventId, data.drawOdds);
        if(data.awayOdds) updateOddBox('away', data.eventId, data.awayOdds);
    });

    function updateOddBox(type, eventId, newValue) {
        const textEl = document.getElementById(`text-${type}-${eventId}`);
        const boxEl = document.getElementById(`box-${type}-${eventId}`);
        
        if (!textEl || !boxEl) return; // Ignore if match isn't on the current page

        const oldValue = parseFloat(textEl.getAttribute('data-odd')) || 0;
        const newFloat = parseFloat(newValue);

        // Only flash if the value actually changed
        if (oldValue !== newFloat) {
            // 1. Update the text and data attribute
            textEl.textContent = newFloat.toFixed(2);
            textEl.setAttribute('data-odd', newFloat);

            // 2. Remove old animation classes so it can trigger again
            boxEl.classList.remove('flash-up', 'flash-down');
            textEl.classList.remove('text-white'); // temporary fix for color during flash
            
            // 3. Trigger DOM reflow (magic trick to restart CSS animations)
            void boxEl.offsetWidth; 

            // 4. Apply the new flash class
            if (newFloat > oldValue) {
                boxEl.classList.add('flash-up');
                textEl.classList.add('text-white');
            } else {
                boxEl.classList.add('flash-down');
                textEl.classList.add('text-white');
            }

            // Clean up text color after animation finishes
            setTimeout(() => {
                textEl.classList.remove('text-white');
            }, 1000);
        }
    }
    
    document.querySelectorAll('.local-time').forEach(el => {
        const utcDate = new Date(el.getAttribute('data-utc'));
        el.innerText = utcDate.toLocaleString(undefined, {
            day: 'numeric',
            month: 'short',
            hour: '2-digit',
            minute: '2-digit'
        });
    });

    document.addEventListener("DOMContentLoaded", () => {
        const carousel = document.getElementById('game-carousel');
        if (!carousel) return;

        let scrollInterval;
        const scrollDelay = 3000; // 3 seconds per slide

        function startCarousel() {
            scrollInterval = setInterval(() => {
                // Calculate the maximum possible scroll distance
                const maxScroll = carousel.scrollWidth - carousel.clientWidth;
                
                // If we are at the end of the carousel, slide back to start
                if (carousel.scrollLeft >= maxScroll - 5) {
                    carousel.scrollTo({ left: 0, behavior: 'smooth' });
                } else {
                    // Otherwise, scroll right by exactly one card width + gap (12px)
                    const cardWidth = carousel.firstElementChild.offsetWidth + 12; 
                    carousel.scrollBy({ left: cardWidth, behavior: 'smooth' });
                }
            }, scrollDelay);
        }

        function stopCarousel() {
            clearInterval(scrollInterval);
        }

        // Pause the animation if the user is interacting with it
        carousel.addEventListener('touchstart', stopCarousel);
        carousel.addEventListener('mouseenter', stopCarousel);
        
        // Resume animation when user is done
        carousel.addEventListener('touchend', startCarousel);
        carousel.addEventListener('mouseleave', startCarousel);

        // Kick off the loop on load
        startCarousel();
    });
</script>