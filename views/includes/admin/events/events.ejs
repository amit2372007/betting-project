<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet"/>
<!-- Tailwind CSS v3 -->
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<!-- Lucide Icons (via CDN) -->
<script src="https://unpkg.com/lucide@latest"></script>
<style data-purpose="custom-config">
    body {
      font-family: 'Lexend', sans-serif;
      background-color: #0a0a0a;
      color: #e5e5e5;
    }
    .neon-green { color: #00ff88; text-shadow: 0 0 10px rgba(0, 255, 136, 0.3); }
    .neon-yellow { color: #facc15; text-shadow: 0 0 10px rgba(250, 204, 21, 0.3); }
    .neon-blue { color: #3b82f6; text-shadow: 0 0 10px rgba(59, 130, 246, 0.3); }
    .neon-border-green { border-color: rgba(0, 255, 136, 0.4); }
    
    /* Custom Scrollbar for dark mode */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #0a0a0a; }
    ::-webkit-scrollbar-thumb { background: #262626; border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: #333; }
</style>
<script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              dark: '#0a0a0a',
              card: '#141414',
              border: '#1a1a1a',
              accent: '#00ff88'
            }
          }
        }
      }
    }
</script>

<main class="flex-1 flex flex-col min-w-0 overflow-hidden">

    <!-- BEGIN: Header -->
    <!--
        Mobile: stacks into two rows (title row + search/action row), auto height
        Desktop (md+): single row, fixed h-20
    -->
    <header class="h-auto md:h-20 border-b border-brand-border px-4 md:px-8 py-3 md:py-0 flex flex-col md:flex-row md:items-center justify-between bg-brand-dark/50 backdrop-blur-md sticky top-0 z-10 gap-3 md:gap-0">
        <h1 class="text-xl md:text-2xl font-bold text-white">Manage Events</h1>
        <div class="flex items-center gap-3 md:gap-6 w-full md:w-auto">
            <div class="relative group flex-1 md:flex-none">
                <i class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500 group-focus-within:text-brand-accent transition-colors" data-lucide="search"></i>
                <input class="w-full md:w-64 bg-brand-card border border-brand-border rounded-full py-2 pl-10 pr-4 text-sm focus:ring-1 focus:ring-brand-accent focus:border-brand-accent transition-all outline-none" placeholder="Search events..." type="text" />
            </div>
            <a href="/admin/create-event" class="shrink-0 bg-brand-accent hover:bg-brand-accent/90 text-black px-3 md:px-5 py-2 md:py-2.5 rounded-lg font-semibold flex items-center gap-2 transition-all shadow-[0_0_15px_rgba(0,255,136,0.2)] text-sm md:text-base">
                <i class="w-4 h-4 md:w-5 md:h-5" data-lucide="plus-circle"></i>
                <span>Create Event</span>
            </a>
        </div>
    </header>
    <!-- END: Header -->

    <!-- BEGIN: Scrollable Content Body -->
    <div class="flex-1 overflow-y-auto p-4 md:p-8">

        <!-- BEGIN: Filter Controls -->
        <section class="flex flex-col gap-4 md:flex-row md:gap-6 md:justify-between md:items-center mb-6 md:mb-8" data-purpose="filter-controls">

            <!-- Sport filter tabs: horizontally scrollable on mobile so all tabs stay on one line -->
            <div class="overflow-x-auto pb-1 md:pb-0 -mx-4 px-4 md:mx-0 md:px-0">
                <div class="flex bg-brand-card p-1 rounded-xl border border-brand-border w-max">
                    <button class="px-4 md:px-6 py-2 rounded-lg text-sm font-medium bg-brand-accent text-black shadow-sm whitespace-nowrap">All Sports</button>
                    <button class="px-4 md:px-6 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-white transition-colors whitespace-nowrap">Cricket</button>
                    <button class="px-4 md:px-6 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-white transition-colors whitespace-nowrap">Football</button>
                    <button class="px-4 md:px-6 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-white transition-colors whitespace-nowrap">Tennis</button>
                </div>
            </div>

            <!-- Status select -->
            <div class="flex items-center gap-3 shrink-0">
                <label class="text-sm text-gray-500 font-medium">Status:</label>
                <select class="bg-brand-card border-brand-border text-sm rounded-lg focus:ring-brand-accent focus:border-brand-accent text-gray-300 min-w-[140px]">
                    <option>All Events</option>
                    <option>Live</option>
                    <option>Upcoming</option>
                </select>
            </div>

        </section>
        <!-- END: Filter Controls -->

        <!-- BEGIN: Events Table Card -->
        <div class="bg-brand-card border border-brand-border rounded-2xl overflow-hidden shadow-2xl">

            <!-- Table wrapper: scrolls horizontally on mobile, table has a fixed min-width -->
            <div class="overflow-x-auto w-full">
                <table class="w-full min-w-[700px] text-left border-collapse">
                    <thead>
                        <tr class="border-b border-brand-border bg-white/[0.02]">
                            <th class="px-4 md:px-6 py-3 md:py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Event ID</th>
                            <th class="px-4 md:px-6 py-3 md:py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Sport</th>
                            <th class="px-4 md:px-6 py-3 md:py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Match Name</th>
                            <th class="px-4 md:px-6 py-3 md:py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Start Time</th>
                            <th class="px-4 md:px-6 py-3 md:py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                            <th class="px-4 md:px-6 py-3 md:py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-brand-border">

                        <% if (activeEvents && activeEvents.length > 0) { %>
                            <% activeEvents.forEach(event => { %>

                                <% 
                                    let sportIcon = 'circle'; 
                                    let sportColor = 'text-gray-400';
                                    let sportName = event.sport ? event.sport.toLowerCase() : 'unknown';
                                    
                                    if (sportName === 'cricket') { sportIcon = 'target'; sportColor = 'text-orange-400'; }
                                    else if (sportName === 'football') { sportIcon = 'layout-grid'; sportColor = 'text-blue-400'; }
                                    else if (sportName === 'tennis') { sportIcon = 'circle'; sportColor = 'text-green-400'; }
                                %>

                                <tr class="hover:bg-white/[0.02] transition-colors group">
                                    <td class="px-4 md:px-6 py-4 md:py-5 text-sm font-mono text-gray-400">#<%= event.eventId || event._id.toString().substring(0,6).toUpperCase() %></td>
                                    <td class="px-4 md:px-6 py-4 md:py-5">
                                        <div class="flex items-center gap-2">
                                            <i class="w-4 h-4 <%= sportColor %>" data-lucide="<%= sportIcon %>"></i>
                                            <span class="text-sm font-medium capitalize"><%= event.sport %></span>
                                        </div>
                                    </td>
                                    <td class="px-4 md:px-6 py-4 md:py-5">
                                        <div class="text-sm font-semibold text-white"><%= event.homeTeam %> vs <%= event.awayTeam %></div>
                                        <div class="text-xs text-gray-500"><%= event.league %></div>
                                    </td>
                                    <td class="px-4 md:px-6 py-4 md:py-5 text-sm text-gray-300 whitespace-nowrap">
                                        <%= event.startTime ? new Date(event.startTime).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute:'2-digit' }) : 'TBA' %>
                                    </td>
                                    <td class="px-4 md:px-6 py-4 md:py-5">
                                        <% if (event.status === 'live') { %>
                                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-[#00ff88]/10 text-[#00ff88] border border-[#00ff88]/30 whitespace-nowrap">
                                                <span class="w-1.5 h-1.5 rounded-full bg-[#00ff88] animate-pulse"></span>
                                                LIVE
                                            </span>
                                        <% } else if (event.status === 'finished') { %>
                                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-blue-500/10 text-blue-400 border border-blue-500/30 whitespace-nowrap">
                                                FINISHED
                                            </span>
                                        <% } else { %>
                                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-yellow-400/10 text-yellow-400 border border-yellow-400/30 whitespace-nowrap">
                                                <%= event.status.toUpperCase() %>
                                            </span>
                                        <% } %>
                                    </td>
                                    <td class="px-4 md:px-6 py-4 md:py-5 text-right">
                                        <div class="flex items-center justify-end gap-1 md:gap-2">
                                            <a href="/admin/event/<%= event._id %>" class="p-1.5 md:p-2 hover:bg-brand-accent/10 rounded-lg text-gray-400 hover:text-brand-accent transition-all" title="Manage Matches & Odds">
                                                <i class="w-4 h-4" data-lucide="edit-3"></i>
                                            </a>
                                            <a href="/admin/event/<%= event._id %>" class="p-1.5 md:p-2 hover:bg-brand-accent/10 rounded-lg text-gray-400 hover:text-brand-accent transition-all" title="Manage Sessions">
                                                <i class="w-4 h-4" data-lucide="database"></i>
                                            </a>
                                            <a href="/admin/event/<%= event._id %>" class="p-1.5 md:p-2 hover:bg-brand-accent/10 rounded-lg text-gray-400 hover:text-brand-accent transition-all" title="Settle Markets">
                                                <i class="w-4 h-4" data-lucide="check-square"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>

                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="px-6 py-8 text-center text-gray-500">
                                    No active events found. Click "Create Event" to add one.
                                </td>
                            </tr>
                        <% } %>

                    </tbody>
                </table>
            </div>
            <!-- END: Table wrapper -->

            <!-- Table Footer -->
            <div class="px-4 md:px-6 py-4 bg-white/[0.01] border-t border-brand-border flex items-center justify-between">
                <span class="text-sm text-gray-500">Total active events: <%= activeEvents.length %></span>
            </div>

        </div>
        <!-- END: Events Table Card -->

    </div>
    <!-- END: Scrollable Content Body -->

</main>
<!-- END: Main Content Area -->

<script data-purpose="init-icons">
    // Initialize Lucide icons
    lucide.createIcons();
</script>
