<!DOCTYPE html>
<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>BetAdmin - Complaints Management</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#e1fdff", "on-surface": "#e5e2e1", "on-surface-variant": "#b9cacb",
                        "surface-container-lowest": "#0e0e0e", "surface-container": "#201f1f",
                        "surface-container-high": "#2a2a2a", "primary-container": "#00f2ff",
                        "on-primary": "#00363a", "outline-variant": "#3a494b", "secondary": "#4edea3"
                    },
                    fontFamily: { "headline": ["Inter"], "body": ["Inter"] }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; vertical-align: middle; }
        body { font-family: 'Inter', sans-serif; background-color: #131313; color: #e5e2e1; }
    </style>
</head>

<body class="bg-background text-on-surface min-h-screen">
    <main class="lg:ml-10 pt-5 px-5 pb-5">
        
        <% if (locals.success && success.length > 0) { %>
            <div class="mb-6 p-4 bg-secondary/10 border border-secondary/30 rounded-xl text-secondary text-sm font-bold flex gap-2 items-center">
                <span class="material-symbols-outlined">check_circle</span> <%= success %>
            </div>
        <% } %>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-10">
            <div class="bg-surface-container rounded-xl p-5 border border-outline-variant/5">
                <p class="text-xs font-bold text-on-surface-variant uppercase tracking-widest mb-1">Open Tickets</p>
                <h2 class="text-3xl font-black text-primary-container tracking-tighter"><%= stats.open %></h2>
            </div>
            <div class="bg-surface-container rounded-xl p-5 border border-outline-variant/5">
                <p class="text-xs font-bold text-on-surface-variant uppercase tracking-widest mb-1">In Progress</p>
                <h2 class="text-3xl font-black text-[#e1fdff] tracking-tighter"><%= stats.inProgress %></h2>
            </div>
            <div class="bg-surface-container rounded-xl p-5 border border-outline-variant/5">
                <p class="text-xs font-bold text-on-surface-variant uppercase tracking-widest mb-1">Resolved Today</p>
                <h2 class="text-3xl font-black text-secondary tracking-tighter"><%= stats.resolvedToday %></h2>
            </div>
            <div class="bg-surface-container rounded-xl p-5 border border-outline-variant/5">
                <p class="text-xs font-bold text-on-surface-variant uppercase tracking-widest mb-1">Total Tickets</p>
                <h2 class="text-3xl font-black text-[#e1fdff] tracking-tighter"><%= complaints.length %></h2>
            </div>
        </div>

        <div class="bg-surface-container rounded-xl overflow-hidden border border-outline-variant/5">
            <table class="w-full text-left border-collapse whitespace-nowrap">
                <thead>
                    <tr class="bg-surface-container-high/50 text-on-surface-variant">
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-widest">Ticket ID</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-widest">User</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-widest">Category</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-widest">Date</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-widest">Status</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-widest text-right">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant/5">
                    <% complaints.forEach(complaint => { %>
                        <tr class="hover:bg-surface-container-high transition-colors group">
                            <td class="px-6 py-5 font-mono text-xs text-primary-container"><%= complaint.ticketId %></td>
                            <td class="px-6 py-5 text-sm">
                                <div class="font-bold"><%= complaint.userId.name %></div>
                                <div class="text-[10px] text-on-surface-variant">USR_<%= complaint.userId._id.toString().substring(0,6) %></div>
                            </td>
                            <td class="px-6 py-5 text-sm">
                                <div class="text-on-surface-variant"><%= complaint.category %></div>
                                <div class="font-medium mt-0.5 truncate max-wxs"><%= complaint.subject %></div>
                            </td>
                            <td class="px-6 py-5 text-xs text-on-surface-variant">
                                <%= new Date(complaint.createdAt).toLocaleDateString() %>
                            </td>
                            <td class="px-6 py-5">
                                <% if(complaint.status === 'Open') { %>
                                    <span class="bg-yellow-500/10 text-yellow-500 text-[10px] font-black uppercase tracking-wider px-2 py-1 rounded-full border border-yellow-500/20">Open</span>
                                <% } else if(complaint.status === 'In Progress') { %>
                                    <span class="bg-primary-container/10 text-primary-container text-[10px] font-black uppercase tracking-wider px-2 py-1 rounded-full border border-primary-container/20">In Progress</span>
                                <% } else if(complaint.status === 'Resolved') { %>
                                    <span class="bg-secondary/10 text-secondary text-[10px] font-black uppercase tracking-wider px-2 py-1 rounded-full border border-secondary/20">Resolved</span>
                                <% } else { %>
                                    <span class="bg-on-surface-variant/10 text-on-surface-variant text-[10px] font-black uppercase tracking-wider px-2 py-1 rounded-full border border-on-surface-variant/20">Closed</span>
                                <% } %>
                            </td>
                            <td class="px-6 py-5 text-right">
                                <button onclick="openModal(this)"
                                    data-id="<%= complaint._id %>"
                                    data-ticketid="<%= complaint.ticketId %>"
                                    data-user="<%= complaint.userId.name %>"
                                    data-subject="<%= complaint.subject %>"
                                    data-desc="<%= complaint.description %>"
                                    data-status="<%= complaint.status %>"
                                    data-reply="<%= complaint.adminReply %>"
                                    data-ref="<%= complaint.referenceId %>"
                                    class="text-xs font-bold text-primary-container bg-primary-container/10 px-4 py-2 rounded-lg hover:bg-primary-container hover:text-on-primary transition-all">
                                    Review
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </main>

    <div id="complaint-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-background/80 backdrop-blur-md p-4 hidden">
        <div class="w-full max-w-2xl bg-surface-container rounded-2xl border border-outline-variant/20 shadow-2xl overflow-hidden relative">
            
            <div class="flex justify-between items-center px-8 py-6 border-b border-outline-variant/10 bg-surface-container-high/30">
                <div>
                    <h3 class="text-xl font-black text-primary-container tracking-tighter">Ticket Review</h3>
                    <p id="modal-ref" class="text-xs text-on-surface-variant">Ref ID: None</p>
                </div>
                <button onclick="closeModal()" class="material-symbols-outlined text-on-surface-variant hover:text-on-surface transition-colors">close</button>
            </div>
            
            <div class="p-8 space-y-8 overflow-y-auto max-h-[80vh]">
                <div class="grid grid-cols-2 gap-6">
                    <div class="space-y-1">
                        <label class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant/60">Ticket ID</label>
                        <p id="modal-ticketId" class="text-sm font-mono text-primary"></p>
                    </div>
                    <div class="space-y-1">
                        <label class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant/60">User Name</label>
                        <p id="modal-user" class="text-sm font-bold"></p>
                    </div>
                    <div class="col-span-2 space-y-1">
                        <label class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant/60">Subject</label>
                        <p id="modal-subject" class="text-sm font-semibold text-white"></p>
                    </div>
                    <div class="col-span-2 space-y-1">
                        <label class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant/60">Description</label>
                        <div id="modal-desc" class="bg-surface-container-lowest p-4 rounded-xl border border-outline-variant/10 text-sm leading-relaxed text-on-surface-variant whitespace-pre-wrap"></div>
                    </div>
                </div>
                
                <form id="reply-form" method="POST" action="" class="space-y-6 pt-6 border-t border-outline-variant/10">
                    <div class="space-y-2">
                        <label class="text-[10px] font-bold uppercase tracking-widest text-primary-container">Admin Reply</label>
                        <textarea id="modal-reply" name="adminReply" class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl p-4 text-sm focus:ring-1 focus:ring-primary-container focus:outline-none transition-all min-h-[120px] placeholder:text-on-surface-variant/30 text-white" placeholder="Type your response to the user..."></textarea>
                    </div>
                    <div class="flex flex-col md:flex-row gap-6">
                        <div class="flex-1 space-y-2">
                            <label class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">Update Status</label>
                            <div class="relative">
                                <select id="modal-status" name="status" class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl py-3 px-4 text-sm appearance-none focus:ring-1 focus:ring-primary-container focus:outline-none transition-all text-white">
                                    <option value="Open">Open</option>
                                    <option value="In Progress">In Progress</option>
                                    <option value="Resolved">Resolved</option>
                                    <option value="Closed">Closed</option>
                                </select>
                                <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-on-surface-variant">expand_more</span>
                            </div>
                        </div>
                        <div class="flex items-end gap-3">
                            <button type="button" onclick="closeModal()" class="px-6 py-3 rounded-xl text-sm font-bold text-on-surface-variant hover:text-on-surface hover:bg-surface-container-high transition-all">Cancel</button>
                            <button type="submit" class="bg-primary-container text-on-primary font-bold px-8 py-3 rounded-xl hover:shadow-[0_0_20px_rgba(0,242,255,0.4)] transition-all flex items-center gap-2">
                                <span class="material-symbols-outlined text-sm">send</span> Save &amp; Update
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        function openModal(button) {
            // Extract data from the clicked button
            const id = button.getAttribute('data-id');
            const ticketId = button.getAttribute('data-ticketid');
            const user = button.getAttribute('data-user');
            const subject = button.getAttribute('data-subject');
            const desc = button.getAttribute('data-desc');
            const status = button.getAttribute('data-status');
            const reply = button.getAttribute('data-reply');
            const refId = button.getAttribute('data-ref');

            // Populate the modal fields
            document.getElementById('modal-ticketId').innerText = ticketId;
            document.getElementById('modal-user').innerText = user;
            document.getElementById('modal-subject').innerText = subject;
            document.getElementById('modal-desc').innerText = desc;
            document.getElementById('modal-ref').innerText = refId ? `Ref ID: ${refId}` : "Ref ID: None";
            
            // Populate form inputs
            document.getElementById('modal-reply').value = reply || "";
            document.getElementById('modal-status').value = status;

            // VERY IMPORTANT: Set the form action URL dynamically
            document.getElementById('reply-form').action = `/admin/complaint/${id}/reply`;

            // Show the modal
            document.getElementById('complaint-modal').classList.remove('hidden');
        }

        function closeModal() {
            document.getElementById('complaint-modal').classList.add('hidden');
        }
    </script>
</body>
</html>