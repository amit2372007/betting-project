<div class="p-6 sm:p-10 space-y-6">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
            <h2 class="text-2xl font-bold text-white">WhatsApp Numbers</h2>
            <p class="text-gray-400 text-sm mt-1">Manage active numbers, rotation schedules, and statuses.</p>
        </div>
        <button onclick="document.getElementById('addNumberModal').classList.remove('hidden')" class="px-4 py-2 bg-green-600 hover:bg-green-700 text-white text-sm font-medium rounded-custom transition-colors flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Add New Number
        </button>
    </div>

    <div class="bg-white/5 border border-white/10 rounded-xl overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-white/5 border-b border-white/10 text-gray-400 text-sm">
                        <th class="p-4 font-medium">Phone Number</th>
                        <th class="p-4 font-medium">Purpose</th>
                        <th class="p-4 font-medium">Status</th>
                        <th class="p-4 font-medium">Valid Until</th>
                        <th class="p-4 font-medium">Msgs</th>
                        <th class="p-4 font-medium text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="text-gray-300 text-sm divide-y divide-white/5">
                    <% if (typeof whatsappNumbers !== 'undefined' && whatsappNumbers.length > 0) { %>
                        <% whatsappNumbers.forEach(number => { %>
                            <tr class="hover:bg-white/[0.02] transition-colors">
                                <td class="p-4 font-medium text-white"><%= number.phoneNumber %></td>
                                <td class="p-4 capitalize"><%= number.purpose %></td>
                                <td class="p-4">
                                    <% if (number.status === 'active') { %>
                                        <span class="px-2.5 py-1 bg-green-500/10 text-green-400 rounded-full text-xs font-medium border border-green-500/20">Active</span>
                                    <% } else if (number.status === 'cooldown') { %>
                                        <span class="px-2.5 py-1 bg-yellow-500/10 text-yellow-400 rounded-full text-xs font-medium border border-yellow-500/20">Cooldown</span>
                                    <% } else if (number.status === 'banned') { %>
                                        <span class="px-2.5 py-1 bg-red-500/10 text-red-400 rounded-full text-xs font-medium border border-red-500/20">Banned</span>
                                    <% } else { %>
                                        <span class="px-2.5 py-1 bg-gray-500/10 text-gray-400 rounded-full text-xs font-medium border border-gray-500/20">Inactive</span>
                                    <% } %>
                                </td>
                                <td class="p-4">
                                    <%= new Date(number.activeUntil).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', dateStyle: 'short', timeStyle: 'short' }) %>
                                </td>
                                <td class="p-4"><%= number.messageCount %></td>
                                <td class="p-4 flex justify-end gap-3 items-center">
                                    <% 
                                        // Format date for datetime-local input safely
                                        let d = new Date(number.activeUntil);
                                        d.setMinutes(d.getMinutes() - d.getTimezoneOffset());
                                        let formattedDate = d.toISOString().slice(0, 16);
                                    %>
                                    <button onclick="openEditModal('<%= number._id %>', '<%= number.phoneNumber %>', '<%= number.purpose %>', '<%= number.status %>', '<%= formattedDate %>')" class="text-blue-400 hover:text-blue-300 transition-colors">Edit</button>
                                    
                                    <form action="/admin/whatsapp/delete/<%= number._id %>" method="POST" class="inline m-0" onsubmit="return confirm('Are you sure you want to delete this number?');">
                                        <button type="submit" class="text-red-400 hover:text-red-300 transition-colors">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="p-8 text-center text-gray-500">No WhatsApp numbers found. Add one to get started.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="addNumberModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4">
    <div class="bg-[#1a1c23] border border-white/10 rounded-xl w-full max-w-md overflow-hidden shadow-2xl">
        <div class="p-6 border-b border-white/10 flex justify-between items-center">
            <h3 class="text-lg font-semibold text-white">Add WhatsApp Number</h3>
            <button onclick="document.getElementById('addNumberModal').classList.add('hidden')" class="text-gray-400 hover:text-white">&times;</button>
        </div>
        <form action="/admin/whatsapp/add" method="POST" class="p-6 space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-400 mb-1">Phone Number</label>
                <input type="text" name="phoneNumber" placeholder="+919876543210" required class="w-full bg-black/20 border border-white/10 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-green-500">
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-400 mb-1">Purpose</label>
                    <select name="purpose" class="w-full bg-black/20 border border-white/10 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-green-500">
                        <option value="support">Support</option>
                        <option value="deposit">Deposit</option>
                        <option value="withdrawal">Withdrawal</option>
                        <option value="general">General</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-400 mb-1">Status</label>
                    <select name="status" class="w-full bg-black/20 border border-white/10 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-green-500">
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                        <option value="cooldown">Cooldown</option>
                        <option value="banned">Banned</option>
                    </select>
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-400 mb-1">Active Until</label>
                <input type="datetime-local" name="activeUntil" required class="w-full bg-black/20 border border-white/10 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-green-500" style="color-scheme: dark;">
            </div>
            <div class="pt-4 flex justify-end gap-3">
                <button type="button" onclick="document.getElementById('addNumberModal').classList.add('hidden')" class="px-4 py-2 text-gray-400 hover:text-white transition-colors">Cancel</button>
                <button type="submit" class="px-4 py-2 bg-green-600 hover:bg-green-700 text-white font-medium rounded-lg transition-colors">Save Number</button>
            </div>
        </form>
    </div>
</div>

<div id="editNumberModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4">
    <div class="bg-[#1a1c23] border border-white/10 rounded-xl w-full max-w-md overflow-hidden shadow-2xl">
        <div class="p-6 border-b border-white/10 flex justify-between items-center">
            <h3 class="text-lg font-semibold text-white">Edit WhatsApp Number</h3>
            <button onclick="document.getElementById('editNumberModal').classList.add('hidden')" class="text-gray-400 hover:text-white">&times;</button>
        </div>
        <form id="editForm" method="POST" class="p-6 space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-400 mb-1">Phone Number</label>
                <input type="text" id="editPhone" name="phoneNumber" required class="w-full bg-black/20 border border-white/10 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-blue-500">
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-400 mb-1">Purpose</label>
                    <select id="editPurpose" name="purpose" class="w-full bg-black/20 border border-white/10 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-blue-500">
                        <option value="support">Support</option>
                        <option value="deposit">Deposit</option>
                        <option value="withdrawal">Withdrawal</option>
                        <option value="general">General</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-400 mb-1">Status</label>
                    <select id="editStatus" name="status" class="w-full bg-black/20 border border-white/10 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-blue-500">
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                        <option value="cooldown">Cooldown</option>
                        <option value="banned">Banned</option>
                    </select>
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-400 mb-1">Active Until</label>
                <input type="datetime-local" id="editDate" name="activeUntil" required class="w-full bg-black/20 border border-white/10 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-blue-500" style="color-scheme: dark;">
            </div>
            <div class="pt-4 flex justify-end gap-3">
                <button type="button" onclick="document.getElementById('editNumberModal').classList.add('hidden')" class="px-4 py-2 text-gray-400 hover:text-white transition-colors">Cancel</button>
                <button type="submit" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors">Update Number</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openEditModal(id, phone, purpose, status, date) {
        // Set form action dynamically based on the ID
        document.getElementById('editForm').action = '/admin/whatsapp/update/' + id;
        
        // Populate inputs
        document.getElementById('editPhone').value = phone;
        document.getElementById('editPurpose').value = purpose;
        document.getElementById('editStatus').value = status;
        document.getElementById('editDate').value = date;
        
        // Show modal
        document.getElementById('editNumberModal').classList.remove('hidden');
    }
</script>