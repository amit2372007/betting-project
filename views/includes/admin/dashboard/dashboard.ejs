<main class="flex-1 flex flex-col min-w-0 overflow-y-auto">
    <!-- BEGIN: Header -->
    <header class="h-auto md:h-16 bg-surface border-b border-white/5 flex flex-col md:flex-row md:items-center justify-between px-4 md:px-8 py-3 md:py-0 sticky top-0 z-30 gap-3 md:gap-0">
        <div class="flex-1 max-w-xl w-full">
            <div class="relative group">
                <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500 group-focus-within:text-primary">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                        <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                    </svg>
                </span>
                <input
                    class="w-full bg-surface-darker border-white/10 rounded-custom pl-10 text-sm focus:ring-primary focus:border-primary text-gray-200"
                    placeholder="Search events, users or transactions..." type="text" />
            </div>
        </div>
        <div class="flex items-center gap-2 md:gap-4 md:ml-6">
            <a href="/admin/addEvent"
                class="flex-1 md:flex-none justify-center bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold py-2.5 px-3 md:px-4 rounded-custom transition-all flex items-center gap-2">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                    <path d="M12 4v16m8-8H4" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                </svg>
                <span class="truncate">CREATE EVENT</span>
            </a>
            <button
                class="flex-1 md:flex-none justify-center bg-primary hover:bg-primary/90 text-white text-xs font-bold py-2.5 px-3 md:px-4 rounded-custom transition-all flex items-center gap-2"
                onclick="document.getElementById('modal-overlay').classList.remove('hidden')">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                    <path d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                </svg>
                <span class="truncate">CREATE USER ID</span>
            </button>
        </div>
    </header>
    <!-- END: Header -->

    <!-- BEGIN: Dashboard Body -->
    <div class="p-4 md:p-8 space-y-6 md:space-y-8">

        <!-- BEGIN: Overview Cards -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-6">

            <!-- Card 1: Active Events -->
            <div class="bg-surface p-4 md:p-5 rounded-custom border border-white/5 flex flex-col gap-2">
                <div class="flex items-center justify-between">
                    <span class="text-[10px] md:text-xs font-semibold text-gray-400 uppercase tracking-wider leading-tight">Active Events</span>
                    <div class="p-1.5 md:p-2 bg-blue-500/10 rounded-lg text-blue-500 shrink-0">
                        <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                            <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                        </svg>
                    </div>
                </div>
                <div class="mt-1">
                    <h3 class="text-xl md:text-2xl font-display font-bold text-white"><%= activeEvents.length %></h3>
                    <p class="text-[10px] md:text-xs text-green-500 mt-1 flex items-center gap-1">
                        <svg class="w-3 h-3 shrink-0" fill="currentColor" viewbox="0 0 20 20">
                            <path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293l-4-4a1 1 0 00-1.414 0l-4 4a1 1 0 101.414 1.414L9 7.414V13a1 1 0 102 0V7.414l1.293 1.293a1 1 0 001.414-1.414z"></path>
                        </svg>
                        +12% from yesterday
                    </p>
                </div>
            </div>

            <!-- Card 2: Pending Deposits -->
            <div class="bg-surface p-4 md:p-5 rounded-custom border border-white/5 flex flex-col gap-2">
                <div class="flex items-center justify-between">
                    <span class="text-[10px] md:text-xs font-semibold text-gray-400 uppercase tracking-wider leading-tight">Pending Deposits</span>
                    <div class="p-1.5 md:p-2 bg-primary/10 rounded-lg text-primary shrink-0">
                        <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                        </svg>
                    </div>
                </div>
                <div class="mt-1">
                    <h3 class="text-xl md:text-2xl font-display font-bold text-white"><%= deposits.filter(d => d.status === 'pending').length %></h3>
                    <p class="text-[10px] md:text-xs text-yellow-500 mt-1">Awaiting approval</p>
                </div>
            </div>

            <!-- Card 3: Pending Withdrawals -->
            <div class="bg-surface p-4 md:p-5 rounded-custom border border-white/5 flex flex-col gap-2">
                <div class="flex items-center justify-between">
                    <span class="text-[10px] md:text-xs font-semibold text-gray-400 uppercase tracking-wider leading-tight">Pending Withdrawals</span>
                    <div class="p-1.5 md:p-2 bg-red-500/10 rounded-lg text-red-500 shrink-0">
                        <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                        </svg>
                    </div>
                </div>
                <div class="mt-1">
                    <h3 class="text-xl md:text-2xl font-display font-bold text-white"><%= withdrawals.filter(w => w.status === 'pending').length %></h3>
                    <p class="text-[10px] md:text-xs text-red-400 mt-1">Priority handling</p>
                </div>
            </div>

            <!-- Card 4: Total Users -->
            <div class="bg-surface p-4 md:p-5 rounded-custom border border-white/5 flex flex-col gap-2">
                <div class="flex items-center justify-between">
                    <span class="text-[10px] md:text-xs font-semibold text-gray-400 uppercase tracking-wider leading-tight">Total Users</span>
                    <div class="p-1.5 md:p-2 bg-purple-500/10 rounded-lg text-purple-500 shrink-0">
                        <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                            <path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                        </svg>
                    </div>
                </div>
                <div class="mt-1">
                    <h3 class="text-xl md:text-2xl font-display font-bold text-white"><%= totalUsers %></h3>
                    <p class="text-[10px] md:text-xs text-gray-400 mt-1">All-time active accounts</p>
                </div>
            </div>

        </div>
        <!-- END: Overview Cards -->

        <!-- BEGIN: Events Table -->
        <div class="bg-surface rounded-custom border border-white/5 overflow-hidden flex flex-col min-w-0">
            <div class="px-4 md:px-6 py-4 border-b border-white/5 flex items-center justify-between shrink-0">
                <h2 class="font-display font-semibold text-white text-sm md:text-base">Live & Upcoming Events</h2>
                <button class="text-xs text-primary font-medium hover:underline">View All</button>
            </div>

            <!-- Scrollable table wrapper — scrolls horizontally on mobile, not the whole page -->
            <div class="overflow-x-auto w-full">
                <table class="w-full min-w-[640px] text-left text-sm whitespace-nowrap">
                    <thead class="bg-surface-lighter/50 text-gray-400 uppercase text-[10px] font-bold tracking-wider">
                        <tr>
                            <th class="px-4 md:px-6 py-3 md:py-4 w-[30%]">Event Name</th>
                            <th class="px-4 md:px-6 py-3 md:py-4 w-[25%]">Sport & League</th>
                            <th class="px-4 md:px-6 py-3 md:py-4 w-[20%]">Date & Time</th>
                            <th class="px-4 md:px-6 py-3 md:py-4 w-[10%]">Status</th>
                            <th class="px-4 md:px-6 py-3 md:py-4 w-[15%] text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/10">

                        <% for(let event of liveEvents) { %>
                        <tr class="hover:bg-white/5 transition-colors group">
                            <td class="px-4 md:px-6 py-3 md:py-4">
                                <div class="font-bold text-white text-sm md:text-base">
                                    <%= event.homeTeam %>
                                    <span class="text-gray-500 font-medium text-xs mx-1">vs</span>
                                    <%= event.awayTeam %>
                                </div>
                                <div class="text-[10px] font-mono text-gray-500 mt-1">ID: <%= event._id.toString().substring(0, 8) %>...</div>
                            </td>
                            <td class="px-4 md:px-6 py-3 md:py-4">
                                <div class="text-white font-medium capitalize"><%= event.sport %></div>
                                <div class="text-xs text-gray-400 mt-0.5"><%= event.tournament || 'Regular Match' %></div>
                            </td>
                            <td class="px-4 md:px-6 py-3 md:py-4">
                                <div class="text-white font-medium">Today</div>
                                <div class="text-xs text-red-400 font-bold mt-0.5 flex items-center gap-1">
                                    <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
                                    IN PLAY
                                </div>
                            </td>
                            <td class="px-4 md:px-6 py-3 md:py-4">
                                <span class="px-2 md:px-3 py-1 md:py-1.5 rounded-md text-[10px] font-black bg-green-500/10 text-green-500 uppercase tracking-widest border border-green-500/20 shadow-[0_0_10px_rgba(34,197,94,0.1)]">
                                    Live
                                </span>
                            </td>
                            <td class="px-4 md:px-6 py-3 md:py-4 text-right">
                                <a href="/admin/event/<%= event._id %>"
                                    class="inline-flex items-center gap-1 md:gap-2 px-2.5 md:px-4 py-1.5 md:py-2 text-xs font-bold uppercase tracking-wider rounded-lg text-[#00f2ff] border border-[#00f2ff]/30 hover:bg-[#00f2ff] hover:text-black hover:shadow-[0_0_15px_rgba(0,242,255,0.4)] transition-all active:scale-95">
                                    <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">settings</span>
                                    Manage
                                </a>
                            </td>
                        </tr>
                        <% } %>

                        <% for(let event of upcomingEvents) { %>
                        <tr class="hover:bg-white/5 transition-colors group">
                            <td class="px-4 md:px-6 py-3 md:py-4">
                                <div class="font-bold text-white text-sm md:text-base">
                                    <%= event.homeTeam %>
                                    <span class="text-gray-500 font-medium text-xs mx-1">vs</span>
                                    <%= event.awayTeam %>
                                </div>
                                <div class="text-[10px] font-mono text-gray-500 mt-1">ID: <%= event._id.toString().substring(0, 8) %>...</div>
                            </td>
                            <td class="px-4 md:px-6 py-3 md:py-4">
                                <div class="text-white font-medium capitalize"><%= event.sport %></div>
                                <div class="text-xs text-gray-400 mt-0.5"><%= event.tournament || 'Regular Match' %></div>
                            </td>
                            <td class="px-4 md:px-6 py-3 md:py-4">
                                <% 
                                    const matchDate = new Date(event.date || Date.now()); 
                                %>
                                <div class="text-white font-medium"><%= matchDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) %></div>
                                <div class="text-xs text-gray-400 mt-0.5 flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[12px]">schedule</span>
                                    <%= matchDate.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %>
                                </div>
                            </td>
                            <td class="px-4 md:px-6 py-3 md:py-4">
                                <span class="px-2 md:px-3 py-1 md:py-1.5 rounded-md text-[10px] font-black bg-blue-500/10 text-blue-400 uppercase tracking-widest border border-blue-500/20">
                                    Upcoming
                                </span>
                            </td>
                            <td class="px-4 md:px-6 py-3 md:py-4 text-right">
                                <a href="/admin/event/<%= event._id %>"
                                    class="inline-flex items-center gap-1 md:gap-2 px-2.5 md:px-4 py-1.5 md:py-2 text-xs font-bold uppercase tracking-wider rounded-lg text-[#00f2ff] border border-[#00f2ff]/30 hover:bg-[#00f2ff] hover:text-black hover:shadow-[0_0_15px_rgba(0,242,255,0.4)] transition-all active:scale-95">
                                    <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">edit</span>
                                    Manage
                                </a>
                            </td>
                        </tr>
                        <% } %>

                    </tbody>
                </table>
            </div>
        </div>
        <!-- END: Events Table -->

    </div>
    <!-- END: Dashboard Body -->
</main>
