<main class="flex-1 flex flex-col min-w-0 overflow-y-auto">
    <!-- BEGIN: Header -->
    <header class="h-auto md:h-16 bg-surface border-b border-white/5 flex flex-col md:flex-row md:items-center justify-between px-4 md:px-8 py-3 md:py-0 sticky top-0 z-30 gap-3 md:gap-0">
        <div class="flex-1 max-w-xl w-full">
            <div class="relative group">
                <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500 group-focus-within:text-primary">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                        <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                    </svg>
                </span>
                <input
                    class="w-full bg-surface-darker border-white/10 rounded-custom pl-10 text-sm focus:ring-primary focus:border-primary text-gray-200"
                    placeholder="Search events, users or transactions..." type="text" />
            </div>
        </div>
        <div class="flex items-center gap-2 md:gap-4 md:ml-6">
            <a href="/admin/addEvent"
                class="flex-1 md:flex-none justify-center bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold py-2.5 px-3 md:px-4 rounded-custom transition-all flex items-center gap-2">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                    <path d="M12 4v16m8-8H4" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                </svg>
                <span class="truncate">CREATE EVENT</span>
            </a>
            <button
                class="flex-1 md:flex-none justify-center bg-primary hover:bg-primary/90 text-white text-xs font-bold py-2.5 px-3 md:px-4 rounded-custom transition-all flex items-center gap-2"
                onclick="document.getElementById('modal-overlay').classList.remove('hidden')">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                    <path d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                </svg>
                <span class="truncate">CREATE USER ID</span>
            </button>
        </div>
    </header>
    <!-- END: Header -->

    <!-- BEGIN: Dashboard Body -->
    <div class="p-4 md:p-8 space-y-6 md:space-y-8">

        <!-- BEGIN: Overview Cards -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-6">

            <!-- Card 1: Active Events -->
            <div class="bg-surface p-4 md:p-5 rounded-custom border border-white/5 flex flex-col gap-2">
                <div class="flex items-center justify-between">
                    <span class="text-[10px] md:text-xs font-semibold text-gray-400 uppercase tracking-wider leading-tight">Active Events</span>
                    <div class="p-1.5 md:p-2 bg-blue-500/10 rounded-lg text-blue-500 shrink-0">
                        <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                            <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                        </svg>
                    </div>
                </div>
                <div class="mt-1">
                    <h3 class="text-xl md:text-2xl font-display font-bold text-white"><%= activeEvents.length %></h3>
                    <p class="text-[10px] md:text-xs text-green-500 mt-1 flex items-center gap-1">
                        <svg class="w-3 h-3 shrink-0" fill="currentColor" viewbox="0 0 20 20">
                            <path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293l-4-4a1 1 0 00-1.414 0l-4 4a1 1 0 101.414 1.414L9 7.414V13a1 1 0 102 0V7.414l1.293 1.293a1 1 0 001.414-1.414z"></path>
                        </svg>
                        +12% from yesterday
                    </p>
                </div>
            </div>

            <!-- Card 2: Pending Deposits -->
            <div class="bg-surface p-4 md:p-5 rounded-custom border border-white/5 flex flex-col gap-2">
                <div class="flex items-center justify-between">
                    <span class="text-[10px] md:text-xs font-semibold text-gray-400 uppercase tracking-wider leading-tight">Pending Deposits</span>
                    <div class="p-1.5 md:p-2 bg-primary/10 rounded-lg text-primary shrink-0">
                        <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                        </svg>
                    </div>
                </div>
                <div class="mt-1">
                    <h3 class="text-xl md:text-2xl font-display font-bold text-white"><%= deposits.filter(d => d.status === 'pending').length %></h3>
                    <p class="text-[10px] md:text-xs text-yellow-500 mt-1">Awaiting approval</p>
                </div>
            </div>

            <!-- Card 3: Pending Withdrawals -->
            <div class="bg-surface p-4 md:p-5 rounded-custom border border-white/5 flex flex-col gap-2">
                <div class="flex items-center justify-between">
                    <span class="text-[10px] md:text-xs font-semibold text-gray-400 uppercase tracking-wider leading-tight">Pending Withdrawals</span>
                    <div class="p-1.5 md:p-2 bg-red-500/10 rounded-lg text-red-500 shrink-0">
                        <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                        </svg>
                    </div>
                </div>
                <div class="mt-1">
                    <h3 class="text-xl md:text-2xl font-display font-bold text-white"><%= withdrawals.filter(w => w.status === 'pending').length %></h3>
                    <p class="text-[10px] md:text-xs text-red-400 mt-1">Priority handling</p>
                </div>
            </div>

            <!-- Card 4: Total Users -->
            <div class="bg-surface p-4 md:p-5 rounded-custom border border-white/5 flex flex-col gap-2">
                <div class="flex items-center justify-between">
                    <span class="text-[10px] md:text-xs font-semibold text-gray-400 uppercase tracking-wider leading-tight">Total Users</span>
                    <div class="p-1.5 md:p-2 bg-purple-500/10 rounded-lg text-purple-500 shrink-0">
                        <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                            <path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                        </svg>
                    </div>
                </div>
                <div class="mt-1">
                    <h3 class="text-xl md:text-2xl font-display font-bold text-white"><%= totalUsers %></h3>
                    <p class="text-[10px] md:text-xs text-gray-400 mt-1">All-time active accounts</p>
                </div>
            </div>

        </div>
        <!-- END: Overview Cards -->

        <!-- BEGIN: Events Table -->
        <div class="bg-surface rounded-custom border border-white/5 overflow-hidden flex flex-col min-w-0">
            <div class="px-4 md:px-6 py-4 border-b border-white/5 flex items-center justify-between shrink-0">
                <h2 class="font-display font-semibold text-white text-sm md:text-base">Live & Upcoming Events</h2>
                <button class="text-xs text-primary font-medium hover:underline">View All</button>
            </div>

            <!-- Scrollable table wrapper — scrolls horizontally on mobile, not the whole page -->
            <div class="overflow-x-auto w-full">
                <table class="w-full min-w-[640px] text-left text-sm whitespace-nowrap">
                    <thead class="bg-surface-lighter/50 text-gray-400 uppercase text-[10px] font-bold tracking-wider">
                        <tr>
                            <th class="px-4 md:px-6 py-3 md:py-4 w-[30%]">Event Name</th>
                            <th class="px-4 md:px-6 py-3 md:py-4 w-[25%]">Sport & League</th>
                            <th class="px-4 md:px-6 py-3 md:py-4 w-[20%]">Date & Time</th>
                            <th class="px-4 md:px-6 py-3 md:py-4 w-[10%]">Status</th>
                            <th class="px-4 md:px-6 py-3 md:py-4 w-[15%] text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/10">

                        <% for(let event of liveEvents) { %>
                        <tr class="hover:bg-white/5 transition-colors group">
                            <td class="px-4 md:px-6 py-3 md:py-4">
                                <div class="font-bold text-white text-sm md:text-base">
                                    <%= event.homeTeam %>
                                    <span class="text-gray-500 font-medium text-xs mx-1">vs</span>
                                    <%= event.awayTeam %>
                                </div>
                                <div class="text-[10px] font-mono text-gray-500 mt-1">ID: <%= event._id.toString().substring(0, 8) %>...</div>
                            </td>
                            <td class="px-4 md:px-6 py-3 md:py-4">
                                <div class="text-white font-medium capitalize"><%= event.sport %></div>
                                <div class="text-xs text-gray-400 mt-0.5"><%= event.tournament || 'Regular Match' %></div>
                            </td>
                            <td class="px-4 md:px-6 py-3 md:py-4">
                                <div class="text-white font-medium">Today</div>
                                <div class="text-xs text-red-400 font-bold mt-0.5 flex items-center gap-1">
                                    <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
                                    IN PLAY
                                </div>
                            </td>
                            <td class="px-4 md:px-6 py-3 md:py-4">
                                <span class="px-2 md:px-3 py-1 md:py-1.5 rounded-md text-[10px] font-black bg-green-500/10 text-green-500 uppercase tracking-widest border border-green-500/20 shadow-[0_0_10px_rgba(34,197,94,0.1)]">
                                    Live
                                </span>
                            </td>
                            <td class="px-4 md:px-6 py-3 md:py-4 text-right">
                                <a href="/admin/event/<%= event._id %>"
                                    class="inline-flex items-center gap-1 md:gap-2 px-2.5 md:px-4 py-1.5 md:py-2 text-xs font-bold uppercase tracking-wider rounded-lg text-[#00f2ff] border border-[#00f2ff]/30 hover:bg-[#00f2ff] hover:text-black hover:shadow-[0_0_15px_rgba(0,242,255,0.4)] transition-all active:scale-95">
                                    <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">settings</span>
                                    Manage
                                </a>
                            </td>
                        </tr>
                        <% } %>

                        <% for(let event of upcomingEvents) { %>
                        <tr class="hover:bg-white/5 transition-colors group">
                            <td class="px-4 md:px-6 py-3 md:py-4">
                                <div class="font-bold text-white text-sm md:text-base">
                                    <%= event.homeTeam %>
                                    <span class="text-gray-500 font-medium text-xs mx-1">vs</span>
                                    <%= event.awayTeam %>
                                </div>
                                <div class="text-[10px] font-mono text-gray-500 mt-1">ID: <%= event._id.toString().substring(0, 8) %>...</div>
                            </td>
                            <td class="px-4 md:px-6 py-3 md:py-4">
                                <div class="text-white font-medium capitalize"><%= event.sport %></div>
                                <div class="text-xs text-gray-400 mt-0.5"><%= event.tournament || 'Regular Match' %></div>
                            </td>
                            <td class="px-4 md:px-6 py-3 md:py-4">
                                <% 
                                    const matchDate = new Date(event.date || Date.now()); 
                                %>
                                <div class="text-white font-medium"><%= matchDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) %></div>
                                <div class="text-xs text-gray-400 mt-0.5 flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[12px]">schedule</span>
                                    <%= matchDate.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %>
                                </div>
                            </td>
                            <td class="px-4 md:px-6 py-3 md:py-4">
                                <span class="px-2 md:px-3 py-1 md:py-1.5 rounded-md text-[10px] font-black bg-blue-500/10 text-blue-400 uppercase tracking-widest border border-blue-500/20">
                                    Upcoming
                                </span>
                            </td>
                            <td class="px-4 md:px-6 py-3 md:py-4 text-right">
                                <a href="/admin/event/<%= event._id %>"
                                    class="inline-flex items-center gap-1 md:gap-2 px-2.5 md:px-4 py-1.5 md:py-2 text-xs font-bold uppercase tracking-wider rounded-lg text-[#00f2ff] border border-[#00f2ff]/30 hover:bg-[#00f2ff] hover:text-black hover:shadow-[0_0_15px_rgba(0,242,255,0.4)] transition-all active:scale-95">
                                    <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">edit</span>
                                    Manage
                                </a>
                            </td>
                        </tr>
                        <% } %>

                    </tbody>
                </table>
            </div>
        </div>
        <!-- END: Events Table -->

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-6 md:mt-8">
            
            <div class="bg-surface rounded-custom border border-white/5 p-4 md:p-6 lg:col-span-1 h-fit">
                <div class="flex items-center gap-2 mb-4">
                    <span class="material-symbols-outlined text-primary">campaign</span>
                    <h2 class="font-display font-semibold text-white text-sm md:text-base">Broadcast Message</h2>
                </div>
                
                <form action="/admin/announcements/create" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-gray-400 uppercase mb-1.5">Message Text</label>
                        <textarea name="message" required rows="3" class="w-full bg-surface-darker border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:ring-primary focus:border-primary resize-none placeholder:text-white/20" placeholder="e.g., IPL bets are now open!"></textarea>
                    </div>
                    
                    <div>
                        <label class="block text-xs font-semibold text-gray-400 uppercase mb-1.5">Theme Color</label>
                        <select name="theme" class="w-full bg-surface-darker border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:ring-primary focus:border-primary">
                            <option value="primary">Orange (Standard)</option>
                            <option value="success">Green (Success/Winners)</option>
                            <option value="danger">Red (Urgent/Maintenance)</option>
                            <option value="info">Blue (Info)</option>
                        </select>
                    </div>

                    <button type="submit" class="w-full bg-primary hover:bg-primary/90 text-black font-bold py-3 rounded-xl text-sm transition-all flex items-center justify-center gap-2 active:scale-95">
                        <span class="material-symbols-outlined text-[18px]">send</span>
                        PUBLISH NOW
                    </button>
                </form>
            </div>

            <div class="bg-surface rounded-custom border border-white/5 overflow-hidden lg:col-span-2 flex flex-col">
                <div class="px-4 md:px-6 py-4 border-b border-white/5 flex items-center justify-between shrink-0">
                    <h2 class="font-display font-semibold text-white text-sm md:text-base">Manage Announcements</h2>
                    <span class="text-[10px] text-gray-400 uppercase tracking-widest font-bold bg-white/5 px-2 py-1 rounded">Only 1 active at a time</span>
                </div>

                <div class="overflow-x-auto w-full">
                    <table class="w-full min-w-[500px] text-left text-sm whitespace-nowrap">
                        <thead class="bg-surface-lighter/50 text-gray-400 uppercase text-[10px] font-bold tracking-wider">
                            <tr>
                                <th class="px-4 md:px-6 py-3 w-[50%]">Message</th>
                                <th class="px-4 md:px-6 py-3 w-[15%]">Theme</th>
                                <th class="px-4 md:px-6 py-3 w-[15%] text-center">Status</th>
                                <th class="px-4 md:px-6 py-3 w-[20%] text-right">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/10">
                            <% if (typeof announcements !== 'undefined' && announcements.length > 0) { %>
                                <% announcements.forEach(ann => { %>
                                    <tr class="hover:bg-white/5 transition-colors group">
                                        <td class="px-4 md:px-6 py-4">
                                            <p class="text-white font-medium truncate max-w-[250px] md:max-w-[300px]" title="<%= ann.message %>">
                                                <%= ann.message %>
                                            </p>
                                            <p class="text-[10px] text-gray-500 mt-1">
                                                <%= new Date(ann.createdAt).toLocaleDateString('en-GB') %>
                                            </p>
                                        </td>
                                        <td class="px-4 md:px-6 py-4">
                                            <span class="capitalize text-xs font-bold text-gray-300"><%= ann.theme %></span>
                                        </td>
                                        <td class="px-4 md:px-6 py-4 text-center">
                                            <% if (ann.isActive) { %>
                                                <span class="px-2 py-1 rounded-md text-[10px] font-black bg-green-500/10 text-green-500 uppercase tracking-widest border border-green-500/20">Active</span>
                                            <% } else { %>
                                                <span class="px-2 py-1 rounded-md text-[10px] font-black bg-gray-500/10 text-gray-400 uppercase tracking-widest border border-gray-500/20">Inactive</span>
                                            <% } %>
                                        </td>
                                        <td class="px-4 md:px-6 py-4 text-right">
                                            <div class="flex items-center justify-end gap-2">
                                                <form action="/admin/announcements/toggle/<%= ann._id %>" method="POST" class="m-0">
                                                    <% if (ann.isActive) { %>
                                                        <button type="submit" class="text-xs font-bold text-yellow-500 hover:text-yellow-400 bg-yellow-500/10 px-3 py-1.5 rounded-lg transition-colors">Deactivate</button>
                                                    <% } else { %>
                                                        <button type="submit" class="text-xs font-bold text-green-500 hover:text-green-400 bg-green-500/10 px-3 py-1.5 rounded-lg transition-colors">Activate</button>
                                                    <% } %>
                                                </form>
                                                
                                                <form action="/admin/announcements/delete/<%= ann._id %>" method="POST" class="m-0" onsubmit="return confirm('Delete this announcement?');">
                                                    <button type="submit" class="text-xs font-bold text-red-500 hover:text-red-400 bg-red-500/10 px-3 py-1.5 rounded-lg transition-colors">
                                                        <span class="material-symbols-outlined text-[16px] mt-0.5">delete</span>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="4" class="px-4 py-8 text-center text-gray-500 text-sm">
                                        No announcements found. Create one to broadcast to users!
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
                <div class="mt-6 md:mt-8 bg-surface rounded-custom border border-white/5 overflow-hidden flex flex-col">
    <div class="px-4 md:px-6 py-4 border-b border-white/5 flex items-center justify-between shrink-0">
        <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[#00f2ff]">data_object</span>
            <h2 class="font-display font-semibold text-white text-sm md:text-base">Active Provider IDs (For Scraping)</h2>
        </div>
        
        <div class="flex items-center gap-3">
            <span class="hidden md:inline-block text-[10px] text-gray-400 uppercase tracking-widest font-bold bg-white/5 px-2 py-1 rounded">Excludes Settled</span>
            
            <% 
                // Filter out events that don't have a providerId, then map to an array of just the IDs
                let allProviderIds = [];
                if (typeof activeEvents !== 'undefined' && activeEvents.length > 0) {
                    allProviderIds = activeEvents.filter(e => e.providerId).map(e => e.providerId);
                }
            %>
            <% if (allProviderIds.length > 0) { %>
                <button onclick="copyAllIds('<%= allProviderIds.join(',') %>', this)" 
                    class="bg-[#00f2ff]/10 hover:bg-[#00f2ff]/20 text-[#00f2ff] border border-[#00f2ff]/30 hover:border-[#00f2ff] text-xs font-bold px-3 py-1.5 rounded transition-all flex items-center gap-1 active:scale-95">
                    <span class="material-symbols-outlined text-[14px]">content_copy</span> Copy All
                </button>
            <% } %>
        </div>
    </div>

    <div class="overflow-x-auto w-full">
        <table class="w-full min-w-[600px] text-left text-sm whitespace-nowrap">
            <thead class="bg-surface-lighter/50 text-gray-400 uppercase text-[10px] font-bold tracking-wider">
                <tr>
                    <th class="px-4 md:px-6 py-3 w-[40%]">Match</th>
                    <th class="px-4 md:px-6 py-3 w-[20%]">Status</th>
                    <th class="px-4 md:px-6 py-3 w-[25%]">Provider ID</th>
                    <th class="px-4 md:px-6 py-3 w-[15%] text-right">Action</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white/10">
                <% if (typeof activeEvents !== 'undefined' && activeEvents.length > 0) { %>
                    <% activeEvents.forEach(event => { %>
                        <tr class="hover:bg-white/5 transition-colors group">
                            <td class="px-4 md:px-6 py-3">
                                <div class="font-bold text-white text-sm"><%= event.homeTeam %> <span class="text-gray-500 text-xs mx-1">vs</span> <%= event.awayTeam %></div>
                                <div class="text-[10px] text-gray-500 mt-0.5 capitalize"><%= event.sport %></div>
                            </td>
                            <td class="px-4 md:px-6 py-3">
                                <% if (event.status === 'live') { %>
                                    <span class="px-2 py-1 rounded-md text-[10px] font-black bg-green-500/10 text-green-500 uppercase tracking-widest border border-green-500/20">Live</span>
                                <% } else { %>
                                    <span class="px-2 py-1 rounded-md text-[10px] font-black bg-blue-500/10 text-blue-400 uppercase tracking-widest border border-blue-500/20"><%= event.status %></span>
                                <% } %>
                            </td>
                            <td class="px-4 md:px-6 py-3">
                                <code class="font-mono text-xs text-[#00f2ff] bg-[#00f2ff]/10 px-2 py-1 rounded border border-[#00f2ff]/20">
                                    <%= event.providerId || 'NOT SET' %>
                                </code>
                            </td>
                            <td class="px-4 md:px-6 py-3 text-right">
                                <% if (event.providerId) { %>
                                    <button onclick="copyProviderId('<%= event.providerId %>')" class="text-xs font-bold text-gray-400 hover:text-black hover:bg-[#00f2ff] border border-white/10 hover:border-[#00f2ff] px-3 py-1.5 rounded-lg transition-all flex items-center justify-end gap-1 ml-auto active:scale-95">
                                        <span class="material-symbols-outlined text-[14px]">content_copy</span> Copy
                                    </button>
                                <% } else { %>
                                    <span class="text-xs text-gray-600 italic">No ID available</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="4" class="px-4 py-8 text-center text-gray-500 text-sm">No active events found for scraping.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
            </div>
        </div>

    </div>
    <!-- END: Dashboard Body -->
</main>

<script>
    function copyProviderId(id) {
        navigator.clipboard.writeText(id).then(() => {
            // Use our custom browser-side flash message
            showAdminToast("Copied!", "success");
        }).catch(err => {
            console.error('Failed to copy text: ', err);
            showAdminToast("Failed to copy.", "error");
        });
    }

    // Client-side Flash Message (Toast) Generator
    function showAdminToast(message, type = "success") {
        // 1. Create the toast element
        const toast = document.createElement("div");
        
        // 2. Style it based on success or error using your Tailwind colors
        const bgColor = type === "success" ? "bg-green-500/10 border-green-500/30 text-green-500" : "bg-red-500/10 border-red-500/30 text-red-500";
        const icon = type === "success" ? "check_circle" : "error";

        toast.className = `fixed top-6 left-1/2 -translate-x-1/2 z-[100] flex items-center gap-3 px-5 py-3.5 rounded-2xl border backdrop-blur-md transition-all duration-300 transform translate-y-[-20px] opacity-0 ${bgColor} shadow-lg`;
        
        toast.innerHTML = `
            <span class="material-symbols-outlined text-xl">${icon}</span>
            <p class="text-sm font-bold tracking-wide">${message}</p>
        `;

        // 3. Add to the page
        document.body.appendChild(toast);

        // 4. Animate in
        requestAnimationFrame(() => {
            toast.classList.remove("translate-y-[-20px]", "opacity-0");
            toast.classList.add("translate-y-0", "opacity-100");
        });

        // 5. Remove after 3 seconds
        setTimeout(() => {
            toast.classList.remove("translate-y-0", "opacity-100");
            toast.classList.add("translate-y-[-20px]", "opacity-0");
            setTimeout(() => toast.remove(), 300); // Wait for fade out to finish before removing from DOM
        }, 3000);
    }

    function copyAllIds(rawIdsString, btnElement) {
        if (!rawIdsString) return;
        
        // This splits the EJS string and rejoins it with " , " to get your requested format: "id1 , id2 , id3"
        const formattedArrayStr = rawIdsString.split(',').join(' , ');

        navigator.clipboard.writeText(formattedArrayStr).then(() => {
            // Save original HTML
            const originalHTML = btnElement.innerHTML;
            
            // Visual feedback: Change to green checkmark
            btnElement.innerHTML = '<span class="material-symbols-outlined text-[14px]">check</span> Copied!';
            btnElement.classList.replace('text-[#00f2ff]', 'text-green-400');
            btnElement.classList.replace('bg-[#00f2ff]/10', 'bg-green-500/20');
            btnElement.classList.replace('border-[#00f2ff]/30', 'border-green-500/50');
            
            // Revert back to original after 2 seconds
            setTimeout(() => {
                btnElement.innerHTML = originalHTML;
                btnElement.classList.replace('text-green-400', 'text-[#00f2ff]');
                btnElement.classList.replace('bg-green-500/20', 'bg-[#00f2ff]/10');
                btnElement.classList.replace('border-green-500/50', 'border-[#00f2ff]/30');
            }, 2000);
        }).catch(err => {
            console.error('Failed to copy text: ', err);
            alert("Failed to copy IDs to clipboard.");
        });
    }
</script>
