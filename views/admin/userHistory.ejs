<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>User History | Admin</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@300..700,0..1&display=swap" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #121212; color: #e0e0e0; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; vertical-align: middle; }
        
        /* Dark Theme Table Borders */
        th { border-bottom: 2px solid #333333; }
        td { border-bottom: 1px solid #2a2a2a; }
        
        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #1a1a1a; }
        ::-webkit-scrollbar-thumb { background: #444; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #666; }
    </style>
</head>

<body class="antialiased selection:bg-blue-500/30">
    <main class="p-6 md:p-10 min-h-screen max-w-[1400px] mx-auto">
        
        <div class="mb-6">
            <a class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors text-sm font-medium group" href="/admin?tab=UserManagement">
                <span class="material-symbols-outlined text-lg transition-transform group-hover:-translate-x-1">arrow_back</span>
                Back to Users
            </a>
        </div>

        <section class="mb-8 bg-[#1e1e1e] border border-[#333] rounded-lg p-6 flex flex-col lg:flex-row justify-between items-center gap-8 shadow-md">
            <div class="flex items-center gap-6 w-full lg:w-auto">
                <div class="relative">
                    <div class="w-20 h-20 rounded-full bg-[#2a2a2a] flex items-center justify-center text-white text-3xl font-bold border border-[#444] uppercase">
                        <%= user.name.charAt(0) %>
                    </div>
                    <div class="absolute bottom-1 right-1 w-4 h-4 <%= user.isBlocked ? 'bg-red-500' : 'bg-emerald-500' %> border-2 border-[#1e1e1e] rounded-full"></div>
                </div>
                <div>
                    <div class="flex items-center gap-3 mb-1">
                        <h1 class="text-2xl font-bold text-white"><%= user.name %></h1>
                        <span class="px-2.5 py-0.5 rounded text-xs font-semibold uppercase tracking-wide border <%= user.role === 'admin' ? 'bg-blue-500/10 text-blue-400 border-blue-500/20' : 'bg-[#2a2a2a] text-gray-300 border-[#444]' %>">
                            <%= user.role %>
                        </span>
                    </div>
                    <p class="text-gray-400 text-sm mb-1 font-mono text-xs">ID: <%= user._id %></p>
                    <p class="text-gray-300 text-sm flex items-center gap-1.5 font-medium">
                        <span class="material-symbols-outlined text-[16px]">call</span>
                        <%= user.contactNumber || 'No contact provided' %>
                    </p>
                    <div class="flex gap-4 mt-3 text-xs font-medium text-gray-500 uppercase tracking-wide">
                        <span>Joined: <%= new Date(user.createdAt).toLocaleDateString() %></span>
                    </div>
                </div>
            </div>
            
            <div class="flex items-center gap-8 w-full lg:w-auto justify-between lg:justify-end">
                <div class="text-right">
                    <p class="text-gray-500 text-xs uppercase tracking-wider font-semibold mb-1">Balance</p>
                    <p class="text-2xl font-bold text-blue-400">₹<%= user.balance.toFixed(2) %></p>
                </div>
                <div class="w-px h-12 bg-[#333] hidden sm:block"></div>
                <div class="text-right">
                    <p class="text-gray-500 text-xs uppercase tracking-wider font-semibold mb-1">Total Deposits</p>
                    <p class="text-xl font-bold text-emerald-400">₹<%= stats.totalDeposits.toLocaleString() %></p>
                </div>
                <div class="w-px h-12 bg-[#333] hidden sm:block"></div>
                <div class="text-right">
                    <p class="text-gray-500 text-xs uppercase tracking-wider font-semibold mb-1">Withdrawals</p>
                    <p class="text-xl font-bold text-red-400">₹<%= stats.totalWithdrawals.toLocaleString() %></p>
                </div>
            </div>
        </section>

        <section class="bg-[#1e1e1e] border border-[#333] rounded-lg shadow-md mb-8">
            <div class="p-5 border-b border-[#333] flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 bg-[#181818] rounded-t-lg">
                <h2 class="text-lg font-bold text-white flex items-center gap-2">
                    <span class="material-symbols-outlined text-gray-400">list_alt</span>
                    Account Ledger
                </h2>
                
                <div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto">
                    <div class="relative w-full sm:w-auto">
                        <select id="history-filter" onchange="window.location.href='?type=' + this.value + '&page=1'" class="appearance-none w-full sm:w-48 bg-[#2a2a2a] border border-[#444] rounded block py-2 px-3 pr-8 text-sm text-gray-200 focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500 cursor-pointer">
                            <option value="all" <%= filterType === 'all' ? 'selected' : '' %>>All Activity</option>
                            <option value="won" <%= filterType === 'won' ? 'selected' : '' %>>Won Bets</option>
                            <option value="lost" <%= filterType === 'lost' ? 'selected' : '' %>>Lost Bets</option>
                            <option value="deposit" <%= filterType === 'deposit' ? 'selected' : '' %>>Deposits</option>
                            <option value="withdraw" <%= filterType === 'withdraw' ? 'selected' : '' %>>Withdrawals</option>
                        </select>
                        <span class="material-symbols-outlined absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none text-sm">expand_more</span>
                    </div>
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse whitespace-nowrap">
                    <thead>
                        <tr class="bg-[#181818]">
                            <th class="px-5 py-3 text-xs font-semibold text-gray-400 uppercase tracking-wider">ID / Ref</th>
                            <th class="px-5 py-3 text-xs font-semibold text-gray-400 uppercase tracking-wider">Date & Time</th>
                            <th class="px-5 py-3 text-xs font-semibold text-gray-400 uppercase tracking-wider">Event Details</th>
                            <th class="px-5 py-3 text-xs font-semibold text-gray-400 uppercase tracking-wider text-center">Market</th>
                            <th class="px-5 py-3 text-xs font-semibold text-gray-400 uppercase tracking-wider text-right">Odds</th>
                            <th class="px-5 py-3 text-xs font-semibold text-gray-400 uppercase tracking-wider text-right">Stake/Amt</th>
                            <th class="px-5 py-3 text-xs font-semibold text-gray-400 uppercase tracking-wider text-center">Status</th>
                            <th class="px-5 py-3 text-xs font-semibold text-gray-400 uppercase tracking-wider text-right">Net Return</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[#2a2a2a] bg-[#1e1e1e]">
                        
                        <% if (ledger && ledger.length > 0) { %>
                            <% ledger.forEach(item => { %>
                                <tr class="hover:bg-[#252525] transition-colors group">
                                    
                                    <td class="px-5 py-4 font-mono text-xs text-gray-500">
                                        <% if(item._id.toString().startsWith('TXN')) { %>
                                            <span class="text-blue-400/80"><%= item._id %></span>
                                        <% } else { %>
                                            <%= item._id.toString().substring(0, 8).toUpperCase() %>
                                        <% } %>
                                    </td>
                                    
                                    <td class="px-5 py-4 text-xs text-gray-400">
                                        <span class="font-medium text-gray-300"><%= new Date(item.createdAt).toLocaleDateString() %></span><br />
                                        <span class="text-[11px]"><%= new Date(item.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></span>
                                    </td>
                                    
                                    <td class="px-5 py-4">
                                        <p class="text-sm font-semibold text-gray-200"><%= item.title %></p>
                                        <p class="text-xs text-gray-400 font-medium mt-0.5"><%= item.details %></p>
                                    </td>
                                    
                                    <td class="px-5 py-4 text-center">
                                        <% if (item.type === 'bet') { %>
                                            <% if (item.betType.toLowerCase() === 'back') { %>
                                                <span class="px-2 py-1 rounded text-[11px] font-bold uppercase bg-[#72bbef] text-gray-900 shadow-[inset_0_1px_2px_rgba(255,255,255,0.4)]">BACK</span>
                                            <% } else if (item.betType.toLowerCase() === 'lay') { %>
                                                <span class="px-2 py-1 rounded text-[11px] font-bold uppercase bg-[#faa9ba] text-gray-900 shadow-[inset_0_1px_2px_rgba(255,255,255,0.4)]">LAY</span>
                                            <% } else if (item.betType.toLowerCase() === 'casino') { %>
                                                <span class="px-2 py-1 rounded text-[11px] font-bold uppercase bg-purple-500/20 text-purple-300 border border-purple-500/30">CASINO</span>
                                            <% } else { %>
                                                <span class="px-2 py-1 rounded text-[11px] font-bold uppercase bg-[#2a2a2a] text-gray-400"><%= item.betType %></span>
                                            <% } %>
                                        <% } else { %>
                                            <span class="text-gray-600 text-xs">--</span>
                                        <% } %>
                                    </td>
                                    
                                    <td class="px-5 py-4 text-right text-sm font-bold text-gray-300">
                                        <%= item.odds %>
                                    </td>
                                    
                                    <td class="px-5 py-4 text-right text-sm font-bold text-white">
                                        ₹<%= item.amount.toFixed(2) %>
                                    </td>
                                    
                                    <td class="px-5 py-4 text-center">
                                        <% if (item.status === 'won' || item.status === 'approved') { %>
                                            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-emerald-500/10 text-emerald-400 text-xs font-bold border border-emerald-500/20">
                                                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> <%= item.status.toUpperCase() %>
                                            </span>
                                        <% } else if (item.status === 'lost' || item.status === 'rejected') { %>
                                            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-red-500/10 text-red-400 text-xs font-bold border border-red-500/20">
                                                <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span> <%= item.status.toUpperCase() %>
                                            </span>
                                        <% } else if (item.status === 'void') { %>
                                            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-gray-500/10 text-gray-400 text-xs font-bold border border-gray-500/20">
                                                <span class="w-1.5 h-1.5 rounded-full bg-gray-500"></span> VOID
                                            </span>
                                        <% } else { %>
                                            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-yellow-500/10 text-yellow-400 text-xs font-bold border border-yellow-500/20">
                                                <span class="w-1.5 h-1.5 rounded-full bg-yellow-500"></span> PENDING
                                            </span>
                                        <% } %>
                                    </td>
                                    
                                    <td class="px-5 py-4 text-right text-sm font-bold <%= (item.type === 'deposit' || item.status === 'won') ? 'text-emerald-400' : (item.status === 'pending' || item.status === 'void' ? 'text-gray-500' : 'text-red-400') %>">
                                        <% if (item.type === 'bet') { %>
                                            <%= item.status === 'won' ? '+₹' + item.payout.toFixed(2) : (item.status === 'lost' ? '-₹' + item.amount.toFixed(2) : '--') %>
                                        <% } else if (item.type === 'deposit') { %>
                                            +₹<%= item.amount.toFixed(2) %>
                                        <% } else if (item.type === 'withdraw') { %>
                                            -₹<%= item.amount.toFixed(2) %>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="8" class="px-6 py-12 text-center text-gray-500 bg-[#181818]/50">
                                    <span class="material-symbols-outlined text-4xl mb-2 text-gray-600">receipt_long</span>
                                    <p class="text-sm font-medium">No financial history found for this user.</p>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <% if (totalPages > 1) { %>
                <div class="p-4 border-t border-[#333] flex items-center justify-between bg-[#181818] rounded-b-lg">
                    <p class="text-sm text-gray-400">
                        Showing page <span class="font-medium text-white"><%= currentPage %></span> of <span class="font-medium text-white"><%= totalPages %></span>
                    </p>
                    <div class="flex items-center gap-2">
                        <a href="?type=<%= filterType %>&page=<%= currentPage > 1 ? currentPage - 1 : 1 %>" 
                           class="px-3 py-1.5 border border-[#444] rounded text-sm font-medium text-gray-300 bg-[#2a2a2a] hover:bg-[#333] transition-colors <%= currentPage === 1 ? 'opacity-50 cursor-not-allowed pointer-events-none' : '' %>">
                            Previous
                        </a>
                        
                        <div class="flex gap-1 hidden sm:flex">
                            <% for(let i = 1; i <= totalPages; i++) { %>
                                <a href="?type=<%= filterType %>&page=<%= i %>" 
                                   class="px-3 py-1.5 border rounded text-sm font-medium transition-colors <%= currentPage === i ? 'bg-blue-600 border-blue-500 text-white' : 'border-[#444] text-gray-300 bg-[#2a2a2a] hover:bg-[#333]' %>">
                                    <%= i %>
                                </a>
                            <% } %>
                        </div>

                        <a href="?type=<%= filterType %>&page=<%= currentPage < totalPages ? currentPage + 1 : totalPages %>" 
                           class="px-3 py-1.5 border border-[#444] rounded text-sm font-medium text-gray-300 bg-[#2a2a2a] hover:bg-[#333] transition-colors <%= currentPage === totalPages ? 'opacity-50 cursor-not-allowed pointer-events-none' : '' %>">
                            Next
                        </a>
                    </div>
                </div>
            <% } %>
        </section>

        <section class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="md:col-span-2 bg-[#1e1e1e] border border-[#333] rounded-lg p-6 shadow-md">
                <h3 class="text-sm font-bold text-gray-300 uppercase tracking-wider mb-5 pb-2 border-b border-[#333]">Risk Profile & Metrics</h3>
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
                    <div>
                        <p class="text-xs text-gray-500 uppercase tracking-wide font-medium mb-1">Win Rate</p>
                        <p class="text-2xl font-bold text-emerald-400"><%= stats.winRate %>%</p>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 uppercase tracking-wide font-medium mb-1">Avg. Stake</p>
                        <p class="text-2xl font-bold text-white">₹<%= stats.avgStake %></p>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 uppercase tracking-wide font-medium mb-1">Max Win</p>
                        <p class="text-2xl font-bold text-blue-400">₹<%= stats.maxWin.toLocaleString() %></p>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 uppercase tracking-wide font-medium mb-1">Status</p>
                        <p class="text-2xl font-bold <%= user.isBlocked ? 'text-red-500' : 'text-emerald-500' %>">
                            <%= user.isBlocked ? 'Blocked' : 'Active' %>
                        </p>
                    </div>
                </div>
            </div>
            
            <div class="bg-[#182028] border border-blue-500/20 rounded-lg p-6 flex flex-col justify-center items-center text-center shadow-md">
                <div class="w-12 h-12 bg-blue-500/10 rounded-full flex items-center justify-center mb-3 border border-blue-500/20">
                    <span class="material-symbols-outlined text-blue-400">manage_accounts</span>
                </div>
                <h4 class="text-sm font-bold text-gray-200 mb-1">Admin Controls</h4>
                <p class="text-xs text-gray-400 mb-5">Modify balance, apply restrictions, or edit basic details.</p>
                <a href="/admin/user/<%= user._id %>/edit" class="px-4 py-2 w-full bg-blue-600/90 text-white rounded font-semibold text-sm hover:bg-blue-600 transition-colors shadow-md border border-blue-500/50">
                    Edit User Profile
                </a>
            </div>
        </section>
    </main>
</body>
</html>