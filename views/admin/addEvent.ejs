<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Create New Event - Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'dark-bg': '#0a0a0a',
                        'dark-surface': '#1a1a1a',
                        'neon-blue': '#00f2ff',
                        'neon-blue-hover': '#00d1db',
                        'border-dark': '#2d2d2d',
                        'back-blue': '#72bbef',
                        'lay-pink': '#faa9ba'
                    }
                }
            }
        }
    </script>
    <style data-purpose="custom-layout">
        input,
        select {
            background-color: #1a1a1a !important;
            border-color: #2d2d2d !important;
            color: #ffffff !important;
            padding: 0.5rem 0.75rem !important;
        }

        input:focus,
        select:focus {
            border-color: #00f2ff !important;
            --tw-ring-color: #00f2ff !important;
            outline: none;
        }

        ::-webkit-calendar-picker-indicator {
            filter: invert(1);
        }
    </style>
</head>

<body class="bg-dark-bg text-gray-200 min-h-screen font-sans antialiased p-4 md:p-8">
    <main class="max-w-4xl mx-auto">
        <header class="mb-8 border-b border-border-dark pb-4">
            <h1 class="text-3xl font-bold text-white tracking-tight">Create New Event</h1>
            <p class="text-gray-400 mt-1">Configure and launch a new sports market.</p>
        </header>
        
        <form action="/admin/addEvent" class="space-y-8 bg-dark-surface p-6 md:p-10 rounded-xl border border-border-dark shadow-2xl" method="POST">
            
            <section>
                <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2">
                    <span class="w-2 h-6 bg-neon-blue rounded-full inline-block"></span>
                    Event Details
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex flex-col gap-1.5">
                        <label class="text-sm font-medium text-gray-400" for="sport">Sport</label>
                        <select class="block w-full rounded-md shadow-sm sm:text-sm" id="sport" name="sport" onchange="toggleTossMarket()">
                            <option value="cricket">Cricket</option>
                            <option value="football">Football</option>
                            <option value="tennis">Tennis</option>
                        </select>
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label class="text-sm font-medium text-gray-400" for="league">League/Tournament</label>
                        <input class="block w-full rounded-md shadow-sm sm:text-sm" id="league" name="league" placeholder="e.g. Premier League" type="text" />
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label class="text-sm font-medium text-gray-400" for="eventId">Internal Event ID</label>
                        <input class="block w-full rounded-md shadow-sm sm:text-sm" id="eventId" name="eventId" placeholder="UID-8829" type="text" />
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label class="text-sm font-medium text-gray-400" for="startTime">Start Time</label>
                        <input class="block w-full rounded-md shadow-sm sm:text-sm" id="startTime" name="startTime" type="datetime-local" />
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label class="text-sm font-medium text-gray-400" for="status">Status</label>
                        <select class="block w-full rounded-md shadow-sm sm:text-sm" id="status" name="status">
                            <option value="upcoming">Upcoming</option>
                            <option value="pending">Pending</option>
                            <option value="live">Live</option>
                            <option value="finished">Finished</option>
                        </select>
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label class="text-sm font-medium text-neon-blue" for="providerId">Provider Match ID *</label>
                        <input class="block w-full rounded-md shadow-sm sm:text-sm border-neon-blue/50" id="providerId" name="providerId" placeholder="e.g. 35387026" type="text" required />
                    </div>
                </div>
            </section>

            <hr class="border-border-dark" />
            
            <section>
                <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2">
                    <span class="w-2 h-6 bg-neon-blue rounded-full inline-block"></span>
                    Team Details
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex flex-col gap-1.5">
                        <label class="text-sm font-medium text-gray-400" for="homeTeam">Home Team</label>
                        <input class="block w-full rounded-md shadow-sm sm:text-sm" id="homeTeam" name="homeTeam" placeholder="Home Team Name" type="text" />
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label class="text-sm font-medium text-gray-400" for="awayTeam">Away Team</label>
                        <input class="block w-full rounded-md shadow-sm sm:text-sm" id="awayTeam" name="awayTeam" placeholder="Away Team Name" type="text" />
                    </div>
                </div>
            </section>

            <hr class="border-border-dark" />
            
            <section>
                <h2 class="text-lg font-semibold text-white mb-6 flex items-center gap-2">
                    <span class="w-2 h-6 bg-neon-blue rounded-full inline-block"></span>
                    Initial Markets & Odds
                </h2>
                
                <div class="space-y-8">
                    <div>
                        <h3 class="text-sm uppercase tracking-widest text-gray-400 font-bold mb-4">Match Odds (1X2)</h3>
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                            <div class="p-4 bg-dark-bg border border-border-dark rounded-lg">
                                <label class="text-sm font-medium text-gray-300 mb-3 block text-center">Home Win</label>
                                <div class="grid grid-cols-2 gap-2">
                                    <div class="flex flex-col gap-1 text-center">
                                        <span class="text-xs text-back-blue font-semibold">Back</span>
                                        <input class="block w-full rounded-md shadow-sm sm:text-sm text-center" name="matchOdds[homeOdds]" placeholder="0.00" step="0.01" type="number" />
                                    </div>
                                    <div class="flex flex-col gap-1 text-center">
                                        <span class="text-xs text-lay-pink font-semibold">Lay</span>
                                        <input class="block w-full rounded-md shadow-sm sm:text-sm text-center" name="matchOdds[homeLay]" placeholder="0.00" step="0.01" type="number" />
                                    </div>
                                </div>
                            </div>
                            <div class="p-4 bg-dark-bg border border-border-dark rounded-lg">
                                <label class="text-sm font-medium text-gray-300 mb-3 block text-center">Away Win</label>
                                <div class="grid grid-cols-2 gap-2">
                                    <div class="flex flex-col gap-1 text-center">
                                        <span class="text-xs text-back-blue font-semibold">Back</span>
                                        <input class="block w-full rounded-md shadow-sm sm:text-sm text-center" name="matchOdds[awayOdds]" placeholder="0.00" step="0.01" type="number" />
                                    </div>
                                    <div class="flex flex-col gap-1 text-center">
                                        <span class="text-xs text-lay-pink font-semibold">Lay</span>
                                        <input class="block w-full rounded-md shadow-sm sm:text-sm text-center" name="matchOdds[awayLay]" placeholder="0.00" step="0.01" type="number" />
                                    </div>
                                </div>
                            </div>
                            <div class="p-4 bg-dark-bg border border-border-dark rounded-lg">
                                <label class="text-sm font-medium text-gray-300 mb-3 block text-center">Draw</label>
                                <div class="grid grid-cols-2 gap-2">
                                    <div class="flex flex-col gap-1 text-center">
                                        <span class="text-xs text-back-blue font-semibold">Back</span>
                                        <input class="block w-full rounded-md shadow-sm sm:text-sm text-center" name="matchOdds[drawOdds]" placeholder="0.00" step="0.01" type="number" />
                                    </div>
                                    <div class="flex flex-col gap-1 text-center">
                                        <span class="text-xs text-lay-pink font-semibold">Lay</span>
                                        <input class="block w-full rounded-md shadow-sm sm:text-sm text-center" name="matchOdds[drawLay]" placeholder="0.00" step="0.01" type="number" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="toss-market-section">
                        <h3 class="text-sm uppercase tracking-widest text-gray-400 font-bold mb-4">Toss Market</h3>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div class="p-4 bg-dark-bg border border-border-dark rounded-lg">
                                <label class="text-sm font-medium text-gray-300 mb-3 block text-center">Home Toss</label>
                                <div class="grid grid-cols-2 gap-2">
                                    <div class="flex flex-col gap-1 text-center">
                                        <span class="text-xs text-back-blue font-semibold">Back</span>
                                        <input class="block w-full rounded-md shadow-sm sm:text-sm text-center" name="tossMarket[homeOdds]" value="1.95" step="0.01" type="number" />
                                    </div>
                                    <div class="flex flex-col gap-1 text-center">
                                        <span class="text-xs text-lay-pink font-semibold">Lay</span>
                                        <input class="block w-full rounded-md shadow-sm sm:text-sm text-center" name="tossMarket[homeLay]" value="1.95" step="0.01" type="number" />
                                    </div>
                                </div>
                            </div>
                            <div class="p-4 bg-dark-bg border border-border-dark rounded-lg">
                                <label class="text-sm font-medium text-gray-300 mb-3 block text-center">Away Toss</label>
                                <div class="grid grid-cols-2 gap-2">
                                    <div class="flex flex-col gap-1 text-center">
                                        <span class="text-xs text-back-blue font-semibold">Back</span>
                                        <input class="block w-full rounded-md shadow-sm sm:text-sm text-center" name="tossMarket[awayOdds]" value="1.95" step="0.01" type="number" />
                                    </div>
                                    <div class="flex flex-col gap-1 text-center">
                                        <span class="text-xs text-lay-pink font-semibold">Lay</span>
                                        <input class="block w-full rounded-md shadow-sm sm:text-sm text-center" name="tossMarket[awayLay]" value="1.95" step="0.01" type="number" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            
            <div class="pt-6 flex justify-end gap-4 border-t border-border-dark">
                <a href="/admin" class="px-6 py-2 rounded-md border border-border-dark text-gray-300 font-medium hover:bg-white/5 transition-colors" type="button">
                    Cancel
                </a>
                <button class="px-8 py-2 rounded-md bg-neon-blue text-dark-bg font-bold shadow-[0_0_10px_rgba(0,242,255,0.2)] hover:bg-neon-blue-hover hover:shadow-[0_0_15px_rgba(0,242,255,0.4)] transition-all" type="submit">
                    Create Event
                </button>
            </div>
        </form>
    </main>

    <script>
        function toggleTossMarket() {
            const sportSelect = document.getElementById('sport');
            const tossSection = document.getElementById('toss-market-section');
            
            if (sportSelect.value.toLowerCase() === 'cricket') {
                tossSection.style.display = 'block';
            } else {
                tossSection.style.display = 'none';
            }
        }

        // Run on page load to set the initial state
        document.addEventListener('DOMContentLoaded', toggleTossMarket);
    </script>
</body>

</html>