<!DOCTYPE html>
<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Event Management Dashboard - <%=Event.homeTeam%> vs <%=Event.awayTeam%></title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'dark-bg': '#0a0a0a',
                        'dark-surface': '#1a1a1a',
                        'dark-border': '#2d2d2d',
                        'neon-blue': '#00f2ff',
                        'neon-green': '#39ff14',
                        'neon-red': '#ff3131',
                        'lay-pink': '#faa9ba',
                        'back-blue': '#72bbef'
                    },
                    boxShadow: {
                        'neon-blue': '0 0 10px rgba(0, 242, 255, 0.3)',
                        'neon-green': '0 0 10px rgba(57, 255, 20, 0.3)',
                        'neon-red': '0 0 10px rgba(255, 49, 49, 0.3)'
                    }
                }
            }
        }
    </script>
    <style data-purpose="custom-scrollbars">
        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #0a0a0a;
        }

        ::-webkit-scrollbar-thumb {
            background: #2d2d2d;
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #3d3d3d;
        }
    </style>
    <style data-purpose="neon-effects">
        .focus-neon-blue:focus {
            outline: none;
            border-color: #00f2ff;
            box-shadow: 0 0 5px #00f2ff;
        }

        .focus-neon-green:focus {
            outline: none;
            border-color: #39ff14;
            box-shadow: 0 0 5px #39ff14;
        }

        .focus-neon-red:focus {
            outline: none;
            border-color: #ff3131;
            box-shadow: 0 0 5px #ff3131;
        }

        .status-badge-live {
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.6; }
            100% { opacity: 1; }
        }
    </style>
</head>

<body class="bg-dark-bg text-gray-100 min-h-screen font-sans">
    <header class="p-6 border-b border-dark-border bg-dark-surface sticky top-0 z-50">
        <div class="max-w-7xl mx-auto">
            <a href="/admin?tab=Dashboard" class="flex items-center text-sm text-gray-400 hover:text-neon-blue transition-colors mb-4"
                data-purpose="back-navigation">
                <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewbox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg">
                    <path d="M10 19l-7-7m0 0l7-7m-7 7h18" stroke-linecap="round" stroke-linejoin="round"
                        stroke-width="2"></path>
                </svg>
                Back to Events
            </a>
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
                <div>
                    <div class="flex items-center gap-3">
                        <h1 class="text-3xl font-bold tracking-tight text-white"><%=Event.homeTeam%> vs <%=Event.awayTeam%></h1>
                        <% if(Event.status === 'live') { %>
                            <span class="status-badge-live px-2 py-0.5 rounded bg-red-600 text-white text-xs font-bold tracking-widest uppercase">LIVE</span>
                        <% } %>
                    </div>
                    <p class="text-gray-400 mt-1"><%=Event.sport%> | <%=Event.league%> | <%=Event.startTime%></p>
                </div>
                <div class="flex items-center gap-3">
                    <span class="text-xs text-gray-500">Last updated: <%=Event.updatedAt%></span>
                    <button class="bg-dark-border hover:bg-gray-800 text-white px-4 py-2 rounded-md text-sm font-medium transition-all">Refresh Data</button>
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            
            <section class="bg-dark-surface border border-dark-border rounded-xl p-6 shadow-xl"
                data-purpose="general-status">
                <h2 class="text-lg font-semibold mb-6 flex items-center gap-2">
                    <svg class="h-5 w-5 text-neon-green" fill="none" stroke="currentColor" viewbox="0 0 24 24"
                        xmlns="http://www.w3.org/2000/svg">
                        <path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round"
                            stroke-linejoin="round" stroke-width="2"></path>
                    </svg>
                    General Event Status
                </h2>
                <div class="space-y-4">
                    <form action="/admin/event/<%=Event._id%>/update-status" method="POST">
                        <div>
                            <label class="block text-xs font-medium text-gray-500 uppercase mb-2">Event Status</label>
                            <select name="status"
                                class="w-full bg-dark-bg border-dark-border rounded-md text-white focus-neon-green transition-all py-2.5">
                                <option value="upcoming" <%= Event.status === 'upcoming' ? 'selected' : '' %>>Upcoming</option>
                                <option value="pending" <%= Event.status === 'pending' ? 'selected' : '' %>>Pending</option>
                                <option value="live" <%= Event.status === 'live' ? 'selected' : '' %>>Live</option>
                                <option value="finished" <%= Event.status === 'finished' ? 'selected' : '' %>>Finished</option>
                            </select>
                        </div>
                        <div class="mt-4">
                            <label class="block text-xs font-medium text-gray-500 uppercase mb-2">Match Result</label>
                            <select name="result"
                                class="w-full bg-dark-bg border-dark-border rounded-md text-white focus-neon-green transition-all py-2.5">
                                <option value="" <%= !Event.result ? 'selected' : '' %>>Select Result</option>
                                <option value="home" <%= Event.result === 'home' ? 'selected' : '' %>><%= Event.homeTeam %></option>
                                <option value="away" <%= Event.result === 'away' ? 'selected' : '' %>> <%= Event.awayTeam %></option>
                                <option value="draw" <%= Event.result === 'draw' ? 'selected' : '' %>>Draw</option>
                                <option value="void" <%= Event.result === 'void' ? 'selected' : '' %>>Void</option>
                            </select>
                        </div>
                        <button type="submit"
                            class="w-full mt-6 bg-neon-green hover:bg-opacity-90 text-black font-bold py-3 rounded-md shadow-neon-green transition-all uppercase text-sm tracking-wider">
                            Save Status
                        </button>
                    </form>
                </div>
            </section>

            <section class="bg-dark-surface border border-dark-border rounded-xl p-6 shadow-xl"
                data-purpose="match-odds">
                <h2 class="text-lg font-semibold mb-6 flex items-center gap-2">
                    <svg class="h-5 w-5 text-neon-blue" fill="none" stroke="currentColor" viewbox="0 0 24 24"
                        xmlns="http://www.w3.org/2000/svg">
                        <path
                            d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
                            stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                    </svg>
                    Edit Match Odds (1X2)
                </h2>
                <form action="/admin/event/<%= Event._id %>/update-match-odds" method="POST">
                    <div class="space-y-4">
                        
                        <div class="bg-dark-bg p-3 rounded-lg border border-dark-border">
                            <label class="block text-xs font-bold text-gray-400 uppercase mb-2">Home (1)</label>
                            <div class="grid grid-cols-2 gap-3">
                                <div>
                                    <label class="block text-[10px] text-back-blue uppercase mb-1 font-semibold">Back</label>
                                    <input name="homeOdds" class="w-full bg-dark-surface border-dark-border rounded text-white focus-neon-blue py-1.5 text-sm" step="0.01" type="number" value="<%= Event.matchOdds.homeOdds %>" />
                                </div>
                                <div>
                                    <label class="block text-[10px] text-lay-pink uppercase mb-1 font-semibold">Lay</label>
                                    <input name="homeLay" class="w-full bg-dark-surface border-dark-border rounded text-white focus-neon-red py-1.5 text-sm" step="0.01" type="number" value="<%= Event.matchOdds.homeLay %>" />
                                </div>
                            </div>
                        </div>

                        <div class="bg-dark-bg p-3 rounded-lg border border-dark-border">
                            <label class="block text-xs font-bold text-gray-400 uppercase mb-2">Draw (X)</label>
                            <div class="grid grid-cols-2 gap-3">
                                <div>
                                    <label class="block text-[10px] text-back-blue uppercase mb-1 font-semibold">Back</label>
                                    <input name="drawOdds" class="w-full bg-dark-surface border-dark-border rounded text-white focus-neon-blue py-1.5 text-sm" step="0.01" type="number" value="<%= Event.matchOdds.drawOdds %>" />
                                </div>
                                <div>
                                    <label class="block text-[10px] text-lay-pink uppercase mb-1 font-semibold">Lay</label>
                                    <input name="drawLay" class="w-full bg-dark-surface border-dark-border rounded text-white focus-neon-red py-1.5 text-sm" step="0.01" type="number" value="<%= Event.matchOdds.drawLay %>" />
                                </div>
                            </div>
                        </div>

                        <div class="bg-dark-bg p-3 rounded-lg border border-dark-border">
                            <label class="block text-xs font-bold text-gray-400 uppercase mb-2">Away (2)</label>
                            <div class="grid grid-cols-2 gap-3">
                                <div>
                                    <label class="block text-[10px] text-back-blue uppercase mb-1 font-semibold">Back</label>
                                    <input name="awayOdds" class="w-full bg-dark-surface border-dark-border rounded text-white focus-neon-blue py-1.5 text-sm" step="0.01" type="number" value="<%= Event.matchOdds.awayOdds %>" />
                                </div>
                                <div>
                                    <label class="block text-[10px] text-lay-pink uppercase mb-1 font-semibold">Lay</label>
                                    <input name="awayLay" class="w-full bg-dark-surface border-dark-border rounded text-white focus-neon-red py-1.5 text-sm" step="0.01" type="number" value="<%= Event.matchOdds.awayLay %>" />
                                </div>
                            </div>
                        </div>

                        <div class="flex items-center justify-between py-3 border-y border-dark-border mt-2">
                            <span class="text-sm text-gray-400 font-medium">Market Status</span>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input name="marketStatus" value="active" type="checkbox" class="sr-only peer" 
                                       <%= Event.matchOdds.status === 'active' ? 'checked' : '' %> />
                                <div class="w-11 h-6 bg-gray-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-neon-blue">
                                </div>
                                <span class="ml-3 text-xs font-bold text-gray-300 uppercase">Active</span>
                            </label>
                        </div>

                        <button type="submit"
                            class="w-full mt-2 bg-neon-blue hover:bg-opacity-90 text-black font-bold py-3 rounded-md shadow-neon-blue transition-all uppercase text-sm tracking-wider">
                            Update Match Odds
                        </button>
                    </div>
                </form>
            </section>

            <section class="bg-dark-surface border border-dark-border rounded-xl p-6 shadow-xl" data-purpose="toss-market">
                <h2 class="text-lg font-semibold mb-6 flex items-center gap-2">
                    <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                        xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                            stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                    </svg>
                    Edit Toss Market
                </h2>

                <form action="/admin/event/<%= Event._id %>/update-toss" method="POST" class="space-y-4">
                    
                    <div class="bg-dark-bg p-3 rounded-lg border border-dark-border">
                        <label class="block text-xs font-bold text-gray-400 uppercase mb-2">Home Toss</label>
                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <label class="block text-[10px] text-back-blue uppercase mb-1 font-semibold">Back</label>
                                <input name="homeOdds" class="w-full bg-dark-surface border-dark-border rounded text-white focus-neon-blue py-1.5 text-sm transition-all" step="0.01" type="number" value="<%= Event.tossMarket.homeOdds %>" />
                            </div>
                            <div>
                                <label class="block text-[10px] text-lay-pink uppercase mb-1 font-semibold">Lay</label>
                                <input name="homeLay" class="w-full bg-dark-surface border-dark-border rounded text-white focus-neon-red py-1.5 text-sm transition-all" step="0.01" type="number" value="<%= Event.tossMarket.homeLay %>" />
                            </div>
                        </div>
                    </div>

                    <div class="bg-dark-bg p-3 rounded-lg border border-dark-border">
                        <label class="block text-xs font-bold text-gray-400 uppercase mb-2">Away Toss</label>
                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <label class="block text-[10px] text-back-blue uppercase mb-1 font-semibold">Back</label>
                                <input name="awayOdds" class="w-full bg-dark-surface border-dark-border rounded text-white focus-neon-blue py-1.5 text-sm transition-all" step="0.01" type="number" value="<%= Event.tossMarket.awayOdds %>" />
                            </div>
                            <div>
                                <label class="block text-[10px] text-lay-pink uppercase mb-1 font-semibold">Lay</label>
                                <input name="awayLay" class="w-full bg-dark-surface border-dark-border rounded text-white focus-neon-red py-1.5 text-sm transition-all" step="0.01" type="number" value="<%= Event.tossMarket.awayLay %>" />
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-3 pt-2">
                        <div>
                            <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">Toss Status</label>
                            <select name="status" class="w-full bg-dark-bg border-dark-border rounded-md text-sm text-white focus-neon-blue py-2">
                                <option value="active" <%= Event.tossMarket.status === 'active' ? 'selected' : '' %>>Active</option>
                                <option value="suspended" <%= Event.tossMarket.status === 'suspended' ? 'selected' : '' %>>Suspended</option>
                                <option value="settled" <%= Event.tossMarket.status === 'settled' ? 'selected' : '' %>>Settled</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">Toss Winner</label>
                            <select name="winner" class="w-full bg-dark-bg border-dark-border rounded-md text-sm text-white focus-neon-blue py-2">
                                <option value="" <%= !Event.tossMarket.winner ? 'selected' : '' %>>Undecided</option>
                                <option value="home" <%= Event.tossMarket.winner === 'home' ? 'selected' : '' %>>Home Team</option>
                                <option value="away" <%= Event.tossMarket.winner === 'away' ? 'selected' : '' %>>Away Team</option>
                            </select>
                        </div>
                    </div>

                    <button type="submit"
                        class="w-full mt-4 border border-gray-600 hover:border-white text-white font-bold py-3 rounded-md transition-all uppercase text-sm tracking-wider">
                        Update Toss Market
                    </button>
                </form>

                
            </section>

            <section class="col-span-1 md:col-span-2 lg:col-span-3 bg-dark-surface border border-dark-border rounded-xl p-6 shadow-xl" data-purpose="session-management">
                <div class="flex items-center justify-between mb-8">
                    <h2 class="text-xl font-bold flex items-center gap-2">
                        <svg class="h-6 w-6 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                        </svg>
                        Session / Fancy Markets
                    </h2>
                </div>

                <form action="/admin/event/<%= Event._id %>/add-session" method="POST" class="bg-dark-bg p-4 rounded-lg border border-dark-border mb-8">
                    <p class="text-xs font-semibold text-gray-500 uppercase mb-4 tracking-widest">New Market Entry</p>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-3 md:grid-cols-6 gap-4">
                        <div>
                            <label class="block text-xs text-gray-400 mb-1">Session Name</label>
                            <input name="name" required class="w-full bg-dark-surface border-dark-border rounded-md text-sm text-white focus-neon-blue" placeholder="e.g., 6 Overs Runs" type="text" />
                        </div>
                        
                        <div>
                            <label class="block text-xs text-gray-400 mb-1">Category</label>
                            <select name="category" class="w-full bg-dark-surface border-dark-border rounded-md text-sm text-white focus-neon-blue">
                                <option value="other">Other</option>
                                <option value="1st innings runs">1st Innings Runs</option>
                                <option value="2nd innings runs">2nd Innings Runs</option>
                                <option value="total runs">Total Runs</option>
                                <option value="wickets">Wickets</option>
                                <option value="toss">Toss</option>
                                <option value="match">Match</option>
                            </select>
                        </div>

                        <div>
                            <label class="block text-xs text-gray-400 mb-1">Line / Value</label>
                            <input name="value" required class="w-full bg-dark-surface border-dark-border rounded-md text-sm text-white focus-neon-blue" placeholder="45.5" step="0.1" type="number" />
                        </div>
                        
                        <div>
                            <label class="block text-xs text-gray-400 mb-1 text-neon-blue">Yes Odds (Back)</label>
                            <input name="yesOdds" required class="w-full bg-dark-surface border-dark-border rounded-md text-sm text-white focus-neon-blue" placeholder="1.90" step="0.01" type="number" />
                        </div>
                        
                        <div>
                            <label class="block text-xs text-gray-400 mb-1 text-neon-red">No Odds (Lay)</label>
                            <input name="noOdds" required class="w-full bg-dark-surface border-dark-border rounded-md text-sm text-white focus-neon-red" placeholder="1.90" step="0.01" type="number" />
                        </div>
                        
                        <div class="flex items-end">
                            <button type="submit" class="w-full bg-gray-100 hover:bg-white text-black font-bold py-2 rounded-md text-sm transition-all h-[38px]">
                                Add Market
                            </button>
                        </div>
                    </div>
                </form>

                <div class="overflow-x-auto">
                    <table class="w-full text-left" id="session-table">
                        <thead>
                            <tr class="text-[10px] uppercase tracking-widest text-gray-500 border-b border-dark-border">
                                <th class="pb-3 font-medium">Session Name</th>
                                <th class="pb-3 font-medium">Line</th>
                                <th class="pb-3 font-medium text-neon-blue">Yes (Back)</th>
                                <th class="pb-3 font-medium text-neon-red">No (Lay)</th>
                                <th class="pb-3 font-medium">Status</th>
                                <th class="pb-3 font-medium">Result</th>
                                <th class="pb-3 font-medium text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-dark-border">
                        <% (Event.sessions || []).filter(s => !s.isCombo).forEach(session => { %>
                            <form id="update-form-<%= session._id %>" action="/admin/event/<%= Event._id %>/update-session/<%= session._id %>" method="POST" class="hidden"></form>

                            <tr class="group hover:bg-white/5 transition-colors">
                                <td class="py-4 font-medium text-sm"><%= session.name %></td>
                                
                                <td class="py-4">
                                    <select form="update-form-<%= session._id %>" name="category" class="bg-dark-bg border-dark-border rounded text-[10px] py-1 text-gray-300 focus:ring-0 uppercase w-24 hidden">
                                        <option value="<%= session.category %>" selected><%= session.category %></option>
                                    </select>
                                    <span class="text-sm font-bold text-white"><%= session.value %></span>
                                </td>

                                <td class="py-4">
                                    <input form="update-form-<%= session._id %>" name="yesOdds" step="0.01" class="w-16 bg-dark-bg border-dark-border rounded text-xs py-1 focus-neon-blue" type="number" value="<%= session.yesOdds %>" />
                                </td>
                                <td class="py-4">
                                    <input form="update-form-<%= session._id %>" name="noOdds" step="0.01" class="w-16 bg-dark-bg border-dark-border rounded text-xs py-1 focus-neon-red" type="number" value="<%= session.noOdds %>" />
                                </td>
                                <td class="py-4">
                                    <select form="update-form-<%= session._id %>" name="status" class="bg-dark-bg border-dark-border rounded text-[10px] py-1 font-bold focus:ring-0 <%= session.status === 'active' ? 'text-green-500' : (session.status === 'suspended' ? 'text-yellow-500' : 'text-red-500') %>">
                                        <option value="active" <%= session.status === 'active' ? 'selected' : '' %>>ACTIVE</option>
                                        <option value="suspended" <%= session.status === 'suspended' ? 'selected' : '' %>>SUSPENDED</option>
                                        <option value="settled" <%= session.status === 'settled' ? 'selected' : '' %>>SETTLED</option>
                                    </select>
                                </td>
                                <td class="py-4">
                                    <select form="update-form-<%= session._id %>" name="result" class="bg-dark-bg border-dark-border rounded text-[10px] py-1 text-gray-300 focus:ring-0">
                                        <option value="" <%= !session.result ? 'selected' : '' %>>Open</option>
                                        <option value="yes" <%= session.result === 'yes' ? 'selected' : '' %>>YES</option>
                                        <option value="no" <%= session.result === 'no' ? 'selected' : '' %>>NO</option>
                                        <option value="void" <%= session.result === 'void' ? 'selected' : '' %>>VOID</option>
                                    </select>
                                </td>
                                <td class="py-4 text-right">
                                    <button form="update-form-<%= session._id %>" type="submit" class="px-3 py-1 bg-neon-blue/10 hover:bg-neon-blue/20 text-neon-blue border border-neon-blue/30 rounded text-xs font-bold transition-all">
                                        Update
                                    </button>
                                </td>
                            </tr>
                        <% }) %>
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="col-span-1 md:col-span-2 lg:col-span-3 bg-dark-surface border border-dark-border rounded-xl p-6 shadow-xl" data-purpose="combo-management">
                <div class="flex items-center justify-between mb-8">
                    <h2 class="text-xl font-bold flex items-center gap-2">
                        <svg class="h-6 w-6 text-neon-green" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                        </svg>
                        Combo Markets (SGPs)
                    </h2>
                </div>

                <form action="/admin/event/<%= Event._id %>/add-combo" method="POST" class="bg-dark-bg p-4 rounded-lg border border-dark-border mb-8">
                    <p class="text-xs font-semibold text-gray-500 uppercase mb-4 tracking-widest">Create New Combo</p>
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                        <div class="md:col-span-2">
                            <label class="block text-xs text-gray-400 mb-1">Combo Name</label>
                            <input name="name" required class="w-full bg-dark-surface border-dark-border rounded-md text-sm text-white focus-neon-green" placeholder="e.g., Kohli 50+ & Siraj 2+ Wickets" type="text" />
                        </div>
                        <div>
                            <label class="block text-xs text-gray-400 mb-1 text-neon-blue">Yes Odds (Back)</label>
                            <input name="yesOdds" required class="w-full bg-dark-surface border-dark-border rounded-md text-sm text-white focus-neon-blue" placeholder="5.50" step="0.01" type="number" />
                        </div>
                        <div>
                            <label class="block text-xs text-gray-400 mb-1 text-neon-red">No Odds (Lay)</label>
                            <input name="noOdds" required class="w-full bg-dark-surface border-dark-border rounded-md text-sm text-white focus-neon-red" placeholder="0.15" step="0.01" type="number" />
                        </div>
                        <div class="md:col-span-3">
                            <label class="block text-xs text-gray-400 mb-1">Combo Legs (Enter one condition per line)</label>
                            <textarea name="comboLegs" required rows="3" class="w-full bg-dark-surface border-dark-border rounded-md text-sm text-white focus-neon-green" placeholder="Kohli to score 50+ Runs&#10;Siraj to get 2+ Wickets"></textarea>
                        </div>
                        <div class="flex items-end">
                            <button type="submit" class="w-full bg-neon-green hover:bg-opacity-90 text-black font-bold py-2 rounded-md text-sm transition-all h-[38px] md:h-[72px]">
                                Add Combo
                            </button>
                        </div>
                    </div>
                </form>

                <div class="space-y-6">
                    <% (Event.sessions || []).filter(s => s.isCombo).forEach(session => { %>
                        <div class="bg-dark-bg border border-dark-border rounded-lg p-4 relative overflow-hidden">
                            <div class="absolute top-0 left-0 w-1 h-full bg-neon-green"></div>
                            <form action="/admin/event/<%= Event._id %>/update-combo/<%= session._id %>" method="POST">
                                <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-4 pb-4 border-b border-dark-border pl-3">
                                    <div>
                                        <h3 class="text-white font-bold text-lg"><%= session.name %></h3>
                                        <p class="text-xs text-gray-500 uppercase tracking-widest mt-1">Odds: <span class="text-neon-blue font-bold"><%= session.yesOdds %></span> / <span class="text-neon-red font-bold"><%= session.noOdds %></span></p>
                                    </div>
                                    <div class="flex items-center gap-3">
                                        <select name="status" class="bg-dark-surface border-dark-border rounded text-[10px] py-1 font-bold focus:ring-0 <%= session.status === 'active' ? 'text-green-500' : (session.status === 'suspended' ? 'text-yellow-500' : 'text-red-500') %>">
                                            <option value="active" <%= session.status === 'active' ? 'selected' : '' %>>ACTIVE</option>
                                            <option value="suspended" <%= session.status === 'suspended' ? 'selected' : '' %>>SUSPENDED</option>
                                            <option value="settled" <%= session.status === 'settled' ? 'selected' : '' %>>SETTLED</option>
                                        </select>
                                        
                                        <select name="result" class="bg-dark-surface border-dark-border rounded text-[10px] py-1 text-gray-300 focus:ring-0">
                                            <option value="" <%= !session.result ? 'selected' : '' %>>Open</option>
                                            <option value="yes" <%= session.result === 'yes' ? 'selected' : '' %>>YES (WON)</option>
                                            <option value="no" <%= session.result === 'no' ? 'selected' : '' %>>NO (LOST)</option>
                                            <option value="void" <%= session.result === 'void' ? 'selected' : '' %>>VOID</option>
                                        </select>
                                        
                                        <button type="submit" class="px-4 py-1.5 bg-neon-green/10 hover:bg-neon-green/20 text-neon-green border border-neon-green/30 rounded text-xs font-bold transition-all">
                                            Update Combo
                                        </button>
                                    </div>
                                </div>
                                
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-3 pl-3">
                                    <% session.comboLegs.forEach((leg, index) => { %>
                                        <div class="flex items-center justify-between bg-dark-surface p-2 rounded border border-dark-border">
                                            <span class="text-sm text-gray-300 truncate pr-2 flex items-center gap-2">
                                                <span class="w-1.5 h-1.5 rounded-full <%= leg.status === 'won' ? 'bg-green-500' : (leg.status === 'lost' ? 'bg-red-500' : 'bg-gray-500') %>"></span>
                                                <%= leg.description %>
                                            </span>
                                            <select name="legStatus_<%= index %>" class="bg-dark-bg border-dark-border rounded text-[10px] py-1 focus:ring-0 <%= leg.status === 'won' ? 'text-green-500' : (leg.status === 'lost' ? 'text-red-500' : 'text-gray-400') %>">
                                                <option value="pending" <%= leg.status === 'pending' ? 'selected' : '' %>>PENDING</option>
                                                <option value="won" <%= leg.status === 'won' ? 'selected' : '' %>>WON</option>
                                                <option value="lost" <%= leg.status === 'lost' ? 'selected' : '' %>>LOST</option>
                                            </select>
                                        </div>
                                    <% }) %>
                                </div>
                            </form>
                        </div>
                    <% }) %>
                </div>
            </section>
        </div>
    </main>

    <footer class="max-w-7xl mx-auto px-6 py-10 mt-10 border-t border-dark-border">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-gray-500 text-xs">
            <div class="flex items-center gap-4">
                <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-neon-green"></span> System Online</span>
                <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-neon-blue"></span> WebSockets Connected</span>
            </div>
            <p>© 2026 Admin Gaming Dashboard. Protected by Enterprise Encryption.</p>
        </div>
    </footer>

    <script data-purpose="table-interactivity">
        document.querySelectorAll('#session-table select[name="status"]').forEach(select => {
            select.addEventListener('change', (e) => {
                if (e.target.value === 'suspended') {
                    e.target.classList.remove('text-green-500');
                    e.target.classList.add('text-yellow-500');
                } else if (e.target.value === 'active') {
                    e.target.classList.remove('text-yellow-500', 'text-red-500');
                    e.target.classList.add('text-green-500');
                } else if (e.target.value === 'settled') {
                    e.target.classList.remove('text-green-500', 'text-yellow-500');
                    e.target.classList.add('text-red-500');
                }
            });
        });
    </script>
</body>
</html>