                    <div class="suspended-overlay absolute inset-0 backdrop-blur-[2px] opacity-0 flex items-center justify-center transition-opacity duration-300 z-10 stripes-anim">
                        <div class="flex items-center gap-2"><span class="material-symbols-outlined text-error/90 text-[24px] drop-shadow-md">lock</span><span class="text-error/90 font-black tracking-widest uppercase text-sm drop-shadow-md">Suspended</span></div>
                    </div>
                    <span class="text-error font-black text-xl tracking-widest uppercase relative z-0">Wicket</span>
                    <span class="text-error font-bold text-[10px] mt-1 tracking-widest relative z-0">11.5x</span>
