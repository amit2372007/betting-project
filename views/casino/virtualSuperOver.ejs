                    <button onclick="addStake(100)" class="flex-shrink-0 px-3 py-2 rounded-xl bg-surface-container hover:bg-surface-container-high text-xs font-black text-on-surface border border-white/5 active:bg-primary/20 transition-all">+100</button>
                    <button onclick="addStake(500)" class="flex-shrink-0 px-3 py-2 rounded-xl bg-surface-container hover:bg-surface-container-high text-xs font-black text-on-surface border border-white/5 active:bg-primary/20 transition-all">+500</button>
                    <button onclick="maxStake()" class="flex-shrink-0 px-3 py-2 rounded-xl bg-primary/10 text-xs font-black text-primary border border-primary/20 active:bg-primary/30 transition-all uppercase shadow-[0_0_10px_rgba(0,242,255,0.1)]">Max</button>
                </div>
            </div>
            
            <button id="submit-bet-btn" onclick="submitBet()" disabled class="w-full bg-surface-container text-on-surface-variant font-black py-4 rounded-2xl transition-all flex items-center justify-center gap-2 disabled-btn uppercase tracking-widest text-lg border border-white/5">
                <span class="material-symbols-outlined text-[20px]">sports_cricket</span>
                <span id="submit-btn-text">WAITING FOR MATCH</span>
            </button>
        </div>
    </footer>

    <script>
        // --- 1. GAME STATE ---
        let currentStake = 10;
        let selectedOutcome = null;
        let currentEventId = null;
        let isBettingOpen = false;
        let showDeliveryResult = false; 
        let previousRuns = -1;
        let previousWickets = -1;
        let myActiveBets = []; // Tracks bets for toast notifications
        
        // Multipliers map (Added Match Odds sample data)
        const multipliersMap = { 
            '0': 6.00, '1': 3.70, '2': 6.00, '3': 45.0, '4': 5.10, '6': 6.00, 'W': 11.50,
            'IND_WIN': 1.85, 'PAK_WIN': 2.10
        };
        
        // --- 2. DOM ELEMENTS ---
        const ui = {
            timerText: document.getElementById('timer-text'),
            timerLabel: document.getElementById('timer-label'),
            timerRing: document.getElementById('timer-ring'),
            liveCommentary: document.getElementById('live-commentary'),
            submitBtn: document.getElementById('submit-bet-btn'),
            submitBtnText: document.getElementById('submit-btn-text'),
            ballTimeline: document.getElementById('ball-timeline'),
            phaseBadge: document.getElementById('phase-badge'),
            phaseContainer: document.getElementById('phase-container'),
            scoreboardPanel: document.getElementById('scoreboard-panel'),
            
            matchIdText: document.getElementById('match-id-text'),
            tossInfo: document.getElementById('toss-info'),
            inningsBadge: document.getElementById('innings-badge'),
            homeContainer: document.getElementById('home-team-container'),
            homeScore: document.getElementById('home-score'),
            homeOvers: document.getElementById('home-overs'),
            awayContainer: document.getElementById('away-team-container'),
            awayScore: document.getElementById('away-score'),
            awayOvers: document.getElementById('away-overs'),
            
            equationContainer: document.getElementById('equation-container'),
            equationText: document.getElementById('equation-text'),
            targetScore: document.getElementById('target-score')
        };

        const betSlipContainer = document.getElementById('bet-slip-container');
        const stakeInput = document.getElementById('stake-input');
        const potentialWinDisplay = document.getElementById('potential-win');
        const walletEl = document.getElementById('wallet-balance');
        const userBal = parseFloat(walletEl.getAttribute('data-balance'));
        
        // --- TOAST SYSTEM ---
        function showToast(title, amount, type) {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            
            let bgClass = "bg-surface-container-high border-white/10 text-primary";
            let icon = "info";
            
            if (type === 'success') {
                bgClass = "bg-secondary-container/90 border-secondary text-secondary shadow-[0_0_20px_rgba(78,222,163,0.3)] backdrop-blur-md";
                icon = "check_circle";
            } else if (type === 'error') {
                bgClass = "bg-error-container/90 border-error text-error shadow-[0_0_20px_rgba(255,180,171,0.3)] backdrop-blur-md";
                icon = "cancel";
            }

            toast.className = `toast-enter flex items-center justify-between w-full max-w-sm rounded-xl p-3 border border-t-[1px] ${bgClass}`;
            toast.innerHTML = `
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-[24px]">${icon}</span>
                    <span class="font-black tracking-widest uppercase text-sm">${title}</span>
                </div>
                <span class="font-black text-lg">${amount}</span>
            `;

            container.appendChild(toast);
            setTimeout(() => {
                toast.classList.remove('toast-enter');
                toast.classList.add('toast-active');
            }, 10);
            setTimeout(() => {
                toast.classList.remove('toast-active');
                toast.classList.add('toast-enter');
                setTimeout(() => toast.remove(), 400); 
            }, 3000);
        }

        // --- 3. SOCKET CONNECTION ---
        const socket = io();

        socket.on('vso_sync', (state) => {

            if (state.matchOdds) {
                const indOdds = state.matchOdds.home.toFixed(2);
                const pakOdds = state.matchOdds.away.toFixed(2);
                
                // Update the UI text
                document.getElementById('ind-odds-text').innerText = indOdds + 'x';
                document.getElementById('pak-odds-text').innerText = pakOdds + 'x';

                // 🔥 CRITICAL: Update the JavaScript multipliers map so the Bet Slip calculates the correct potential payout based on the LIVE odds!
                multipliersMap['IND_WIN'] = parseFloat(indOdds);
                multipliersMap['PAK_WIN'] = parseFloat(pakOdds);

                // If the user currently has a Match Winner bet selected in their bet slip, recalculate their potential win instantly!
                if (selectedOutcome === 'IND_WIN' || selectedOutcome === 'PAK_WIN') {
                    updateStakeUI();
                }
            } 

            currentEventId = state.eventId;
            ui.matchIdText.innerText = state.eventId;

            if (state.toss && state.toss.winner) {
                const tossWinner = state.toss.winner === 'home' ? state.homeTeam : state.awayTeam;
                ui.tossInfo.innerText = `${tossWinner} WON TOSS, ELECTED TO ${state.toss.decision}`;
            }
            ui.inningsBadge.innerText = state.currentInnings === 1 ? '1ST INNINGS' : '2ND INNINGS';

            const homeIsInn1 = state.innings1.battingTeam === 'home';
            const homeScoreData = homeIsInn1 ? state.innings1 : state.innings2;
            const awayScoreData = homeIsInn1 ? state.innings2 : state.innings1;

            ui.homeScore.innerText = `${homeScoreData.runs}/${homeScoreData.wickets}`;
            ui.homeOvers.innerText = `${Math.floor(homeScoreData.balls / 6)}.${homeScoreData.balls % 6} OV`;
            
            ui.awayScore.innerText = `${awayScoreData.runs}/${awayScoreData.wickets}`;
            ui.awayOvers.innerText = `${Math.floor(awayScoreData.balls / 6)}.${awayScoreData.balls % 6} OV`;

            if (state.battingTeam === 'home') {
                ui.homeContainer.classList.remove('opacity-50');
                ui.homeScore.classList.add('text-primary', 'text-glow');
                ui.awayContainer.classList.add('opacity-50');
                ui.awayScore.classList.remove('text-primary', 'text-glow');
            } else {
                ui.awayContainer.classList.remove('opacity-50');
                ui.awayScore.classList.add('text-primary', 'text-glow');
                ui.homeContainer.classList.add('opacity-50');
                ui.homeScore.classList.remove('text-primary', 'text-glow');
            }

            ui.equationContainer.classList.remove('hidden');
            ui.equationContainer.classList.add('flex');

            if (state.currentInnings === 1) {
                ui.targetScore.parentElement.style.display = 'none'; 
                ui.equationText.innerText = `${state.innings1.runs} RUNS SCORED IN ${state.innings1.balls} BALLS`;
                ui.equationText.className = 'text-sm font-black text-primary uppercase tracking-widest text-glow';
            } else {
                ui.targetScore.parentElement.style.display = 'block'; 
                ui.targetScore.innerText = state.targetScore;
                
                const runsNeeded = state.targetScore - state.innings2.runs;
                const ballsLeft = 6 - state.innings2.balls;
                
                if (runsNeeded <= 0) {
                    ui.equationText.innerText = "TARGET CHASED! 🎉";
                    ui.equationText.className = 'text-sm font-black text-secondary uppercase tracking-widest text-glow-success';
                } else if (state.innings2.wickets >= 2 || ballsLeft <= 0) {
                    ui.equationText.innerText = "INNINGS OVER";
                    ui.equationText.className = 'text-sm font-black text-error uppercase tracking-widest text-glow-error';
                } else {
                    ui.equationText.innerText = `NEED ${runsNeeded} RUNS IN ${ballsLeft} BALLS`;
                    ui.equationText.className = 'text-sm font-black text-secondary uppercase tracking-widest text-glow-success';
                }
            }
            
            const activeInnings = state.currentInnings === 1 ? state.innings1 : state.innings2;
            
            const activeScoreEl = state.battingTeam === 'home' ? ui.homeScore : ui.awayScore;
            if (activeInnings.runs !== previousRuns || activeInnings.wickets !== previousWickets) {
                activeScoreEl.classList.remove('score-pulse-up', 'score-pulse-down');
                void activeScoreEl.offsetWidth; 
                if (activeInnings.wickets > previousWickets && previousWickets !== -1) {
                    activeScoreEl.classList.add('score-pulse-down');
                } else {
                    activeScoreEl.classList.add('score-pulse-up');
                }
                previousRuns = activeInnings.runs;
                previousWickets = activeInnings.wickets;
            }

            renderTimeline(activeInnings.timeline);
            updatePhaseUI(state);
        });

        socket.on('vso_event', (data) => {
            ui.liveCommentary.innerText = data.message;
            ui.liveCommentary.className = 'text-[11px] font-black tracking-wide whitespace-nowrap text-primary transition-colors';
        });

        socket.on('vso_delivery', (result) => {
            showDeliveryResult = true; 
            
            isBettingOpen = false;
            updateSubmitButton();

            ui.timerText.innerText = result.outcome === '0' ? 'DOT' : result.outcome;
            ui.timerText.classList.add('scale-150', 'text-glow');
            ui.timerLabel.innerText = result.outcome === 'W' ? 'OUT' : 'RUNS';

            ui.scoreboardPanel.classList.remove('flash-bg-error', 'flash-bg-success');
            ui.liveCommentary.className = 'text-[12px] font-black tracking-wide whitespace-nowrap uppercase transition-colors';
            
            if (result.outcome === 'W') {
                ui.timerText.classList.replace('text-primary', 'text-error');
                ui.timerText.classList.add('text-glow-error');
                ui.liveCommentary.classList.add('text-error');
                ui.scoreboardPanel.classList.add('flash-bg-error');
                ui.liveCommentary.innerText = "🚨 CLEAN BOWLED! WICKET FALLS!";
            } else if (['4', '6'].includes(result.outcome)) {
                ui.timerText.classList.replace('text-primary', 'text-secondary');
                ui.timerText.classList.add('text-glow-success');
                ui.liveCommentary.classList.add('text-secondary');
                ui.scoreboardPanel.classList.add('flash-bg-success');
                ui.liveCommentary.innerText = `🔥 MASSIVE HIT! IT'S A ${result.outcome}!`;
            } else {
                ui.liveCommentary.classList.add('text-primary');
                ui.liveCommentary.innerText = result.outcome === '0' ? "Solid defense. Dot ball." : `Pushed into the gap for ${result.outcome}.`;
            }
            
            setTimeout(() => {
                showDeliveryResult = false;
                ui.timerText.classList.remove('scale-150', 'text-glow', 'text-glow-error', 'text-glow-success');
                ui.timerText.classList.replace('text-error', 'text-primary');
                ui.timerText.classList.replace('text-secondary', 'text-primary');
                ui.scoreboardPanel.classList.remove('flash-bg-error', 'flash-bg-success');
            }, 4000);

            // FLASH TOASTS FOR WINS AND LOSSES
            if (myActiveBets.length > 0) {
                let totalWon = 0;
                let totalLost = 0;
                
                myActiveBets.forEach(bet => {
                    if (bet.selection === result.outcome) {
                        totalWon += bet.potentialWin;
                    } else if (['0','1','2','3','4','6','W'].includes(bet.selection)) { 
                        // Only calculate Next Ball bets here, ignore Match Odds for now
                        totalLost += bet.stake;
                    }
                });

                setTimeout(() => {
                    if (totalWon > 0) {
                        showToast("YOU WON! 🎉", `+₹${Math.floor(totalWon).toLocaleString('en-IN')}`, "success");
                        let currentBal = parseFloat(walletEl.getAttribute('data-balance'));
                        currentBal += totalWon;
                        walletEl.innerText = '₹' + Math.floor(currentBal).toLocaleString('en-IN');
                        walletEl.setAttribute('data-balance', currentBal);
                    } else if (totalLost > 0) {
                        showToast("BET LOST", `-₹${Math.floor(totalLost).toLocaleString('en-IN')}`, "error");
                    }
                }, 1500); 

                // Note: In a real system, keep 'IND_WIN'/'PAK_WIN' bets until 'match_end' phase
                myActiveBets = myActiveBets.filter(b => !['0','1','2','3','4','6','W'].includes(b.selection)); 
            }
        });

        socket.on('vso_match_result', (data) => {
            if (myActiveBets.length > 0) {
                let totalWon = 0;
                let totalLost = 0;
                
                // Map 'home'/'away' back to the UI selection strings
                let winningSelection = null;
                if (data.winner === 'home') winningSelection = 'IND_WIN';
                if (data.winner === 'away') winningSelection = 'PAK_WIN';

                myActiveBets.forEach(bet => {
                    if (data.winner === 'tie') {
                        // 🤝 TIE = REFUND
                        let currentBal = parseFloat(walletEl.getAttribute('data-balance'));
                        currentBal += bet.stake; // Refund stake
                        walletEl.innerText = '₹' + Math.floor(currentBal).toLocaleString('en-IN');
                        walletEl.setAttribute('data-balance', currentBal);
                        showToast("MATCH TIED", `₹${bet.stake} Refunded`, "info");
                    } else if (bet.selection === winningSelection) {
                        totalWon += bet.potentialWin; // potentialWin in UI actually holds total payout
                    } else {
                        totalLost += bet.stake;
                    }
                });

                // Show massive toast for Match Results
                setTimeout(() => {
                    if (totalWon > 0) {
                        showToast("MATCH WON! 🏆", `+₹${Math.floor(totalWon).toLocaleString('en-IN')}`, "success");
                        let currentBal = parseFloat(walletEl.getAttribute('data-balance'));
                        currentBal += totalWon;
                        walletEl.innerText = '₹' + Math.floor(currentBal).toLocaleString('en-IN');
                        walletEl.setAttribute('data-balance', currentBal);
                    } else if (totalLost > 0) {
                        showToast("MATCH LOST", `-₹${Math.floor(totalLost).toLocaleString('en-IN')}`, "error");
                    }
                }, 1000); 

                // Clear out the match bets
                myActiveBets = [];
            }
        });

        // --- HELPER FUNCTIONS ---
        function updatePhaseUI(state) {
            const updateRing = (sec, max) => ui.timerRing.style.strokeDashoffset = 264 - ((sec / max) * 264);

            if (state.phase === 'betting') {
                isBettingOpen = true;
                ui.phaseBadge.innerText = 'BETS OPEN';
                ui.phaseContainer.className = 'flex items-center space-x-1 bg-secondary-container/20 px-3 py-1 rounded-full border border-secondary/30';
                ui.phaseBadge.className = 'text-[10px] font-black uppercase tracking-wider text-secondary';
                
                if(!showDeliveryResult) {
                    ui.timerText.innerText = state.timer;
                    ui.timerLabel.innerText = 'SEC TO BET';
                    updateRing(state.timer, 10);
                }
                updateSubmitButton();

            } else if (state.phase === 'delivery') {
                isBettingOpen = false;
                ui.phaseBadge.innerText = 'BOWLING';
                ui.phaseContainer.className = 'flex items-center space-x-1 bg-error-container/20 px-3 py-1 rounded-full border border-error/30';
                ui.phaseBadge.className = 'text-[10px] font-black uppercase tracking-wider text-error';
                
                if(!showDeliveryResult) {
                    ui.timerText.innerText = 'BOWL';
                    ui.timerLabel.innerText = 'ACTION';
                    ui.timerRing.style.strokeDashoffset = 0; 
                }
                updateSubmitButton();

            } else {
                isBettingOpen = false;
                ui.phaseBadge.innerText = state.phase.toUpperCase();
                ui.phaseContainer.className = 'flex items-center space-x-1 bg-surface-container-high px-3 py-1 rounded-full border border-white/10';
                ui.phaseBadge.className = 'text-[10px] font-black uppercase tracking-wider text-on-surface-variant';
                
                if(!showDeliveryResult) {
                    ui.timerText.innerText = state.timer;
                    ui.timerLabel.innerText = state.phase === 'toss' ? 'TOSS' : 'BREAK';
                    updateRing(state.timer, 15);
                }
                updateSubmitButton();
            }
        }
        
        function renderTimeline(timelineArray) {
            ui.ballTimeline.innerHTML = ''; 
            
            timelineArray.forEach(ball => {
                let colorClass = "bg-surface-container-high border-white/10 text-on-surface";
                if (ball.outcome === 'W') colorClass = "bg-error-container border-error/30 text-error shadow-[0_0_8px_rgba(255,180,171,0.2)]";
                if (ball.outcome === '4' || ball.outcome === '6') colorClass = "bg-secondary-container border-secondary/30 text-secondary shadow-[0_0_8px_rgba(78,222,163,0.2)]";
                
                ui.ballTimeline.innerHTML += `
                    <div class="w-9 h-9 rounded-full flex items-center justify-center border font-black text-xs ${colorClass}">
                        ${ball.outcome}
                    </div>
                `;
            });

            const remaining = 6 - timelineArray.filter(b => b.isLegal).length;
            for(let i=0; i<remaining; i++) {
                ui.ballTimeline.innerHTML += `<div class="w-9 h-9 rounded-full border border-dashed border-white/20 flex items-center justify-center"></div>`;
            }
        }
        
        // --- BETTING & STAKE LOGIC ---
        const betOptions = document.querySelectorAll('.bet-option');
        betOptions.forEach(btn => {
            btn.addEventListener('click', (e) => {
                if(!isBettingOpen) return;
                betOptions.forEach(b => b.classList.remove('bet-selected'));
                const target = e.currentTarget;
                target.classList.add('bet-selected');
                selectedOutcome = target.getAttribute('data-outcome');
                updateSubmitButton();
            });
        });

        function deselectBet() {
            selectedOutcome = null;
            betOptions.forEach(b => b.classList.remove('bet-selected'));
            updateSubmitButton();
        }

        function customStake(val) {
            let num = parseInt(val);
            if(isNaN(num) || num < 0) num = 0;
            if(num > userBal) num = userBal; 
            currentStake = num;
            updateStakeUI();
        }

        function addStake(amount) { 
            currentStake += amount; 
            if (currentStake > userBal) currentStake = userBal; 
            stakeInput.value = currentStake;
            updateStakeUI(); 
        }
        function clearStake() { 
            currentStake = 10; 
            stakeInput.value = currentStake;
            updateStakeUI(); 
        }
        function maxStake() {
            currentStake = userBal;
            if (currentStake < 10) currentStake = 10; 
            stakeInput.value = currentStake;
            updateStakeUI();
        }

        function updateStakeUI() {
            if (selectedOutcome && multipliersMap[selectedOutcome]) {
                const potentialReturn = currentStake * multipliersMap[selectedOutcome];
                potentialWinDisplay.innerText = '₹' + Math.floor(potentialReturn).toLocaleString('en-IN');
            } else {
                potentialWinDisplay.innerText = '₹0';
            }
            
            if (isBettingOpen && selectedOutcome) {
                ui.submitBtnText.innerText = `PLACE ₹${Math.floor(currentStake).toLocaleString('en-IN')} BET`;
            }
        }

        function updateSubmitButton() {
            // Show or Hide Bet Slip
            if (selectedOutcome) {
                betSlipContainer.classList.remove('translate-y-full');
            } else {
                betSlipContainer.classList.add('translate-y-full');
            }

            updateStakeUI();

            // Toggle Suspended State on ALL grids
            const bettingGrid = document.getElementById('betting-grid');
            const matchOddsGrid = document.getElementById('match-odds-grid');
            
            if (!isBettingOpen) {
                bettingGrid.classList.add('bets-closed');
                matchOddsGrid.classList.add('bets-closed');
                
                ui.submitBtn.className = 'w-full bg-surface-container text-on-surface-variant font-black py-4 rounded-2xl flex items-center justify-center disabled-btn uppercase tracking-widest text-lg border border-white/5';
                ui.submitBtn.disabled = true;
                ui.submitBtnText.innerText = "BETS CLOSED";
                return;
            } else {
                bettingGrid.classList.remove('bets-closed');
                matchOddsGrid.classList.remove('bets-closed');
            }

            if (!selectedOutcome) {
                ui.submitBtn.className = 'w-full bg-surface-container-high text-primary/50 font-black py-4 rounded-2xl flex items-center justify-center disabled-btn uppercase tracking-widest text-lg border border-primary/20';
                ui.submitBtn.disabled = true;
                ui.submitBtnText.innerText = "SELECT OUTCOME";
                return;
            }
            ui.submitBtn.className = 'w-full bg-primary-container text-on-primary font-black py-4 rounded-2xl shadow-[0_0_30px_rgba(0,242,255,0.3)] transition-all flex items-center justify-center uppercase tracking-widest text-lg active:scale-[0.98]';
            ui.submitBtn.disabled = false;
        }

        function submitBet() {
            if(!isBettingOpen || !selectedOutcome || currentStake < 10) return;
            
            ui.submitBtn.className = 'w-full bg-secondary-container text-on-secondary font-black py-4 rounded-2xl shadow-[0_0_30px_rgba(0,165,114,0.3)] flex items-center justify-center uppercase tracking-widest text-lg disabled-btn';
            ui.submitBtnText.innerText = "LOCKING BET...";

            fetch('/vso/place-bet', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ eventId: currentEventId, selection: selectedOutcome, stake: currentStake })
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    walletEl.innerText = '₹' + Math.floor(data.newBalance).toLocaleString('en-IN');
                    walletEl.setAttribute('data-balance', data.newBalance);
                    ui.submitBtnText.innerText = "BET PLACED!";
                    
                    const pWin = currentStake * multipliersMap[selectedOutcome];
                    myActiveBets.push({ selection: selectedOutcome, stake: currentStake, potentialWin: pWin });
                    
                    showToast("BET PLACED", `₹${currentStake}`, "info");

                    setTimeout(() => { deselectBet(); }, 1500);
                } else {
                    showToast("ERROR", data.error, "error");
                    updateSubmitButton();
                }
            }).catch(err => {
                showToast("ERROR", "Network failure.", "error");
                updateSubmitButton();
            });
        }

        // --- 🏟️ VSO LIVE STADIUM ATTENDANCE (FIXED) ---
        let currentVSOPlayers = Math.floor(Math.random() * (10000 - 5000 + 1)) + 5000;
        const vsoPlayerDisplay = document.getElementById('vso-live-players');

        function simulateVSOLivePlayers() {
            if (!vsoPlayerDisplay) return;

            const change = Math.floor(Math.random() * 56) - 20; 
            currentVSOPlayers += change;

            if (currentVSOPlayers < 5000) currentVSOPlayers = 5000;
            if (currentVSOPlayers > 10000) currentVSOPlayers = 10000;

            vsoPlayerDisplay.innerText = currentVSOPlayers.toLocaleString();

            const nextUpdate = Math.floor(Math.random() * 2000) + 2000;
            setTimeout(simulateVSOLivePlayers, nextUpdate);
        }

        // Boot it up immediately on load
        simulateVSOLivePlayers();
    </script>
</body>
</html>