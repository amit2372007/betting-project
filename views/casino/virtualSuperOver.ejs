                    <span class="text-primary font-bold text-[10px] mt-1 tracking-widest relative z-0">6.0x</span>
                </button>
                <button data-outcome="1" class="bet-option relative overflow-hidden bg-surface-container hover:bg-surface-container-high border border-white/5 rounded-xl py-3 flex flex-col items-center transition-all">
                    <div class="suspended-overlay absolute inset-0 backdrop-blur-[2px] opacity-0 flex items-center justify-center transition-opacity duration-300 z-10 stripes-anim"><span class="material-symbols-outlined text-error/90 text-[20px] drop-shadow-md">lock</span></div>
                    <span class="text-on-surface font-black text-xl relative z-0">1</span>
                    <span class="text-primary font-bold text-[10px] mt-1 tracking-widest relative z-0">3.7x</span>
                </button>
                <button data-outcome="2" class="bet-option relative overflow-hidden bg-surface-container hover:bg-surface-container-high border border-white/5 rounded-xl py-3 flex flex-col items-center transition-all">
                    <div class="suspended-overlay absolute inset-0 backdrop-blur-[2px] opacity-0 flex items-center justify-center transition-opacity duration-300 z-10 stripes-anim"><span class="material-symbols-outlined text-error/90 text-[20px] drop-shadow-md">lock</span></div>
                    <span class="text-on-surface font-black text-xl relative z-0">2</span>
                    <span class="text-primary font-bold text-[10px] mt-1 tracking-widest relative z-0">6.0x</span>
                </button>
                <button data-outcome="3" class="bet-option relative overflow-hidden bg-surface-container hover:bg-surface-container-high border border-white/5 rounded-xl py-3 flex flex-col items-center transition-all">
                    <div class="suspended-overlay absolute inset-0 backdrop-blur-[2px] opacity-0 flex items-center justify-center transition-opacity duration-300 z-10 stripes-anim"><span class="material-symbols-outlined text-error/90 text-[20px] drop-shadow-md">lock</span></div>
                    <span class="text-on-surface font-black text-xl relative z-0">3</span>
                    <span class="text-primary font-bold text-[10px] mt-1 tracking-widest relative z-0">45x</span>
                </button>
                
                <button data-outcome="4" class="bet-option relative overflow-hidden col-span-2 bg-secondary-container/10 border border-secondary/20 rounded-xl py-3 flex flex-col items-center transition-all">
                    <div class="suspended-overlay absolute inset-0 backdrop-blur-[2px] opacity-0 flex items-center justify-center transition-opacity duration-300 z-10 stripes-anim"><span class="material-symbols-outlined text-error/90 text-[22px] drop-shadow-md">lock</span></div>
                    <span class="text-secondary font-black text-xl uppercase relative z-0">4 Runs</span>
                    <span class="text-secondary font-bold text-[10px] mt-1 tracking-widest relative z-0">5.1x</span>
                </button>
                <button data-outcome="6" class="bet-option relative overflow-hidden col-span-2 bg-secondary-container/20 border border-secondary/40 shadow-[0_0_15px_rgba(78,222,163,0.1)] rounded-xl py-3 flex flex-col items-center transition-all">
                    <div class="suspended-overlay absolute inset-0 backdrop-blur-[2px] opacity-0 flex items-center justify-center transition-opacity duration-300 z-10 stripes-anim"><span class="material-symbols-outlined text-error/90 text-[22px] drop-shadow-md">lock</span></div>
                    <span class="text-secondary font-black text-xl uppercase relative z-0">6 Runs</span>
