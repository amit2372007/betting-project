    <footer id="bet-slip-container" class="fixed bottom-0 left-0 w-full bg-[#131313]/95 backdrop-blur-xl border-t border-white/10 z-50 pb-safe rounded-t-[2rem] shadow-[0_-15px_40px_rgba(0,0,0,0.6)] transform translate-y-full transition-transform duration-300 ease-in-out">
        <button onclick="deselectBet()" class="absolute top-4 right-5 text-on-surface-variant hover:text-white">
            <span class="material-symbols-outlined text-[20px]">close</span>
        </button>
        
        <div class="w-12 h-1.5 bg-white/10 rounded-full mx-auto mt-3 mb-1"></div>

        <div class="px-5 py-4">
            <div class="flex items-end justify-between mb-4 px-1">
                <div class="flex flex-col">
                    <span class="text-[10px] uppercase font-bold text-on-surface-variant tracking-widest mb-1 flex items-center gap-1">
                        <span class="material-symbols-outlined text-[12px]">account_balance_wallet</span> Wallet
                    </span>
                    <span id="wallet-balance" class="text-on-surface font-bold text-sm tracking-wide" data-balance="<%= typeof user !== 'undefined' ? user.balance : 0 %>">
