<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Virtual Super Over | Premium Casino</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <script src="/socket.io/socket.io.js"></script>
    
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary-container": "#00f2ff", "primary": "#e1fdff", "background": "#131313",
                        "on-primary": "#00363a", "surface-container": "#201f1f", "surface-container-low": "#1c1b1b",
                        "secondary": "#4edea3", "secondary-container": "#00a572",
                        "on-surface": "#e5e2e1", "surface": "#131313",
                        "error-container": "#93000a", "error": "#ffb4ab", "surface-container-high": "#2a2a2a",
                        "on-surface-variant": "#b9cacb"
                    },
                    fontFamily: { "body": ["Inter", "sans-serif"] },
                    borderRadius: { "2xl": "1.5rem" },
                }
            }
        }
    </script>
    <style>
        .glass-panel { background: rgba(32, 31, 31, 0.6); backdrop-filter: blur(16px); border: 1px solid rgba(58, 73, 75, 0.15); transition: all 0.3s ease; }
        .neon-glow-primary { box-shadow: 0 0 20px rgba(0, 242, 255, 0.2); }
        .text-glow { text-shadow: 0 0 12px rgba(0, 242, 255, 0.5); }
        .text-glow-error { text-shadow: 0 0 15px rgba(255, 180, 171, 0.7); }
        .text-glow-success { text-shadow: 0 0 15px rgba(78, 222, 163, 0.7); }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        
        /* Smooth Animations */
        .status-pulse { animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: .5; } }
        
        .score-pulse-up { animation: scorePopUp 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        @keyframes scorePopUp { 0% { transform: scale(1); } 50% { transform: scale(1.2); color: #4edea3; } 100% { transform: scale(1); } }
        
        .score-pulse-down { animation: scorePopDown 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        @keyframes scorePopDown { 0% { transform: scale(1); } 50% { transform: scale(1.2); color: #ffb4ab; } 100% { transform: scale(1); } }

        /* UI States */
        .bet-selected { border-color: #00f2ff !important; background-color: rgba(0, 242, 255, 0.1) !important; box-shadow: 0 0 15px rgba(0, 242, 255, 0.2); transform: scale(0.95); }
        .disabled-btn { opacity: 0.4; pointer-events: none; filter: grayscale(100%); transition: all 0.3s; }
        .flash-bg-error { background: rgba(147, 0, 10, 0.3) !important; }
        .flash-bg-success { background: rgba(0, 165, 114, 0.3) !important; }
        
        /* --- Suspended Betting Animations --- */
        .bets-closed .bet-option {
            pointer-events: none;
            border-color: rgba(255, 180, 171, 0.15) !important;
            transform: scale(0.98);
        }
        .bets-closed .bet-option .suspended-overlay {
            opacity: 1 !important;
        }
        .stripes-anim {
            background-image: repeating-linear-gradient(
                -45deg,
                rgba(0, 0, 0, 0.6),
                rgba(0, 0, 0, 0.6) 10px,
                rgba(255, 180, 171, 0.08) 10px,
                rgba(255, 180, 171, 0.08) 20px
            );
            background-size: 28px 28px;
            animation: moveStripes 1s linear infinite;
        }
        @keyframes moveStripes {
            0% { background-position: 0 0; }
            100% { background-position: 28px 0; }
        }

        /* Toast Animations */
        .toast-enter { transform: translateY(-150%); opacity: 0; }
        .toast-active { transform: translateY(0); opacity: 1; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }

        /* Hide arrows on number input */
        input[type=number]::-webkit-inner-spin-button, 
        input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
        input[type=number] { -moz-appearance: textfield; background: transparent; }
    </style>
</head>

<body class="bg-background text-on-surface font-body min-h-screen flex flex-col pb-16">
    
    <div id="toast-container" class="fixed top-4 left-0 w-full z-[100] flex flex-col items-center gap-2 pointer-events-none px-4"></div>

    <header class="fixed top-0 w-full z-50 bg-[#131313] shadow-[0_20px_40px_rgba(0,219,231,0.04)]">
        <div class="flex items-center px-5 h-16 w-full">
            <a href="/home" class="text-[#00f2ff] active:scale-95 transition-transform mr-4">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
            <h1 class="font-bold text-lg tracking-tight text-[#e1fdff]">Super Over Live</h1>
            
            <div class="ml-auto flex items-center space-x-2 sm:space-x-4">
                
