                </div>
                <div class="flex flex-col items-end text-right">
                    <span class="text-[10px] uppercase font-bold text-primary tracking-widest mb-1 flex items-center gap-1">
                        Potential Return <span class="material-symbols-outlined text-[12px]">payments</span>
                    </span>
                    <span id="potential-win" class="text-primary font-black text-xl tracking-tight text-glow">₹0</span>
                </div>
            </div>

