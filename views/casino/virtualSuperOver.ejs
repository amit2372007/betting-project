            </div>
            
            <div class="grid grid-cols-2 gap-2.5" id="match-odds-grid">
                <button data-outcome="IND_WIN" class="bet-option relative overflow-hidden bg-surface-container hover:bg-surface-container-high border border-white/5 rounded-xl py-3 flex flex-col items-center transition-all">
                    <div class="suspended-overlay absolute inset-0 backdrop-blur-[2px] opacity-0 flex items-center justify-center transition-opacity duration-300 z-10 stripes-anim">
                        <span class="material-symbols-outlined text-error/90 text-[20px] drop-shadow-md">lock</span>
                    </div>
                    <span class="text-on-surface font-black text-lg relative z-0">India</span>
                    <span id="ind-odds-text" class="text-primary font-bold text-[10px] mt-1 tracking-widest relative z-0">1.85x</span>
                </button>

                <button data-outcome="PAK_WIN" class="bet-option relative overflow-hidden bg-surface-container hover:bg-surface-container-high border border-white/5 rounded-xl py-3 flex flex-col items-center transition-all">
                    <div class="suspended-overlay absolute inset-0 backdrop-blur-[2px] opacity-0 flex items-center justify-center transition-opacity duration-300 z-10 stripes-anim">
                        <span class="material-symbols-outlined text-error/90 text-[20px] drop-shadow-md">lock</span>
                    </div>
                    <span class="text-on-surface font-black text-lg relative z-0">Pakistan</span>
                    <span id="pak-odds-text" class="text-primary font-bold text-[10px] mt-1 tracking-widest relative z-0">2.10x</span>
                </button>
            </div>
        </section>

        <section class="space-y-3 pb-20">
            <div class="flex items-center justify-between px-1">
                <h3 class="text-sm font-bold uppercase tracking-widest text-on-surface-variant flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary text-[18px]">ads_click</span>
                    Predict Next Ball
                </h3>
            </div>
            <div class="grid grid-cols-4 gap-2.5" id="betting-grid">
                <button data-outcome="0" class="bet-option relative overflow-hidden bg-surface-container hover:bg-surface-container-high border border-white/5 rounded-xl py-3 flex flex-col items-center transition-all">
                    <div class="suspended-overlay absolute inset-0 backdrop-blur-[2px] opacity-0 flex items-center justify-center transition-opacity duration-300 z-10 stripes-anim"><span class="material-symbols-outlined text-error/90 text-[20px] drop-shadow-md">lock</span></div>
