<!DOCTYPE html>
<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Betting Exchange Login V2</title>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#f28b0d",
                        "secondary-green": "#28a745",
                        "background-light": "#f8f7f5",
                        "background-dark": "#050505",
                        "surface": "#121212"
                    },
                    fontFamily: {
                        "display": ["Lexend", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "1rem", "lg": "2rem", "xl": "3rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        /* Custom scrollbar for webkit */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #1a1a1a; }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }
        body { min-height: max(884px, 100dvh); }
        
        /* Auto-fill styling fix for dark mode */
        input:-webkit-autofill,
        input:-webkit-autofill:hover, 
        input:-webkit-autofill:focus, 
        input:-webkit-autofill:active{
            -webkit-box-shadow: 0 0 0 30px #121212 inset !important;
            -webkit-text-fill-color: white !important;
        }

        /* Flash Message Animations */
        @keyframes slideDown {
            0% { transform: translate(-50%, -100%); opacity: 0; }
            100% { transform: translate(-50%, 0); opacity: 1; }
        }
        @keyframes fadeOut {
            0% { opacity: 1; }
            100% { opacity: 0; visibility: hidden; }
        }
        .animate-slide-down { animation: slideDown 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        .animate-fade-out { animation: fadeOut 0.3s ease-out forwards; }
    </style>
</head>

<body class="bg-background-light dark:bg-background-dark text-white font-display min-h-screen flex items-center justify-center p-4 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] relative">
    
    <% if (error && error.length) { %>
        <div id="flash-error" class="fixed top-6 left-1/2 -translate-x-1/2 z-50 flex items-center gap-3 bg-red-500/10 border border-red-500/30 text-red-500 px-5 py-3.5 rounded-2xl shadow-[0_0_20px_rgba(239,68,68,0.15)] backdrop-blur-md animate-slide-down min-w-[300px]">
            <span class="material-symbols-outlined text-2xl">error</span>
            <p class="text-sm font-bold tracking-wide flex-1"><%= error %></p>
            <button onclick="dismissFlash('flash-error')" class="opacity-60 hover:opacity-100 transition-opacity flex items-center justify-center">
                <span class="material-symbols-outlined text-lg">close</span>
            </button>
        </div>
    <% } %>

    <% if (success && success.length) { %>
        <div id="flash-success" class="fixed top-6 left-1/2 -translate-x-1/2 z-50 flex items-center gap-3 bg-secondary-green/10 border border-secondary-green/30 text-secondary-green px-5 py-3.5 rounded-2xl shadow-[0_0_20px_rgba(40,167,69,0.15)] backdrop-blur-md animate-slide-down min-w-[300px]">
            <span class="material-symbols-outlined text-2xl">check_circle</span>
            <p class="text-sm font-bold tracking-wide flex-1"><%= success %></p>
            <button onclick="dismissFlash('flash-success')" class="opacity-60 hover:opacity-100 transition-opacity flex items-center justify-center">
                <span class="material-symbols-outlined text-lg">close</span>
            </button>
        </div>
    <% } %>
    <div class="relative w-full max-w-md mx-auto flex flex-col bg-[#0a0a0a] border border-white/10 shadow-[0_0_40px_rgba(242,139,13,0.15)] rounded-3xl overflow-hidden min-h-[800px]">
        
        <div class="pt-6 pb-6 px-6 text-center flex flex-col items-center">
            <h1 class="text-4xl font-extrabold tracking-tight mb-2">
                <span class="text-secondary-green drop-shadow-[0_0_8px_rgba(40,167,69,0.5)]">WICKET</span><span class="text-white">ADDA</span>
            </h1>
            <p class="text-[10px] font-bold text-primary uppercase tracking-[0.2em] opacity-90">
                Greater Odds. Greater Winnings.
            </p>
        </div>

        <div class="px-8 space-y-6">
            <form action="/user/login" method="POST" class="flex flex-col gap-4">
                
                <div class="group relative">
                    <label class="block text-gray-400 text-xs font-bold mb-1.5 pl-1 uppercase tracking-wide" for="username">Username</label>
                    <div class="flex items-center bg-surface border border-gray-800 rounded-xl px-4 py-3 focus-within:border-primary focus-within:ring-1 focus-within:ring-primary transition-all shadow-inner">
                        <span class="material-symbols-outlined text-gray-500 mr-3 text-xl group-focus-within:text-primary transition-colors">person</span>
                        <input name="username" id="username" type="text" placeholder="Enter username" required
                            class="bg-transparent border-none outline-none focus:ring-0 text-white placeholder-gray-600 flex-1 p-0 text-base font-medium" />
                    </div>
                </div>

                <div class="group relative">
                    <label class="block text-gray-400 text-xs font-bold mb-1.5 pl-1 uppercase tracking-wide" for="password">Password</label>
                    <div class="flex items-center bg-surface border border-gray-800 rounded-xl px-4 py-3 focus-within:border-primary focus-within:ring-1 focus-within:ring-primary transition-all shadow-inner">
                        <span class="material-symbols-outlined text-gray-500 mr-3 text-xl group-focus-within:text-primary transition-colors">lock</span>
                        <input name="password" id="password" type="password" placeholder="Enter password" required
                            class="bg-transparent border-none outline-none focus:ring-0 text-white placeholder-gray-600 flex-1 p-0 text-base font-medium" />
                        <button type="button" onclick="togglePassword()" class="ml-2 flex items-center justify-center text-gray-500 hover:text-white transition-colors focus:outline-none">
                            <span id="eye-icon" class="material-symbols-outlined text-xl">visibility_off</span>
                        </button>
                    </div>
                </div>

                <div class="flex items-center justify-between pt-1 pb-2">
                    <label class="flex items-center gap-2 cursor-pointer group">
                        <div class="relative flex items-center justify-center w-5 h-5">
                            <input class="peer appearance-none w-5 h-5 border-2 border-gray-600 rounded bg-surface checked:bg-primary checked:border-primary focus:ring-0 transition-all cursor-pointer" type="checkbox" name="remember" />
                            <span class="material-symbols-outlined absolute text-black text-sm pointer-events-none opacity-0 peer-checked:opacity-100 font-bold" style="font-size: 14px;">check</span>
                        </div>
                        <span class="text-gray-400 text-sm font-medium group-hover:text-white transition-colors">Remember Me</span>
                    </label>
                </div>

                <button type="submit" class="w-full bg-gradient-to-r from-primary to-[#ff6b00] hover:from-[#ff6b00] hover:to-[#e65c00] text-black font-black text-lg py-3.5 rounded-xl uppercase tracking-widest shadow-[0_0_20px_rgba(242,139,13,0.3)] transition-all active:scale-[0.98] mt-2">
                    Secure Login
                </button>
            </form>

            <a href="/user/demo-login" class="w-full bg-[#1a1a1a] border border-secondary-green/50 hover:bg-secondary-green/20 text-secondary-green font-bold text-sm py-3.5 rounded-xl uppercase tracking-widest transition-all active:scale-[0.98] flex items-center justify-center gap-2 shadow-sm">
                <span class="material-symbols-outlined text-lg">play_circle</span>
                Play Demo Account
            </a>
        </div>

        <div class="px-8 mt-6 flex items-center justify-center gap-4">
            <div class="h-[1px] bg-gradient-to-r from-transparent to-gray-800 flex-1"></div>
            <span class="text-gray-500 text-[10px] font-bold uppercase tracking-widest">Support</span>
            <div class="h-[1px] bg-gradient-to-l from-transparent to-gray-800 flex-1"></div>
        </div>

        <div class="px-6 mt-3 flex-1 flex flex-col">
            <p class="text-center text-gray-400 text-xs font-medium mb-4">
                Need a ready-made ID? Contact us on WhatsApp.
            </p>
            
            <div class="grid grid-cols-3 gap-3 mb-6">
                <div class="bg-surface rounded-xl p-3 flex flex-col items-center justify-center text-center gap-2 border border-white/5 shadow-sm">
                    <span class="material-symbols-outlined text-primary text-2xl">diamond</span>
                    <span class="text-[9px] leading-tight text-gray-400 font-bold uppercase">New Session<br />Market</span>
                </div>
                <div class="bg-surface rounded-xl p-3 flex flex-col items-center justify-center text-center gap-2 border border-white/5 shadow-sm">
                    <span class="material-symbols-outlined text-primary text-2xl">support_agent</span>
                    <span class="text-[9px] leading-tight text-gray-400 font-bold uppercase">1 To 1<br />Support</span>
                </div>
                <div class="bg-surface rounded-xl p-3 flex flex-col items-center justify-center text-center gap-2 border border-white/5 shadow-sm">
                    <span class="material-symbols-outlined text-primary text-2xl">payments</span>
                    <span class="text-[9px] leading-tight text-gray-400 font-bold uppercase">Instant<br />Deposit & Withdrawal</span>
                </div>
            </div>

            <a href="https://wa.me/918102073403?text=Hi,%20I%20need%20a%20new%20ID." target="_blank"
                class="w-full bg-[#25D366] hover:bg-[#1ebd57] text-white font-extrabold text-sm py-4 rounded-xl uppercase tracking-wider flex items-center justify-center gap-2 shadow-[0_0_15px_rgba(37,211,102,0.3)] mb-8 transition-all active:scale-[0.98]">
                <img src="https://upload.wikimedia.org/wikipedia/commons/6/6b/WhatsApp.svg" alt="WhatsApp" class="w-6 h-6 filter brightness-0 invert" />
                GET NEW ID ( 100% BONUS )
            </a>

            <div class="mt-auto mb-6 text-center">
                <a class="text-gray-500 text-[10px] font-bold uppercase tracking-widest hover:text-primary transition-colors underline decoration-dotted underline-offset-4" href="#">
                    Whitelabel Enquiries
                </a>
            </div>
        </div>
    </div>

    <script>
        function togglePassword() {
            const passwordInput = document.getElementById('password');
            const eyeIcon = document.getElementById('eye-icon');
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                eyeIcon.textContent = 'visibility';
                eyeIcon.classList.add('text-primary');
            } else {
                passwordInput.type = 'password';
                eyeIcon.textContent = 'visibility_off';
                eyeIcon.classList.remove('text-primary');
            }
        }

        // Script to handle Flash Messages auto-dismissal
        function dismissFlash(elementId) {
            const el = document.getElementById(elementId);
            if (el) {
                el.classList.add('animate-fade-out');
                setTimeout(() => el.remove(), 300); // Remove from DOM after animation completes
            }
        }

        // Auto dismiss after 4 seconds
        document.addEventListener('DOMContentLoaded', () => {
            setTimeout(() => {
                dismissFlash('flash-error');
                dismissFlash('flash-success');
            }, 4000);
        });
    </script>
</body>
</html>