<!DOCTYPE html>
<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0, viewport-fit=cover" name="viewport" />
    <title>Change Password - Premium Sports &amp; Casino</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&amp;family=Manrope:wght@200..800&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#fd941b",
                        "primary-dim": "#e98500",
                        "background": "#0e0e0e",
                        "surface": "#121212",
                        "surface-container-highest": "#262626",
                        "on-surface": "#ffffff",
                        "on-surface-variant": "#adaaaa",
                        "on-secondary": "#535151",
                        "success": "#28a745",
                        "error": "#ff7351"
                    },
                    fontFamily: {
                        "headline": ["Space Grotesk", "sans-serif"],
                        "body": ["Manrope", "sans-serif"],
                        "label": ["Manrope", "sans-serif"]
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .glass-glow {
            background: rgba(38, 38, 38, 0.6);
            backdrop-filter: blur(20px);
            border-top: 1px solid rgba(253, 148, 27, 0.2);
            border-left: 1px solid rgba(253, 148, 27, 0.2);
        }
        body { min-height: max(884px, 100dvh); }
        
        /* Toast Animations */
        @keyframes toastEnter { 0% { opacity: 0; transform: translateX(100%) scale(0.9); } 100% { opacity: 1; transform: translateX(0) scale(1); } }
        @keyframes toastLeave { 0% { opacity: 1; transform: translateX(0) scale(1); } 100% { opacity: 0; transform: translateX(100%) scale(0.9); } }
        .toast-enter { animation: toastEnter 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
        .toast-leave { animation: toastLeave 0.3s ease-in forwards; }
    </style>
</head>

<body class="bg-background text-on-surface font-body selection:bg-primary/30 min-h-screen flex flex-col pb-[100px]">
    
    <div id="toast-container" class="fixed top-20 right-4 z-[100] flex flex-col gap-3 pointer-events-none w-full max-w-[280px]"></div>

    <header class="fixed top-0 w-full z-50 bg-[#0a0a0a]/90 backdrop-blur-xl flex items-center justify-between px-6 h-16 w-full border-b border-white/5">
        <div class="flex items-center gap-4">
            <a href="/home?tab=Profile" class="text-primary hover:opacity-80 transition-opacity active:scale-95 duration-200 flex items-center">
                <span class="material-symbols-outlined">arrow_back_ios</span>
            </a>
        </div>
        <h1 class="font-headline font-bold uppercase tracking-widest text-lg text-on-surface">CHANGE PASSWORD</h1>
        <div class="w-6"></div> </header>

    <main class="flex-grow pt-24 px-6 flex flex-col items-center justify-start w-full max-w-md mx-auto">
        <div class="mb-10 text-center flex flex-col items-center">
            <div class="relative group">
                <div class="absolute -inset-1 bg-primary/20 blur-xl rounded-full opacity-75 group-hover:opacity-100 transition duration-1000"></div>
                <div class="relative w-24 h-24 rounded-full glass-glow flex items-center justify-center shadow-[0_0_30px_rgba(253,148,27,0.15)]">
                    <span class="material-symbols-outlined text-primary text-5xl" style="font-variation-settings: 'FILL' 1;">lock_reset</span>
                </div>
            </div>
            <div class="mt-8 space-y-2">
                <h2 class="font-headline font-bold text-2xl tracking-tight text-white">Secure Your Realm</h2>
                <p class="text-on-surface-variant text-sm max-w-[280px] leading-relaxed mx-auto">
                    Your password must be at least 8 characters long to ensure elite-level security.
                </p>
            </div>
        </div>

        <form id="password-form" class="w-full space-y-5" onsubmit="submitPasswordChange(event)">
            
            <div class="space-y-1.5">
                <label class="font-label text-[10px] uppercase tracking-[0.2em] text-on-surface-variant px-1 font-bold">Current Password</label>
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <span class="material-symbols-outlined text-on-secondary group-focus-within:text-primary transition-colors">lock</span>
                    </div>
                    <input id="current-password" name="currentPassword" class="w-full h-14 bg-surface-container-highest rounded-xl border border-white/5 focus:border-primary focus:ring-1 focus:ring-primary/20 bg-transparent pl-12 pr-12 text-on-surface placeholder:text-on-secondary transition-all outline-none shadow-inner" placeholder="••••••••" type="password" required />
                    <button type="button" onclick="toggleVisibility('current-password', 'eye-current')" class="absolute inset-y-0 right-0 pr-4 flex items-center text-on-secondary hover:text-on-surface transition-colors focus:outline-none">
                        <span id="eye-current" class="material-symbols-outlined">visibility_off</span>
                    </button>
                </div>
            </div>

            <div class="space-y-1.5">
                <label class="font-label text-[10px] uppercase tracking-[0.2em] text-on-surface-variant px-1 font-bold">New Password</label>
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <span class="material-symbols-outlined text-on-secondary group-focus-within:text-primary transition-colors">key</span>
                    </div>
                    <input id="new-password" name="newPassword" oninput="validatePassword()" class="w-full h-14 bg-surface-container-highest rounded-xl border border-white/5 focus:border-primary focus:ring-1 focus:ring-primary/20 bg-transparent pl-12 pr-12 text-on-surface placeholder:text-on-secondary transition-all outline-none shadow-inner" placeholder="••••••••" type="password" required />
                    <button type="button" onclick="toggleVisibility('new-password', 'eye-new')" class="absolute inset-y-0 right-0 pr-4 flex items-center text-on-secondary hover:text-on-surface transition-colors focus:outline-none">
                        <span id="eye-new" class="material-symbols-outlined">visibility_off</span>
                    </button>
                </div>
            </div>

            <div class="space-y-1.5">
                <label class="font-label text-[10px] uppercase tracking-[0.2em] text-on-surface-variant px-1 font-bold">Confirm New Password</label>
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <span class="material-symbols-outlined text-on-secondary group-focus-within:text-primary transition-colors">lock_person</span>
                    </div>
                    <input id="confirm-password" name="confirmPassword" class="w-full h-14 bg-surface-container-highest rounded-xl border border-white/5 focus:border-primary focus:ring-1 focus:ring-primary/20 bg-transparent pl-12 pr-12 text-on-surface placeholder:text-on-secondary transition-all outline-none shadow-inner" placeholder="••••••••" type="password" required />
                    <button type="button" onclick="toggleVisibility('confirm-password', 'eye-confirm')" class="absolute inset-y-0 right-0 pr-4 flex items-center text-on-secondary hover:text-on-surface transition-colors focus:outline-none">
                        <span id="eye-confirm" class="material-symbols-outlined">visibility_off</span>
                    </button>
                </div>
            </div>

            <div class="pt-2 px-2 space-y-3 bg-[#161616] p-4 rounded-xl border border-white/5">
                <div class="flex items-center gap-3">
                    <div id="check-bg-length" class="w-5 h-5 rounded-full bg-surface-container-highest flex items-center justify-center transition-colors duration-300">
                        <span id="check-icon-length" class="material-symbols-outlined text-[14px] text-on-secondary transition-colors duration-300">check</span>
                    </div>
                    <span id="text-length" class="text-xs text-on-surface-variant tracking-wide font-medium transition-colors duration-300">Minimum 8 characters</span>
                </div>
                <div class="flex items-center gap-3">
                    <div id="check-bg-num" class="w-5 h-5 rounded-full bg-surface-container-highest flex items-center justify-center transition-colors duration-300">
                        <span id="check-icon-num" class="material-symbols-outlined text-[14px] text-on-secondary transition-colors duration-300">check</span>
                    </div>
                    <span id="text-num" class="text-xs text-on-surface-variant tracking-wide font-medium transition-colors duration-300">At least 1 number</span>
                </div>
                <div class="flex items-center gap-3">
                    <div id="check-bg-spec" class="w-5 h-5 rounded-full bg-surface-container-highest flex items-center justify-center transition-colors duration-300">
                        <span id="check-icon-spec" class="material-symbols-outlined text-[14px] text-on-secondary transition-colors duration-300">check</span>
                    </div>
                    <span id="text-spec" class="text-xs text-on-surface-variant tracking-wide font-medium transition-colors duration-300">At least 1 special character</span>
                </div>
            </div>

            <div class="pt-4">
                <button id="submit-btn" class="w-full h-16 rounded-xl bg-gradient-to-r from-[#f28b0d] to-[#d97706] text-white font-headline font-black uppercase tracking-[0.25em] text-sm shadow-[0_10px_20px_-5px_rgba(242,139,13,0.4)] active:scale-[0.98] transition-all duration-150 flex items-center justify-center" type="submit">
                    UPDATE PASSWORD
                </button>
            </div>
        </form>
    </main>

    <nav class="fixed bottom-0 left-0 w-full flex justify-around items-center px-4 py-3 pb-safe bg-[#131313]/95 backdrop-blur-2xl rounded-t-2xl z-50 border-t border-white/5">
        <a class="flex flex-col items-center justify-center text-on-surface-variant hover:text-white transition-colors active:scale-90 duration-150" href="/home">
            <span class="material-symbols-outlined mb-1">home</span>
            <span class="font-label font-medium text-[10px] tracking-widest uppercase">Home</span>
        </a>
        <a class="flex flex-col items-center justify-center text-primary bg-primary/10 border border-primary/20 rounded-xl px-4 py-1.5 transition-colors active:scale-90 duration-150 shadow-inner" href="/user/profile">
            <span class="material-symbols-outlined mb-1" style="font-variation-settings: 'FILL' 1;">person</span>
            <span class="font-label font-bold text-[10px] tracking-widest uppercase">Profile</span>
        </a>
    </nav>

    <script>
        // Premium Toast Notifications
        function showToast(title, message, type = 'info') {
            const container = document.getElementById('toast-container');
            if (!container) return;
            const toast = document.createElement('div');
            let bgClass = "bg-surface-container-highest border-white/10";
            let icon = "info"; let iconColor = "text-on-surface-variant"; let glow = "shadow-lg";

            if (type === 'success') {
                bgClass = "bg-[#28a745]/10 border-[#28a745]/30 backdrop-blur-md";
                icon = "check_circle"; iconColor = "text-[#28a745]"; glow = "shadow-[0_0_20px_rgba(40,167,69,0.3)]";
            } else if (type === 'error') {
                bgClass = "bg-[#ff7351]/10 border-[#ff7351]/30 backdrop-blur-md";
                icon = "error"; iconColor = "text-[#ff7351]"; glow = "shadow-[0_0_20px_rgba(255,115,81,0.3)]";
            }

            toast.className = `toast-enter flex items-center justify-between w-full rounded-xl p-3 border ${bgClass} ${glow} pointer-events-auto`;
            toast.innerHTML = `<div class="flex items-center gap-3"><span class="material-symbols-outlined text-[28px] ${iconColor}">${icon}</span><div class="flex flex-col"><span class="font-black tracking-widest uppercase text-[11px] text-white">${title}</span><span class="font-bold text-[10px] text-white/60 tracking-wide">${message}</span></div></div>`;
            container.appendChild(toast);
            setTimeout(() => { toast.classList.replace('toast-enter', 'toast-leave'); setTimeout(() => toast.remove(), 300); }, 3000);
        }

        // Toggle Password Visibility
        function toggleVisibility(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility';
                icon.classList.add('text-primary');
            } else {
                input.type = 'password';
                icon.textContent = 'visibility_off';
                icon.classList.remove('text-primary');
            }
        }

        // Real-Time Password Validation
        function validatePassword() {
            const val = document.getElementById('new-password').value;
            
            // Check 1: Length
            const isLength = val.length >= 8;
            updateChecklist('length', isLength);
            
            // Check 2: Number
            const isNum = /\d/.test(val);
            updateChecklist('num', isNum);
            
            // Check 3: Special Character
            const isSpec = /[!@#$%^&*(),.?":{}|<>]/.test(val);
            updateChecklist('spec', isSpec);
        }

        function updateChecklist(idSuffix, isValid) {
            const bg = document.getElementById(`check-bg-${idSuffix}`);
            const icon = document.getElementById(`check-icon-${idSuffix}`);
            const text = document.getElementById(`text-${idSuffix}`);

            if (isValid) {
                bg.classList.replace('bg-surface-container-highest', 'bg-success/20');
                icon.classList.replace('text-on-secondary', 'text-success');
                text.classList.replace('text-on-surface-variant', 'text-white');
            } else {
                bg.classList.replace('bg-success/20', 'bg-surface-container-highest');
                icon.classList.replace('text-success', 'text-on-secondary');
                text.classList.replace('text-white', 'text-on-surface-variant');
            }
        }

        // Handle AJAX Form Submission
        async function submitPasswordChange(e) {
            e.preventDefault();
            const currentPassword = document.getElementById('current-password').value;
            const newPassword = document.getElementById('new-password').value;
            const confirmPassword = document.getElementById('confirm-password').value;
            const btn = document.getElementById('submit-btn');

            if (newPassword !== confirmPassword) {
                return showToast("MISMATCH", "New passwords do not match.", "error");
            }
            if (newPassword.length < 8 || !/\d/.test(newPassword) || !/[!@#$%^&*(),.?":{}|<>]/.test(newPassword)) {
                return showToast("WEAK PASSWORD", "Please meet all security requirements.", "error");
            }

            btn.disabled = true;
            btn.innerHTML = '<span class="material-symbols-outlined animate-spin">sync</span>';

            try {
                const response = await fetch('/user/change-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ currentPassword, newPassword, confirmPassword })
                });
                
                const data = await response.json();

                if (data.success) {
                    showToast("SUCCESS!", "Password updated securely.", "success");
                    document.getElementById('password-form').reset();
                    validatePassword(); // Reset checklist
                    // Optional: Redirect back to profile after a short delay
                    setTimeout(() => window.location.href = '/user/profile', 2000);
                } else {
                    showToast("UPDATE FAILED", data.error || "Incorrect current password.", "error");
                }
            } catch (error) {
                showToast("NETWORK ERROR", "Unable to reach security server.", "error");
            } finally {
                btn.disabled = false;
                btn.innerHTML = 'UPDATE PASSWORD';
            }
        }
    </script>
</body>
</html>