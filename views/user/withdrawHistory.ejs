<% layout('layouts/boilerplate.ejs') -%>
<main class="max-w-md mx-auto px-4">
    <% 
        let totalWithdrawn = 0;
        let pendingAmount = 0;
        userWithdraw.forEach(tx => {
            if(tx.status === 'approved') totalWithdrawn += tx.amount;
            if(tx.status === 'pending') pendingAmount += tx.amount;
        });
    %>
    <div class="mt-4 flex gap-4">
        <div class="flex-1 bg-slate-100 dark:bg-surface-dark p-5 rounded-2xl border border-slate-200 dark:border-white/5 shadow-sm">
            <div class="flex items-center gap-2 mb-2">
                <span class="material-symbols-outlined text-primary text-xl">payments</span>
                <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Total Approved</p>
            </div>
            <p class="text-2xl font-bold noto-font tracking-tight">₹<%= totalWithdrawn.toLocaleString('en-IN') %></p>
        </div>
        <div class="flex-1 bg-slate-100 dark:bg-surface-dark p-5 rounded-2xl border border-slate-200 dark:border-white/5 shadow-sm">
            <div class="flex items-center gap-2 mb-2">
                <span class="material-symbols-outlined text-primary text-xl">pending_actions</span>
                <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Pending</p>
            </div>
            <p class="text-2xl font-bold noto-font tracking-tight text-primary">₹<%= pendingAmount.toLocaleString('en-IN') %></p>
        </div>
    </div>

    <div class="mt-8 mb-4">
        <h2 class="text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-widest px-1">Recent Transactions</h2>
    </div>

    <div class="space-y-3">
        <% if (userWithdraw && userWithdraw.length > 0) { %>
            <% userWithdraw.sort((a, b) => b.createdAt - a.createdAt).forEach(tx => { %>
                <div class="bg-slate-100 dark:bg-surface-dark p-4 rounded-2xl border border-slate-200 dark:border-white/5 flex flex-col gap-3 group active:scale-[0.98] transition-transform">
                    <div class="flex justify-between items-start">
                        <div class="flex items-center gap-3">
                            <div class="size-10 rounded-xl bg-slate-200 dark:bg-accent-dark flex items-center justify-center">
                                <span class="material-symbols-outlined text-slate-600 dark:text-white">account_balance</span>
                            </div>
                            <div>
                                <h3 class="font-bold text-base"><%= tx.bankDetails.bankName || 'Bank Withdrawal' %></h3>
                                <p class="text-[11px] text-slate-500 dark:text-slate-400 noto-font">
                                    ID: #<%= tx.transactionId %> • <%= new Date(tx.createdAt).toLocaleString('en-IN', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                                </p>
                            </div>
                        </div>
                        <div class="text-right">
                            <p class="text-lg font-bold noto-font">₹<%= tx.amount.toLocaleString('en-IN') %></p>
                        </div>
                    </div>
                    <div class="flex justify-end">
                        <% 
                            let statusClass = "bg-primary/10 text-primary border-primary/20";
                            let dotClass = "bg-primary";
                            if(tx.status === 'approved') {
                                statusClass = "bg-emerald-500/10 text-emerald-500 border-emerald-500/20";
                                dotClass = "bg-emerald-500";
                            } else if(tx.status === 'rejected') {
                                statusClass = "bg-rose-500/10 text-rose-500 border-rose-500/20";
                                dotClass = "bg-rose-500";
                            }
                        %>
                        <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider border flex items-center gap-1 <%= statusClass %>">
                            <span class="size-1.5 rounded-full <%= dotClass %>"></span>
                            <%= tx.status.charAt(0).toUpperCase() + tx.status.slice(1) %>
                        </span>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="flex flex-col items-center justify-center py-20 text-center opacity-40">
                <span class="material-symbols-outlined text-6xl mb-4">history_toggle_off</span>
                <p class="text-sm font-medium">No withdrawal requests found</p>
            </div>
        <% } %>
    </div>
</main>