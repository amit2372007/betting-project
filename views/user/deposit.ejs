<% layout('layouts/boilerplate.ejs') -%>
<script id="tailwind-config">
    tailwind.config = {
        darkMode: "class",
        theme: {
            extend: {
                colors: {
                    "primary": "#ff8c00",
                    "background-light": "#f8f7f5",
                    "background-dark": "#0a0a0a",
                    "container-dark": "#1a1a1a",
                    "input-dark": "#2a2a2a",
                },
                fontFamily: {
                    "display": ["Lexend", "Noto Sans", "sans-serif"]
                },
                borderRadius: {
                    "DEFAULT": "1rem", "lg": "2rem", "xl": "3rem", "full": "9999px"
                },
                boxShadow: {
                    'glow': '0px 0px 20px 0px rgba(255, 140, 0, 0.4)',
                }
            },
        },
    }
</script>
<style>
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    .form-input-focus:focus-within { border-color: rgba(255, 140, 0, 0.5); box-shadow: 0 0 0 2px rgba(255, 140, 0, 0.2); }
    
    /* Toast Animations */
    @keyframes toastEnter { 0% { opacity: 0; transform: translateY(100%) scale(0.9); } 100% { opacity: 1; transform: translateY(0) scale(1); } }
    @keyframes toastLeave { 0% { opacity: 1; transform: translateY(0) scale(1); } 100% { opacity: 0; transform: translateY(100%) scale(0.9); } }
    .toast-enter { animation: toastEnter 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
    .toast-leave { animation: toastLeave 0.3s ease-in forwards; }
</style>

<body class="bg-background-light dark:bg-background-dark font-display text-white min-h-screen flex flex-col">
    
    <div id="toast-container" class="fixed bottom-24 left-1/2 -translate-x-1/2 z-[100] flex flex-col gap-2 pointer-events-none w-max"></div>

    <header class="sticky top-0 z-50 bg-background-light dark:bg-background-dark border-b border-white/5 px-4 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
            <a href="/home?tab=Profile"><span class="material-symbols-outlined text-white cursor-pointer hover:text-primary transition-colors active:scale-95">arrow_back_ios</span></a>
            <h1 class="text-xl font-bold tracking-tight">Deposit Funds</h1>
        </div>
    </header>

    <form action="/transaction/deposit" method="POST" class="flex-1 overflow-y-auto pb-32">
        
        <section class="mt-6">
            <h2 class="px-4 text-sm font-semibold uppercase tracking-widest text-white/50 mb-4">Select Payment Method</h2>
            
            <div class="flex overflow-x-auto no-scrollbar gap-4 px-4 pb-4">
                <% if (depositAccounts && depositAccounts.length > 0) { %>
                    <% depositAccounts.forEach(account => { %>
                        
                        <% if (account.methodType === 'qr_scanner' || account.methodType === 'upi') { %>
                            <div class="flex-shrink-0 w-72 bg-container-dark rounded-lg p-5 border border-white/10 flex flex-col gap-4 shadow-lg">
                                <div class="flex justify-between items-start">
                                    <p class="text-lg font-bold leading-tight text-white"><%= account.displayName %></p>
                                    <% if (account.methodType === 'qr_scanner') { %>
                                        <span class="text-[10px] bg-primary text-black font-bold px-2 py-0.5 rounded-full uppercase tracking-widest shadow-glow">Fastest</span>
                                    <% } %>
                                </div>
                                
                                <% if (account.qrCodeUrl) { %>
                                    <div class="w-full aspect-square bg-white rounded-xl p-3 flex items-center justify-center">
                                        <img src="<%= account.qrCodeUrl %>" alt="QR Code" class="w-full h-full object-contain rounded-lg">
                                    </div>
                                <% } %>
                                
                                <% if (account.upiDetails && account.upiDetails.upiId) { %>
                                    <button type="button" onclick="copyToClipboard('<%= account.upiDetails.upiId %>', 'UPI ID')" class="w-full py-3 bg-white/5 hover:bg-primary hover:text-black rounded-xl flex items-center justify-center gap-2 text-sm font-bold transition-all active:scale-95 border border-white/10 mt-auto">
                                        <span class="material-symbols-outlined text-[18px]">content_copy</span> Copy <%= account.upiDetails.upiId %>
                                    </button>
                                <% } %>
                            </div>
                        <% } %>

                        <% if (account.methodType === 'bank_transfer' && account.bankDetails) { %>
                            <div class="flex-shrink-0 w-72 bg-container-dark rounded-lg p-5 border-2 border-primary flex flex-col gap-4 relative shadow-glow">
                                <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-primary text-black text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest shadow-lg">Recommended</div>
                                <p class="text-lg font-bold leading-tight mt-1"><%= account.displayName %></p>
                                
                                <div class="space-y-2">
                                    <div class="flex flex-col bg-black/40 p-3 rounded-xl gap-1 border border-white/5 hover:border-primary/50 transition-colors">
                                        <p class="text-[10px] text-white/40 uppercase font-bold tracking-wider">Account Number</p>
                                        <div class="flex justify-between items-center">
                                            <span class="font-mono text-sm text-primary font-bold"><%= account.bankDetails.accountNumber %></span>
                                            <span class="material-symbols-outlined text-lg cursor-pointer text-white/60 hover:text-primary active:scale-90 transition-all" onclick="copyToClipboard('<%= account.bankDetails.accountNumber %>', 'Account Number')">content_copy</span>
                                        </div>
                                    </div>
                                    <div class="flex flex-col bg-black/40 p-3 rounded-xl gap-1 border border-white/5 hover:border-primary/50 transition-colors">
                                        <p class="text-[10px] text-white/40 uppercase font-bold tracking-wider">IFSC Code</p>
                                        <div class="flex justify-between items-center">
                                            <span class="font-mono text-sm text-primary font-bold"><%= account.bankDetails.ifscCode %></span>
                                            <span class="material-symbols-outlined text-lg cursor-pointer text-white/60 hover:text-primary active:scale-90 transition-all" onclick="copyToClipboard('<%= account.bankDetails.ifscCode %>', 'IFSC Code')">content_copy</span>
                                        </div>
                                    </div>
                                    <div class="flex flex-col bg-black/40 p-3 rounded-xl gap-1 border border-white/5 hover:border-primary/50 transition-colors">
                                        <p class="text-[10px] text-white/40 uppercase font-bold tracking-wider">Account Holder</p>
                                        <div class="flex justify-between items-center">
                                            <span class="font-mono text-sm text-primary font-bold truncate pr-2"><%= account.bankDetails.accountName %></span>
                                            <span class="material-symbols-outlined text-lg cursor-pointer text-white/60 hover:text-primary active:scale-90 transition-all" onclick="copyToClipboard('<%= account.bankDetails.accountName %>', 'Account Name')">content_copy</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% } %>

                    <% }) %>
                <% } else { %>
                    <div class="w-full bg-container-dark rounded-xl p-6 border border-white/10 text-center flex flex-col items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-4xl text-white/20">account_balance</span>
                        <p class="text-white/60 font-medium">No deposit methods currently available.<br>Please contact support.</p>
                    </div>
                <% } %>
            </div>
        </section>

        <section class="mt-4 px-4">
            <h2 class="text-sm font-semibold uppercase tracking-widest text-white/50 mb-4">Submit Deposit Proof</h2>
            <div class="bg-container-dark rounded-2xl p-5 border border-white/10 space-y-5">
                
                <div class="space-y-2">
                    <label class="text-xs font-bold text-white/80 uppercase tracking-wider pl-1">Transaction ID / UTR</label>
                    <div class="relative">
                        <input name="transactionId" required class="w-full bg-input-dark border border-white/5 rounded-xl h-14 pl-12 pr-4 text-base focus:ring-1 focus:ring-primary focus:border-primary outline-none transition-all placeholder:text-white/20" placeholder="Enter 12-digit UTR number" type="text" />
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/40">receipt_long</span>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="text-xs font-bold text-white/80 uppercase tracking-wider pl-1">Deposit Amount</label>
                    <div class="relative">
                        <span class="absolute left-5 top-1/2 -translate-y-1/2 text-primary font-black text-xl">₹</span>
                        <input name="amount" id="deposit-amount" required min="100" class="w-full bg-input-dark border border-white/5 rounded-xl h-14 pl-12 pr-4 text-lg font-black focus:ring-1 focus:ring-primary focus:border-primary outline-none transition-all placeholder:text-white/20" placeholder="0.00" type="number" oninput="updateBonusDisplay()" />
                    </div>
                    <p class="text-[10px] text-primary/80 font-bold uppercase tracking-wider pl-1">* Minimum deposit: ₹100</p>
                </div>

                <div class="space-y-2 pt-4 border-t border-white/5 mt-2">
                    <label class="text-xs font-bold text-white/80 uppercase tracking-wider pl-1 flex items-center justify-between">
                        <span>Promo Code (Optional)</span>
                    </label>
                    
                    <div class="flex items-center justify-between bg-primary/10 border border-primary/20 rounded-xl p-3 mb-2 cursor-pointer hover:bg-primary/20 transition-colors active:scale-[0.98]" onclick="document.getElementById('promo-input').value = 'WICKET5'">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary text-lg">redeem</span>
                            <span class="text-xs font-medium text-white/80">Use code <span class="text-primary font-bold tracking-widest">WICKET5</span> for 5% Bonus</span>
                        </div>
                        <span class="text-[9px] bg-primary text-black font-black px-2 py-0.5 rounded-sm uppercase tracking-widest">Tap</span>
                    </div>

                    <div class="flex gap-2 relative">
                        <div class="relative flex-1">
                            <input id="promo-input" class="w-full bg-input-dark border border-white/5 rounded-xl h-12 pl-10 pr-4 text-sm font-bold focus:ring-1 focus:ring-primary focus:border-primary outline-none transition-all placeholder:text-white/20 uppercase" placeholder="ENTER CODE" type="text" />
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-white/40 text-[18px]">local_activity</span>
                        </div>
                        <button type="button" onclick="applyPromo()" id="promo-btn" class="bg-white/10 hover:bg-primary hover:text-black text-white px-5 rounded-xl font-bold text-xs uppercase tracking-widest transition-all active:scale-95 border border-white/10">Apply</button>
                    </div>
                    
                    <p id="bonus-message" class="text-[11px] text-[#28a745] font-bold uppercase tracking-wider pl-1 hidden transition-all"></p>
                </div>
                </div>
        </section>

        <div class="px-4 mt-8">
            <button type="submit" class="w-full bg-gradient-to-r from-primary to-[#ff6b00] text-black font-black text-lg py-4 rounded-xl shadow-[0_0_20px_rgba(255,140,0,0.3)] active:scale-[0.98] transition-all uppercase tracking-widest">
                Submit Request
            </button>
        </div>

        <section class="mt-6 px-4">
    <div class="bg-container-dark rounded-2xl p-5 border border-white/10 flex items-center justify-between gap-4 relative overflow-hidden">
        <div class="absolute -right-8 -top-8 w-32 h-32 bg-[#25D366]/10 rounded-full blur-2xl pointer-events-none"></div>

        <div class="flex flex-col z-10">
            <h3 class="text-white font-bold text-base mb-1">Need help depositing?</h3>
            <p class="text-white/50 text-xs">Our support team is online 24/7 to assist you.</p>
        </div>
        
        <a href="https://wa.me/<%=whatsaapNumber.phoneNumber%>?text=Hello%20WicketAdda%20Support,%20I%20need%20help%20with%20my%20deposit." 
           target="_blank"
           class="z-10 flex-shrink-0 bg-[#25D366] hover:bg-[#20bd5a] text-black w-12 h-12 rounded-full flex items-center justify-center shadow-[0_0_15px_rgba(37,211,102,0.3)] transition-all active:scale-90">
            <svg class="w-6 h-6 ml-[1px] mt-[1px]" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
            </svg>
        </a>
    </div>
</section>
    </form>

    

    <script>
        // Premium Copy with Toast Notification
        function copyToClipboard(text, itemType) {
            navigator.clipboard.writeText(text).then(() => {
                showToast("COPIED!", `${itemType} copied to clipboard.`);
            }).catch(err => {
                console.error('Failed to copy: ', err);
                showToast("ERROR", "Failed to copy text.", true);
            });
        }

        // Custom Toast Function
        function showToast(title, message, isError = false) {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            
            const bgColor = isError ? 'bg-[#ff3b30]' : 'bg-[#28a745]';
            const icon = isError ? 'error' : 'check_circle';

            toast.className = `toast-enter flex items-center gap-3 px-4 py-2.5 rounded-full ${bgColor} text-white shadow-xl pointer-events-auto`;
            toast.innerHTML = `
                <span class="material-symbols-outlined text-[20px]">${icon}</span>
                <div class="flex flex-col">
                    <span class="font-bold text-[11px] uppercase tracking-widest leading-none">${title}</span>
                </div>
            `;
            
            container.appendChild(toast);
            
            setTimeout(() => {
                toast.classList.replace('toast-enter', 'toast-leave');
                setTimeout(() => toast.remove(), 300);
            }, 2500);
        }

        // ==============================================
        // UI ONLY PROMO LOGIC
        // ==============================================
        let isPromoApplied = false;
        const VALID_PROMO_CODE = "WICKET5";

        function applyPromo() {
            const inputEl = document.getElementById('promo-input');
            const code = inputEl.value.trim().toUpperCase();

            if (!code) {
                showToast("ERROR", "Please enter a promo code", true);
                return;
            }

            if (code !== VALID_PROMO_CODE) {
                showToast("INVALID", "This code is invalid or expired", true);
                inputEl.value = '';
                return;
            }

            // Success UI State
            isPromoApplied = true;
            showToast("SUCCESS", "5% Bonus Coupon Applied!");
            
            // Lock the input
            inputEl.disabled = true;
            inputEl.classList.add('text-primary', 'border-primary/50', 'bg-primary/5');
            
            const btn = document.getElementById('promo-btn');
            btn.innerText = "Applied";
            btn.classList.replace('hover:bg-primary', 'bg-[#28a745]');
            btn.classList.replace('hover:text-black', 'text-white');
            btn.classList.remove('bg-white/10');
            btn.disabled = true;

            updateBonusDisplay();
        }

        function updateBonusDisplay() {
            if (!isPromoApplied) return;
            
            const amountEl = document.getElementById('deposit-amount');
            const amount = parseFloat(amountEl.value) || 0;
            const msgEl = document.getElementById('bonus-message');
            
            if (amount >= 100) {
                const bonus = (amount * 0.05).toFixed(2);
                msgEl.innerHTML = `🎉 5% Bonus Active! Extra <span class="text-white bg-black/50 px-1 rounded">+₹${bonus}</span> credited on approval.`;
                msgEl.classList.remove('hidden');
            } else {
                msgEl.classList.add('hidden');
            }
        }
    </script>
</body>